---
import BaseLayout from '../components/layout/BaseLayout.astro';
import { guidePlaces, guideCategories } from '../data/bkkGuide';

const placesJson  = JSON.stringify(guidePlaces);
const catsJson    = JSON.stringify(guideCategories);
const mapboxToken = import.meta.env.PUBLIC_MAPBOX_TOKEN;

const areas = [...new Set(guidePlaces.map(p => p.area))].sort();
---

<BaseLayout
  title="Bangkok Map 2026 — Bars, Clubs, Hotels, Food & Sightseeing"
  description="Interactive Bangkok map for Songkran 2026. Bars, clubs, saunas, hotels, food, sightseeing and more."
  canonical="https://bkksongkran.com/map"
  noindex={true}
>

<!-- FULL-HEIGHT MAP SHELL -->
<div id="map-shell">

  <!-- LEFT SIDEBAR -->
  <aside id="cat-sidebar">
    <div class="sidebar-header">
      <div class="sidebar-title font-headline">BKK<br/>GUIDE</div>
      <div class="sidebar-sub">{guidePlaces.length} places</div>
    </div>

    <nav class="sidebar-nav">
      <button class="sidebar-btn active-sidebar" data-cat="all">
        <span class="sidebar-icon material-symbols-outlined" style="font-variation-settings:'FILL' 1;color:#003345;">apps</span>
        <span class="sidebar-label">All Places</span>
        <span class="sidebar-count">{guidePlaces.length}</span>
      </button>
      {guideCategories.map(c => (
        <button class="sidebar-btn" data-cat={c.id}>
          <span class="sidebar-icon material-symbols-outlined" style={`color:${c.color};font-variation-settings:'FILL' 1;`}>{c.icon}</span>
          <span class="sidebar-label">{c.label}</span>
          <span class="sidebar-count">{guidePlaces.filter(p => p.category === c.id).length}</span>
        </button>
      ))}
    </nav>
  </aside>

  <!-- CENTER: Map + floating controls -->
  <div id="map-center">
    <!-- Area chips floating over map top -->
    <div id="area-chips">
      <button class="area-chip area-active" data-area="all">All Areas</button>
      {areas.map(area => (
        <button class="area-chip" data-area={area}>{area}</button>
      ))}
    </div>

    <!-- Map canvas -->
    <div id="guide-map"></div>

    <!-- Location button -->
    <button id="locate-btn" aria-label="My location">
      <span class="material-symbols-outlined" style="font-variation-settings:'FILL' 1;">my_location</span>
    </button>
  </div>

  <!-- RIGHT: Detail panel -->
  <div id="detail-panel">
    <button id="close-panel" aria-label="Close panel">
      <span class="material-symbols-outlined">close</span>
    </button>

    <!-- Gradient image header -->
    <div id="panel-header">
      <span id="panel-badge"></span>
    </div>

    <!-- Content body -->
    <div id="panel-body">
      <h2 id="panel-name"></h2>
      <p id="panel-sub"></p>

      <div id="panel-stats">
        <div class="stat-card">
          <div class="stat-label">Type</div>
          <div id="stat-cat" class="stat-value"></div>
        </div>
        <div class="stat-card">
          <div class="stat-label">Neighbourhood</div>
          <div id="stat-area" class="stat-value"></div>
        </div>
      </div>

      <p id="panel-tip"></p>

      <div id="panel-actions">
        <a id="panel-directions" href="#" target="_blank" rel="noopener noreferrer" class="btn-directions">
          <span class="material-symbols-outlined" style="font-size:18px;font-variation-settings:'FILL' 1;">near_me</span>
          Get Directions
        </a>
        <button id="panel-share" class="btn-share" aria-label="Share">
          <span class="material-symbols-outlined">ios_share</span>
        </button>
      </div>

      <div id="panel-nearby">
        <div class="nearby-title">Nearby Places</div>
        <div id="nearby-list"></div>
      </div>
    </div>
  </div>

</div>

<!-- MOBILE BOTTOM CATEGORY BAR -->
<div id="mobile-cats">
  <div id="mobile-cats-inner">
    <button class="mobile-cat active-mobile" data-cat="all">
      <span class="material-symbols-outlined" style="font-variation-settings:'FILL' 1;color:#003345;">apps</span>
      <span>All</span>
    </button>
    {guideCategories.map(c => (
      <button class="mobile-cat" data-cat={c.id}>
        <span class="material-symbols-outlined" style={`color:${c.color};font-variation-settings:'FILL' 1;`}>{c.icon}</span>
        <span>{c.label}</span>
      </button>
    ))}
  </div>
</div>

</BaseLayout>

<link href="https://api.mapbox.com/mapbox-gl-js/v3.3.0/mapbox-gl.css" rel="stylesheet" />

<style is:global>
  /* Full-screen map page overrides */
  body { overflow: hidden !important; }
  footer { display: none !important; }
  main  { padding: 0 !important; min-height: unset !important; }
</style>

<style>
/* ── Shell ───────────────────────────────── */
#map-shell {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  z-index: 5; /* navbar is z-40, floats above */
  display: flex;
  overflow: hidden;
  background: #f0f7ff;
}

/* ── Left Sidebar ────────────────────────── */
#cat-sidebar {
  width: 220px;
  flex-shrink: 0;
  background: white;
  border-right: 1px solid rgba(192,232,255,0.6);
  display: flex;
  flex-direction: column;
  overflow-y: auto;
  z-index: 10;
  padding-top: 88px; /* clear floating navbar */
}

.sidebar-header {
  padding: 16px 16px 12px;
  border-bottom: 1px solid rgba(192,232,255,0.6);
}

.sidebar-title {
  font-size: 1.4rem;
  font-weight: 900;
  color: #003345;
  line-height: 1;
  letter-spacing: -0.02em;
}

.sidebar-sub {
  font-size: 10px;
  font-weight: 600;
  color: #6b8fa3;
  margin-top: 3px;
  text-transform: uppercase;
  letter-spacing: 0.1em;
}

.sidebar-nav {
  padding: 8px 8px;
  display: flex;
  flex-direction: column;
  gap: 2px;
}

.sidebar-btn {
  display: flex;
  align-items: center;
  gap: 10px;
  width: 100%;
  padding: 9px 10px;
  border-radius: 10px;
  border: none;
  background: none;
  cursor: pointer;
  text-align: left;
  transition: background 0.15s;
  color: #326177;
}

.sidebar-btn:hover { background: rgba(0,100,121,0.06); }

.sidebar-btn.active-sidebar {
  background: #003345;
  color: white;
}
.sidebar-btn.active-sidebar .sidebar-icon { color: white !important; }
.sidebar-btn.active-sidebar .sidebar-count { background: rgba(255,255,255,0.2); color: white; }

.sidebar-icon {
  font-size: 18px;
  flex-shrink: 0;
  width: 20px;
  text-align: center;
}

.sidebar-label {
  font-size: 12px;
  font-weight: 600;
  flex: 1;
  min-width: 0;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.sidebar-count {
  font-size: 10px;
  font-weight: 700;
  background: rgba(0,100,121,0.08);
  color: #006479;
  padding: 2px 6px;
  border-radius: 20px;
  flex-shrink: 0;
}

/* ── Map Center ──────────────────────────── */
#map-center {
  flex: 1;
  position: relative;
  overflow: hidden;
}

#guide-map {
  width: 100%;
  height: 100%;
}

/* ── Area Chips ──────────────────────────── */
#area-chips {
  position: absolute;
  top: 96px; /* below navbar */
  left: 12px;
  right: 12px;
  z-index: 20;
  display: flex;
  gap: 6px;
  overflow-x: auto;
  padding-bottom: 4px;
  scrollbar-width: none;
  pointer-events: all;
}
#area-chips::-webkit-scrollbar { display: none; }

.area-chip {
  flex-shrink: 0;
  padding: 6px 14px;
  border-radius: 20px;
  border: none;
  font-size: 11px;
  font-weight: 700;
  cursor: pointer;
  background: white;
  color: #003345;
  box-shadow: 0 2px 8px rgba(0,0,0,0.12);
  transition: all 0.15s;
  white-space: nowrap;
}

.area-chip:hover { background: #f0f7ff; }
.area-chip.area-active { background: #003345; color: white; }

/* ── Locate button ───────────────────────── */
#locate-btn {
  position: absolute;
  bottom: 100px;
  right: 12px;
  z-index: 20;
  width: 40px;
  height: 40px;
  border-radius: 50%;
  border: none;
  background: white;
  box-shadow: 0 2px 8px rgba(0,0,0,0.15);
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  color: #006479;
  transition: background 0.15s;
}
#locate-btn:hover { background: #f0f7ff; }

/* ── Detail Panel ────────────────────────── */
#detail-panel {
  width: 340px;
  flex-shrink: 0;
  background: white;
  border-left: 1px solid rgba(192,232,255,0.6);
  display: flex;
  flex-direction: column;
  overflow: hidden;
  transition: transform 0.3s cubic-bezier(0.4,0,0.2,1);
  transform: translateX(100%);
  position: absolute;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 30;
  box-shadow: -4px 0 24px rgba(0,0,0,0.08);
}

#detail-panel.panel-open {
  transform: translateX(0);
}

#close-panel {
  position: absolute;
  top: 10px;
  right: 10px;
  z-index: 10;
  width: 32px;
  height: 32px;
  border-radius: 50%;
  border: none;
  background: rgba(255,255,255,0.9);
  backdrop-filter: blur(8px);
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  color: #003345;
  box-shadow: 0 2px 8px rgba(0,0,0,0.12);
}

#panel-header {
  height: 160px;
  flex-shrink: 0;
  display: flex;
  align-items: flex-end;
  padding: 14px;
  position: relative;
  transition: background 0.3s;
}

#panel-badge {
  display: inline-flex;
  align-items: center;
  padding: 5px 12px;
  border-radius: 20px;
  font-size: 10px;
  font-weight: 800;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  background: rgba(255,255,255,0.92);
  color: #003345;
}

#panel-body {
  flex: 1;
  overflow-y: auto;
  padding: 16px 18px 24px;
}

#panel-name {
  font-size: 1.4rem;
  font-weight: 900;
  color: #003345;
  line-height: 1.1;
  margin: 0 0 4px;
  font-family: 'Bebas Neue', sans-serif;
  letter-spacing: 0.02em;
}

#panel-sub {
  font-size: 12px;
  font-weight: 600;
  color: #6b8fa3;
  margin: 0 0 14px;
  display: flex;
  align-items: center;
  gap: 4px;
}

#panel-stats {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 8px;
  margin-bottom: 14px;
}

.stat-card {
  background: #f5faff;
  border: 1px solid rgba(192,232,255,0.7);
  border-radius: 10px;
  padding: 10px 12px;
}

.stat-label {
  font-size: 9px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: #6b8fa3;
  margin-bottom: 4px;
}

.stat-value {
  font-size: 13px;
  font-weight: 700;
  color: #003345;
}

#panel-tip {
  font-size: 13px;
  line-height: 1.6;
  color: #326177;
  margin: 0 0 18px;
  padding: 12px 14px;
  background: rgba(225,243,255,0.5);
  border-radius: 10px;
  border-left: 3px solid #40cef3;
}

#panel-tip:empty { display: none; }

#panel-actions {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 22px;
}

.btn-directions {
  flex: 1;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  padding: 12px 16px;
  background: #003345;
  color: white;
  border-radius: 12px;
  font-size: 13px;
  font-weight: 700;
  text-decoration: none;
  transition: background 0.15s;
}
.btn-directions:hover { background: #006479; }

.btn-share {
  width: 44px;
  height: 44px;
  border-radius: 12px;
  border: 1px solid rgba(192,232,255,0.8);
  background: white;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  color: #006479;
  flex-shrink: 0;
}

/* ── Nearby ──────────────────────────────── */
.nearby-title {
  font-size: 11px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: #6b8fa3;
  margin-bottom: 10px;
}

.nearby-item {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 8px 10px;
  border-radius: 10px;
  border: none;
  background: none;
  width: 100%;
  cursor: pointer;
  text-align: left;
  transition: background 0.15s;
  margin-bottom: 2px;
}
.nearby-item:hover { background: #f5faff; }

.nearby-icon-wrap {
  width: 32px;
  height: 32px;
  border-radius: 8px;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.nearby-name {
  font-size: 12px;
  font-weight: 600;
  color: #003345;
  line-height: 1.2;
}

.nearby-meta {
  font-size: 10px;
  color: #6b8fa3;
  font-weight: 500;
}

/* ── Mobile bottom bar ───────────────────── */
#mobile-cats {
  display: none;
  position: fixed;
  bottom: 0; left: 0; right: 0;
  z-index: 15;
  background: white;
  border-top: 1px solid rgba(192,232,255,0.6);
  box-shadow: 0 -4px 20px rgba(0,0,0,0.08);
}

#mobile-cats-inner {
  display: flex;
  overflow-x: auto;
  padding: 8px 8px 12px;
  gap: 4px;
  scrollbar-width: none;
}
#mobile-cats-inner::-webkit-scrollbar { display: none; }

.mobile-cat {
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 3px;
  padding: 6px 10px;
  border-radius: 10px;
  border: none;
  background: none;
  cursor: pointer;
  font-size: 9px;
  font-weight: 600;
  color: #6b8fa3;
  transition: background 0.15s;
  min-width: 52px;
}
.mobile-cat:hover { background: #f5faff; }
.mobile-cat.active-mobile { background: rgba(0,51,69,0.06); color: #003345; }

/* ── Responsive ──────────────────────────── */
@media (max-width: 900px) {
  #cat-sidebar { display: none; }
  #mobile-cats { display: block; }
  #map-shell { bottom: 68px; } /* leave room for mobile bottom bar */
  #area-chips { top: 80px; } /* tighter on mobile */
  #detail-panel {
    width: 100%;
    top: auto;
    height: 70vh;
    border-left: none;
    border-top: 1px solid rgba(192,232,255,0.6);
    border-radius: 20px 20px 0 0;
    box-shadow: 0 -8px 32px rgba(0,0,0,0.12);
  }
}

@media (max-width: 600px) {
  #area-chips { top: 8px; left: 8px; right: 8px; }
}

/* Hide mapbox popup since we use the panel */
.mapboxgl-popup { display: none !important; }

.mapboxgl-ctrl-group { border-radius: 10px !important; overflow: hidden; }
</style>

<script define:vars={{ placesJson, catsJson, mapboxToken }}>
const places = JSON.parse(placesJson);
const cats   = JSON.parse(catsJson);
const catMap = Object.fromEntries(cats.map(c => [c.id, c]));

const CAT_MATERIAL = {
  sightseeing: 'photo_camera', shopping: 'shopping_bag', 'gay-bars': 'local_bar',
  'gay-clubs': 'nightlife', hotels: 'hotel', food: 'restaurant',
  massage: 'self_improvement', shows: 'theater_comedy', saunas: 'hot_tub', useful: 'storefront',
};

const SVG_NS = 'http://www.w3.org/2000/svg';
let map;
let markerObjs = {};
let activeCat = 'all';
let activeArea = 'all';
let selectedId = null;

// ── Marker ────────────────────────────────
function makeMarkerEl(cat, id) {
  const c = catMap[cat];
  const color = c ? c.color : '#006479';
  const icon  = CAT_MATERIAL[cat] || 'place';

  const wrap = document.createElement('div');
  wrap.style.cssText = 'width:32px;height:38px;cursor:pointer;pointer-events:all;position:absolute;transition:transform 0.2s;';
  wrap.dataset.id = id;

  const svg = document.createElementNS(SVG_NS, 'svg');
  svg.setAttribute('viewBox', '0 0 32 38');
  svg.setAttribute('width', '32');
  svg.setAttribute('height', '38');
  svg.style.cssText = 'position:absolute;top:0;left:0;';

  const path = document.createElementNS(SVG_NS, 'path');
  path.setAttribute('d', 'M16 0C7.163 0 0 7.163 0 16c0 12 16 22 16 22s16-10 16-22C32 7.163 24.837 0 16 0z');
  path.setAttribute('fill', color);
  path.setAttribute('filter', 'drop-shadow(0 2px 4px rgba(0,0,0,0.35))');

  const circle = document.createElementNS(SVG_NS, 'circle');
  circle.setAttribute('cx', '16'); circle.setAttribute('cy', '15'); circle.setAttribute('r', '9');
  circle.setAttribute('fill', 'rgba(255,255,255,0.2)');
  svg.appendChild(path);
  svg.appendChild(circle);

  const iconEl = document.createElement('span');
  iconEl.className = 'material-symbols-outlined';
  iconEl.style.cssText = 'position:absolute;top:6px;left:50%;transform:translateX(-50%);font-size:14px;color:white;line-height:1;pointer-events:none;user-select:none;';
  iconEl.style.fontVariationSettings = "'FILL' 1";
  iconEl.textContent = icon;

  wrap.appendChild(svg);
  wrap.appendChild(iconEl);
  return wrap;
}

// ── Detail Panel ──────────────────────────
function openPanel(place) {
  selectedId = place.id;
  const cat = catMap[place.category];
  const color = cat ? cat.color : '#006479';

  // Header gradient
  const header = document.getElementById('panel-header');
  header.style.background = `linear-gradient(135deg, ${color}cc, ${color}44), linear-gradient(180deg, #003345 0%, ${color} 100%)`;

  // Badge
  document.getElementById('panel-badge').textContent = cat ? cat.label.toUpperCase() : '';

  // Content
  document.getElementById('panel-name').textContent = place.name;

  const sub = document.getElementById('panel-sub');
  sub.textContent = '';
  const icon = document.createElement('span');
  icon.className = 'material-symbols-outlined';
  icon.style.cssText = `font-size:13px;color:${color};font-variation-settings:'FILL' 1;`;
  icon.textContent = 'location_on';
  sub.appendChild(icon);
  sub.appendChild(document.createTextNode(place.area));

  document.getElementById('stat-cat').textContent = cat ? cat.label : '';
  document.getElementById('stat-cat').style.color = color;
  document.getElementById('stat-area').textContent = place.area;

  const tip = document.getElementById('panel-tip');
  tip.textContent = place.tip || '';

  // Directions link
  const dirLink = document.getElementById('panel-directions');
  dirLink.href = `https://www.google.com/maps/dir/?api=1&destination=${place.lat},${place.lng}`;

  // Share button
  document.getElementById('panel-share').onclick = () => {
    const url = `https://www.google.com/maps/search/?api=1&query=${place.lat},${place.lng}`;
    if (navigator.share) {
      navigator.share({ title: place.name, text: `${place.name} – ${place.area}`, url });
    } else {
      navigator.clipboard.writeText(url).then(() => alert('Link copied!'));
    }
  };

  // Nearby: same area, excluding self, max 4
  const nearby = places
    .filter(p => p.area === place.area && p.id !== place.id)
    .slice(0, 4);

  const nearbyList = document.getElementById('nearby-list');
  nearbyList.textContent = '';
  nearby.forEach(np => {
    const nc = catMap[np.category];
    const ncColor = nc ? nc.color : '#006479';

    const btn = document.createElement('button');
    btn.className = 'nearby-item';
    btn.onclick = () => {
      map.flyTo({ center: [np.lng, np.lat], zoom: 17, duration: 500 });
      setTimeout(() => openPanel(np), 550);
    };

    const iconWrap = document.createElement('div');
    iconWrap.className = 'nearby-icon-wrap';
    iconWrap.style.background = `${ncColor}18`;

    const nIcon = document.createElement('span');
    nIcon.className = 'material-symbols-outlined';
    nIcon.style.cssText = `font-size:16px;color:${ncColor};font-variation-settings:'FILL' 1;`;
    nIcon.textContent = CAT_MATERIAL[np.category] || 'place';
    iconWrap.appendChild(nIcon);

    const textWrap = document.createElement('div');
    const nameEl = document.createElement('div');
    nameEl.className = 'nearby-name';
    nameEl.textContent = np.name;
    const metaEl = document.createElement('div');
    metaEl.className = 'nearby-meta';
    metaEl.textContent = nc ? nc.label : '';
    textWrap.appendChild(nameEl);
    textWrap.appendChild(metaEl);

    btn.appendChild(iconWrap);
    btn.appendChild(textWrap);
    nearbyList.appendChild(btn);
  });

  document.getElementById('panel-nearby').style.display = nearby.length ? 'block' : 'none';

  // Open panel
  document.getElementById('detail-panel').classList.add('panel-open');

  // Pulse selected marker
  highlightMarker(place.id);
}

function closePanel() {
  document.getElementById('detail-panel').classList.remove('panel-open');
  selectedId = null;
  resetMarkers();
}

function highlightMarker(id) {
  Object.values(markerObjs).forEach(({ el, place }) => {
    el.style.transform = place.id === id ? 'scale(1.35)' : 'scale(1)';
    el.style.zIndex = place.id === id ? '10' : '1';
  });
}

function resetMarkers() {
  Object.values(markerObjs).forEach(({ el }) => {
    el.style.transform = 'scale(1)';
    el.style.zIndex = '1';
  });
}

// ── Filter logic ──────────────────────────
function applyFilters() {
  const bounds = new mapboxgl.LngLatBounds();
  let count = 0;

  Object.values(markerObjs).forEach(({ marker, place, el }) => {
    const catMatch  = activeCat  === 'all' || place.category === activeCat;
    const areaMatch = activeArea === 'all' || place.area === activeArea;
    if (catMatch && areaMatch) {
      marker.addTo(map);
      bounds.extend([place.lng, place.lat]);
      count++;
    } else {
      marker.remove();
    }
  });

  if (count > 0) map.fitBounds(bounds, { padding: 60, maxZoom: 16, duration: 700 });

  // Close panel if selected place no longer visible
  if (selectedId) {
    const obj = markerObjs[selectedId];
    if (obj) {
      const catMatch  = activeCat  === 'all' || obj.place.category === activeCat;
      const areaMatch = activeArea === 'all' || obj.place.area === activeArea;
      if (!catMatch || !areaMatch) closePanel();
    }
  }
}

// ── Category sidebar ──────────────────────
function setCat(cat) {
  activeCat = cat;
  document.querySelectorAll('.sidebar-btn').forEach(btn => {
    if (btn.getAttribute('data-cat') === cat) btn.classList.add('active-sidebar');
    else btn.classList.remove('active-sidebar');
  });
  document.querySelectorAll('.mobile-cat').forEach(btn => {
    if (btn.getAttribute('data-cat') === cat) btn.classList.add('active-mobile');
    else btn.classList.remove('active-mobile');
  });
  applyFilters();
}

// ── Area chips ────────────────────────────
function setArea(area) {
  activeArea = area;
  document.querySelectorAll('.area-chip').forEach(btn => {
    if (btn.getAttribute('data-area') === area) btn.classList.add('area-active');
    else btn.classList.remove('area-active');
  });
  applyFilters();
}

// ── Map init ──────────────────────────────
function initMap() {
  mapboxgl.accessToken = mapboxToken;
  map = new mapboxgl.Map({
    container: 'guide-map',
    style: 'mapbox://styles/ninoerjavec/cmnbmfwyi001m01qt79mi86hx',
    center: [100.5290, 13.7270],
    zoom: 13.5,
  });

  map.addControl(new mapboxgl.NavigationControl({ showCompass: false }), 'bottom-right');

  places.forEach(p => {
    const el = makeMarkerEl(p.category, p.id);
    const m = new mapboxgl.Marker({ element: el, anchor: 'bottom' })
      .setLngLat([p.lng, p.lat])
      .addTo(map);

    el.addEventListener('click', (e) => {
      e.stopPropagation();
      map.flyTo({ center: [p.lng, p.lat], zoom: 17, duration: 500 });
      setTimeout(() => openPanel(p), 550);
    });

    markerObjs[p.id] = { marker: m, place: p, el };
  });

  // Click map to close panel
  map.on('click', closePanel);
}

// ── Event listeners ───────────────────────
document.addEventListener('DOMContentLoaded', () => {
  // Sidebar category buttons
  document.querySelectorAll('.sidebar-btn').forEach(btn => {
    btn.addEventListener('click', () => setCat(btn.getAttribute('data-cat')));
  });

  // Mobile category buttons
  document.querySelectorAll('.mobile-cat').forEach(btn => {
    btn.addEventListener('click', () => setCat(btn.getAttribute('data-cat')));
  });

  // Area chips
  document.querySelectorAll('.area-chip').forEach(btn => {
    btn.addEventListener('click', () => setArea(btn.getAttribute('data-area')));
  });

  // Close panel
  document.getElementById('close-panel').addEventListener('click', closePanel);

  // Locate me
  document.getElementById('locate-btn').addEventListener('click', () => {
    if (!navigator.geolocation || !map) return;
    navigator.geolocation.getCurrentPosition(pos => {
      map.flyTo({ center: [pos.coords.longitude, pos.coords.latitude], zoom: 15, duration: 800 });
    });
  });

  loadMapbox(initMap);
});

function loadMapbox(cb) {
  if (window.mapboxgl) { cb(); return; }
  const s = document.createElement('script');
  s.src = 'https://api.mapbox.com/mapbox-gl-js/v3.3.0/mapbox-gl.js';
  s.onload = cb;
  document.head.appendChild(s);
}
</script>
