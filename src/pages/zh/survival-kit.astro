---
import BaseLayout from '../../components/layout/BaseLayout.astro';
import Breadcrumb from '../../components/atoms/Breadcrumb.astro';
import { checklist } from '../../data/index';
import { zh } from '../../data/zh';

const t = zh;
const totalItems = checklist.reduce((sum, cat) => sum + cat.items.length, 0);
---

<BaseLayout
  title={t.survivalKit.metaTitle}
  description={t.survivalKit.metaDescription}
  canonical="https://bkksongkran.com/zh/survival-kit"
  lang="zh"
  enUrl="https://bkksongkran.com/survival-kit"
>

  <!-- HEADER -->
  <section class="pt-36 pb-16 px-6" style="background:linear-gradient(180deg,rgba(225,243,255,0.8),rgba(238,248,255,0));">
    <div class="max-w-7xl mx-auto">
      <Breadcrumb crumbs={[{ label: "首页", href: "/zh" }, { label: t.survivalKit.h1Line1 + t.survivalKit.h1Line2 }]} />
      <div class="text-xs font-bold tracking-[0.2em] uppercase mb-3" style="color:#964300;">{t.survivalKit.pageLabel}</div>
      <h1 class="font-headline font-extrabold tracking-tighter mb-4" style="font-size:clamp(3rem,8vw,6rem);color:#003345;line-height:0.9;">
        {t.survivalKit.h1Line1}<br/>
        <span style="background:linear-gradient(135deg,#006479,#40cef3);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;">{t.survivalKit.h1Line2}</span>
      </h1>
      <p class="text-lg max-w-2xl" style="color:#326177;">{t.survivalKit.intro}</p>
    </div>
  </section>

  <!-- STICKY PROGRESS BAR -->
  <div class="sticky top-20 z-30 px-6" id="sticky-progress">
    <div class="max-w-7xl mx-auto">
      <div class="rounded-2xl p-4 flex items-center gap-4" style="background:rgba(238,248,255,0.95);backdrop-filter:blur(20px);border:1px solid rgba(192,232,255,0.6);box-shadow:0 4px 24px rgba(0,100,121,0.08);">
        <div class="flex items-center gap-3 flex-shrink-0">
          <span class="material-symbols-outlined text-xl" style="color:#006479;font-variation-settings:'FILL' 1;">shield</span>
          <div>
            <div class="font-headline font-black text-xl" style="color:#006479;" id="checklist-score">0%</div>
            <div class="text-[10px] font-bold uppercase tracking-wider" style="color:#6b8fa3;" id="checklist-progress-label">0/{totalItems} 已打包</div>
          </div>
        </div>
        <div class="flex-1 h-3 rounded-full overflow-hidden" style="background:rgba(0,100,121,0.08);">
          <div class="h-full rounded-full transition-all duration-500" style="width:0%;background:linear-gradient(90deg,#006479,#40cef3);" id="checklist-progress-bar"></div>
        </div>
        <button onclick="shareChecklist()" class="flex-shrink-0 flex items-center gap-1.5 px-4 py-2 rounded-xl text-xs font-bold text-white transition-all hover:scale-105" style="background:linear-gradient(135deg,#006479,#40cef3);">
          <span class="material-symbols-outlined text-sm">share</span>
          分享
        </button>
      </div>
    </div>
  </div>

  <!-- SCENARIO SECTIONS -->
  <section class="px-6 pt-10 pb-24">
    <div class="max-w-4xl mx-auto space-y-16">

      {checklist.map((category, catIdx) => (
        <div class="relative">
          <div class="flex items-start gap-5 mb-8">
            <div class="relative flex-shrink-0">
              <div class="w-16 h-16 rounded-2xl flex items-center justify-center text-3xl" style={`background:${category.color}15;border:2px solid ${category.color}30;`}>
                {category.emoji}
              </div>
              {catIdx < checklist.length - 1 && (
                <div class="absolute top-full left-1/2 -translate-x-1/2 w-px h-16" style={`background:linear-gradient(to bottom,${category.color}30,transparent);`}></div>
              )}
            </div>
            <div>
              <h2 class="font-headline font-extrabold text-2xl tracking-tight mb-1" style="color:#003345;">
                {category.category}
              </h2>
              <p class="text-sm" style="color:#6b8fa3;">{category.description}</p>
            </div>
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 pl-0 sm:pl-[5.25rem]">
            {category.items.map(item => (
              <div class="group relative rounded-2xl overflow-hidden transition-all duration-300 hover:shadow-lg hover:-translate-y-0.5" style={`border:1px solid ${category.color}20;`}>
                <div class="h-1" style={`background:${category.color};opacity:0.4;`}></div>

                <div class="p-5 bg-white/70">
                  <div class="flex items-start justify-between gap-3 mb-3">
                    <div class="w-10 h-10 rounded-xl flex items-center justify-center flex-shrink-0" style={`background:${category.color}12;`}>
                      <span class="material-symbols-outlined text-xl" style={`color:${category.color};font-variation-settings:'FILL' 1;`}>{(item as any).icon ?? category.icon}</span>
                    </div>
                    <span class="flex-shrink-0 text-[9px] font-bold uppercase tracking-widest px-2.5 py-1 rounded-full" style={`background:${
                      item.priority === 'critical' ? '#FFE8E8' :
                      item.priority === 'high' ? '#FFF8E0' : '#E8FFF0'
                    };color:${
                      item.priority === 'critical' ? '#FF3B30' :
                      item.priority === 'high' ? '#FF9F0A' : '#34C759'
                    };`}>
                      {item.priority === 'critical' ? '必备' :
                       item.priority === 'high' ? '推荐' : '锦上添花'}
                    </span>
                  </div>

                  <label for={`check-${item.id}`} class="cursor-pointer block">
                    <h3 class="font-bold text-sm mb-1.5" style="color:#003345;">{item.label}</h3>
                    <p class="text-xs leading-relaxed" style="color:#6b8fa3;">{item.tip}</p>
                  </label>

                  <div class="mt-4 pt-3 flex items-center gap-3" style="border-top:1px solid rgba(192,232,255,0.4);">
                    <input type="checkbox" id={`check-${item.id}`} class="sr-only peer" />
                    <label for={`check-${item.id}`} class="flex items-center gap-3 cursor-pointer w-full">
                      <div class="w-6 h-6 rounded-lg border-2 flex items-center justify-center transition-all duration-200 flex-shrink-0" style={`border-color:${category.color}40;`}>
                        <div class="w-6 h-6 rounded-lg flex items-center justify-center check-indicator" style={`background:${category.color};`}>
                          <svg class="w-3.5 h-3.5 text-white" viewBox="0 0 12 12" fill="none">
                            <path d="M2 6l3 3 5-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                          </svg>
                        </div>
                      </div>
                      <span class="text-xs font-semibold packed-label" style="color:#6b8fa3;">已打包</span>
                    </label>
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>
      ))}

      <!-- SHARE CARD -->
      <div id="share-card" class="relative rounded-3xl overflow-hidden" style="background:linear-gradient(135deg,#006479,#00899e,#40cef3);">
        <div class="absolute inset-0 opacity-10" style="background:repeating-linear-gradient(45deg,transparent,transparent 10px,rgba(255,255,255,0.05) 10px,rgba(255,255,255,0.05) 20px);"></div>
        <div class="relative p-8 sm:p-12 text-center">
          <span class="material-symbols-outlined text-5xl text-white/80 mb-4 block" style="font-variation-settings:'FILL' 1;">water_drop</span>
          <h2 class="font-headline font-extrabold text-3xl text-white mb-2">分享你的装备</h2>
          <p class="text-white/70 text-sm mb-8 max-w-md mx-auto">让你的队友知道你有多准备好了。生成视觉评分卡，秀出你的准备程度。</p>

          <div id="share-preview" class="max-w-sm mx-auto rounded-2xl p-6 mb-8 text-left" style="background:rgba(255,255,255,0.12);backdrop-filter:blur(10px);border:1px solid rgba(255,255,255,0.2);">
            <div class="flex items-center justify-between mb-4">
              <span class="font-headline font-black text-lg text-white">SONGKRAN<span style="color:#ff8eb2;"> 2026</span></span>
            </div>
            <div class="text-center py-4">
              <div class="font-headline font-black text-6xl text-white mb-1" id="share-score">0%</div>
              <div class="text-sm font-bold text-white/60">宋干节准备就绪</div>
            </div>
            <div class="grid grid-cols-5 gap-2 mt-4" id="share-items-grid"></div>
            <div class="mt-4 pt-3 text-center" style="border-top:1px solid rgba(255,255,255,0.15);">
              <span class="text-[10px] font-bold text-white/40 tracking-widest uppercase">bkksongkran.com/zh/survival-kit</span>
            </div>
          </div>

          <button onclick="shareChecklist()" class="inline-flex items-center gap-2 px-8 py-3.5 rounded-full text-sm font-bold transition-all hover:scale-105" style="background:rgba(255,255,255,0.95);color:#006479;">
            <span class="material-symbols-outlined text-base">share</span>
            分享我的准备分数
          </button>
        </div>
      </div>

    </div>
  </section>

</BaseLayout>

<style>
  .check-indicator {
    opacity: 0;
    transform: scale(0.5);
    transition: all 0.2s ease;
  }
  input[type="checkbox"]:checked ~ label .check-indicator,
  input[type="checkbox"]:checked + label .check-indicator {
    opacity: 1;
    transform: scale(1);
  }
  input[type="checkbox"]:checked ~ label .packed-label,
  input[type="checkbox"]:checked + label .packed-label {
    color: #006479 !important;
    font-weight: 700;
  }
</style>

<script>
function updateProgress() {
  const all = document.querySelectorAll<HTMLInputElement>('input[type="checkbox"][id^="check-"]');
  const checked = Array.from(all).filter(cb => cb.checked).length;
  const total = all.length;
  const pct = total > 0 ? Math.round((checked / total) * 100) : 0;

  const bar = document.getElementById('checklist-progress-bar');
  const label = document.getElementById('checklist-progress-label');
  const score = document.getElementById('checklist-score');
  const shareScore = document.getElementById('share-score');

  if (bar) bar.style.width = `${pct}%`;
  if (label) label.textContent = `${checked}/${total} 已打包`;
  if (score) score.textContent = `${pct}%`;
  if (shareScore) shareScore.textContent = `${pct}%`;

  updateShareGrid();
}

function updateShareGrid() {
  const grid = document.getElementById('share-items-grid');
  if (!grid) return;
  const all = document.querySelectorAll<HTMLInputElement>('input[type="checkbox"][id^="check-"]');

  while (grid.firstChild) {
    grid.removeChild(grid.firstChild);
  }

  all.forEach(cb => {
    const dot = document.createElement('div');
    dot.className = 'w-full aspect-square rounded-lg transition-all duration-300';
    dot.style.background = cb.checked ? 'rgba(64,206,243,0.8)' : 'rgba(255,255,255,0.1)';
    grid.appendChild(dot);
  });
}

document.addEventListener('DOMContentLoaded', () => {
  const all = document.querySelectorAll<HTMLInputElement>('input[type="checkbox"][id^="check-"]');
  all.forEach(cb => {
    const saved = localStorage.getItem(cb.id);
    if (saved === 'true') cb.checked = true;
    cb.addEventListener('change', () => {
      localStorage.setItem(cb.id, String(cb.checked));
      updateProgress();
    });
  });
  updateProgress();
});

function shareChecklist() {
  const score = document.getElementById('checklist-score')?.textContent || '0%';
  const all = document.querySelectorAll<HTMLInputElement>('input[type="checkbox"][id^="check-"]');
  const checked = Array.from(all).filter(cb => cb.checked).length;
  const total = all.length;

  const text = `我的2026年宋干节准备度：${score}！（${checked}/${total} 项已打包）\n\n在这里查看你的准备程度：bkksongkran.com/zh/survival-kit`;

  if (navigator.share) {
    navigator.share({ title: '我的宋干节生存指南', text, url: window.location.href });
  } else {
    navigator.clipboard.writeText(text).then(() => {
      const btn = document.querySelector<HTMLButtonElement>('[onclick="shareChecklist()"]');
      if (btn) {
        const origText = btn.textContent;
        btn.textContent = '已复制！';
        setTimeout(() => {
          if (btn) btn.textContent = origText;
        }, 2000);
      }
    });
  }
}

(window as any).shareChecklist = shareChecklist;
</script>
