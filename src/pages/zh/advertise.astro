---
import BaseLayout from '../../components/layout/BaseLayout.astro';
import Breadcrumb from '../../components/atoms/Breadcrumb.astro';
---

<BaseLayout
  title="在BKK宋干节投放广告 — 触达50,000+节日旅行者"
  description="赞助曼谷领先的2026年宋干节指南。横幅广告、活动推荐、地图标记等多种形式。触达数万名正在规划行程的节日爱好者。"
  canonical="https://bkksongkran.com/zh/advertise"
  lang="zh"
  enUrl="https://bkksongkran.com/advertise"
>

  <!-- 页头 -->
  <section class="pt-36 pb-16 px-6" style="background:linear-gradient(180deg,rgba(225,243,255,0.9),rgba(238,248,255,0));">
    <div class="max-w-4xl mx-auto">
      <Breadcrumb crumbs={[{ label: "首页", href: "/zh" }, { label: "广告合作" }]} />
      <div class="text-xs font-bold tracking-[0.2em] uppercase mb-3" style="color:#006479;">与我们合作</div>
      <h1 class="font-headline font-extrabold tracking-tighter mb-5" style="font-size:clamp(2.8rem,8vw,5.5rem);color:#003345;line-height:0.9;">
        触达<br/>
        <span style="background:linear-gradient(135deg,#006479,#40cef3);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;">节日人群</span>
      </h1>
      <p class="text-lg max-w-2xl mb-6" style="color:#326177;line-height:1.7;">
        BKK宋干节是曼谷访问量最高的2026年宋干节独立指南 — 专为4月10–15日积极规划旅行、住宿、门票和夜生活的国际节日爱好者打造。
      </p>

      <!-- 数据行 -->
      <div class="flex flex-wrap gap-6 mb-8">
        {[
          { value: '50,000+',   label: '月访问量' },
          { value: '12',        label: '深度攻略' },
          { value: '4',         label: '大型节日报道' },
          { value: '4月10–15日', label: '流量高峰期' },
        ].map(s => (
          <div class="flex flex-col">
            <span class="font-headline font-black text-3xl" style="color:#006479;">{s.value}</span>
            <span class="text-xs font-semibold uppercase tracking-wider mt-0.5" style="color:#6b8fa3;">{s.label}</span>
          </div>
        ))}
      </div>

      <a href="#contact-form" class="btn-primary inline-flex px-8 py-3.5 text-sm">
        <span class="material-symbols-outlined text-base" style="font-variation-settings:'FILL' 1;">campaign</span>
        联系我们
      </a>
    </div>
  </section>

  <!-- 受众 -->
  <section class="px-6 py-16">
    <div class="max-w-4xl mx-auto">
      <h2 class="font-headline font-extrabold text-3xl mb-2" style="color:#003345;">网站访客画像</h2>
      <p class="text-sm mb-8" style="color:#6b8fa3;">以25–40岁为主的国际旅行者，正在积极规划或参加2026年曼谷宋干节。</p>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        {[
          { icon: 'flight_land', title: '国际旅行者', body: '大多数从欧洲、澳大利亚、美国和东南亚专程飞来参加节日。' },
          { icon: 'hotel',       title: '住宿需求者', body: '积极寻找暹罗、素坤逸和RCA附近的酒店和青旅。' },
          { icon: 'confirmation_number', title: '购票用户', body: '规划S2O、暹罗宋干、GCircuit门票，比较价格和购买渠道。' },
          { icon: 'nightlife',   title: '夜生活与美食', body: '寻找曼谷各区的酒吧、夜店、餐厅及派对前后活动。' },
        ].map(a => (
          <div class="card p-5 space-y-3">
            <div class="w-10 h-10 rounded-xl flex items-center justify-center" style="background:rgba(0,100,121,0.08);">
              <span class="material-symbols-outlined" style="color:#006479;font-variation-settings:'FILL' 1;">{a.icon}</span>
            </div>
            <h3 class="font-bold text-sm" style="color:#003345;">{a.title}</h3>
            <p class="text-xs leading-relaxed" style="color:#6b8fa3;">{a.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 投放位置 -->
  <section class="px-6 py-16" style="background:rgba(225,243,255,0.4);">
    <div class="max-w-4xl mx-auto">
      <h2 class="font-headline font-extrabold text-3xl mb-2" style="color:#003345;">广告位选项</h2>
      <p class="text-sm mb-10" style="color:#6b8fa3;">所有广告位均经过人工审核。我们只推广与宋干节旅行者相关的品牌。</p>

      <div class="space-y-4">

        <!-- 首页横幅 -->
        <div class="card p-6 flex gap-5 items-start">
          <div class="w-12 h-12 rounded-2xl flex-shrink-0 flex items-center justify-center" style="background:linear-gradient(135deg,rgba(0,100,121,0.12),rgba(64,206,243,0.12));">
            <span class="material-symbols-outlined text-2xl" style="color:#006479;font-variation-settings:'FILL' 1;">home</span>
          </div>
          <div class="flex-1 min-w-0">
            <div class="flex items-center gap-2 mb-1">
              <h3 class="font-headline font-bold text-lg" style="color:#003345;">首页横幅</h3>
              <span class="text-[10px] font-black uppercase tracking-wider px-2 py-0.5 rounded-full" style="background:rgba(255,159,10,0.12);color:#c77700;">高流量</span>
            </div>
            <p class="text-sm mb-3" style="color:#326177;line-height:1.6;">全宽赞助条幅，位于首页快捷链接区和精选文章之间。第一印象广告位 — 每位访客都能看到。</p>
            <div class="flex flex-wrap gap-3 text-xs font-semibold" style="color:#6b8fa3;">
              <span class="flex items-center gap-1"><span class="material-symbols-outlined text-xs">check_circle</span> 桌面端 &amp; 移动端全宽展示</span>
              <span class="flex items-center gap-1"><span class="material-symbols-outlined text-xs">check_circle</span> 品牌Logo、标语 &amp; 链接</span>
              <span class="flex items-center gap-1"><span class="material-symbols-outlined text-xs">check_circle</span> 滚动首屏可见</span>
            </div>
          </div>
        </div>

        <!-- 活动页推荐 -->
        <div class="card p-6 flex gap-5 items-start">
          <div class="w-12 h-12 rounded-2xl flex-shrink-0 flex items-center justify-center" style="background:linear-gradient(135deg,rgba(180,0,93,0.1),rgba(233,30,140,0.1));">
            <span class="material-symbols-outlined text-2xl" style="color:#b4005d;font-variation-settings:'FILL' 1;">festival</span>
          </div>
          <div class="flex-1 min-w-0">
            <div class="flex items-center gap-2 mb-1">
              <h3 class="font-headline font-bold text-lg" style="color:#003345;">活动页推荐</h3>
              <span class="text-[10px] font-black uppercase tracking-wider px-2 py-0.5 rounded-full" style="background:rgba(180,0,93,0.1);color:#b4005d;">最适合场馆 &amp; 主办方</span>
            </div>
            <p class="text-sm mb-3" style="color:#326177;line-height:1.6;">将你的派对、场馆或活动列入<a href="/zh/events" class="underline font-semibold" style="color:#006479;">/活动</a>页面，与S2O、暹罗宋干、GCircuit并列展示。包含演出阵容、场馆详情、购票链接及精选徽章。</p>
            <div class="flex flex-wrap gap-3 text-xs font-semibold" style="color:#6b8fa3;">
              <span class="flex items-center gap-1"><span class="material-symbols-outlined text-xs">check_circle</span> 展示头条艺人 &amp; 时间表</span>
              <span class="flex items-center gap-1"><span class="material-symbols-outlined text-xs">check_circle</span> 购票链接 &amp; 场馆信息</span>
              <span class="flex items-center gap-1"><span class="material-symbols-outlined text-xs">check_circle</span> 精选徽章</span>
            </div>
          </div>
        </div>

        <!-- 曼谷地图标记 -->
        <div class="card p-6 flex gap-5 items-start">
          <div class="w-12 h-12 rounded-2xl flex-shrink-0 flex items-center justify-center" style="background:linear-gradient(135deg,rgba(52,199,89,0.1),rgba(0,200,100,0.1));">
            <span class="material-symbols-outlined text-2xl" style="color:#16a34a;font-variation-settings:'FILL' 1;">location_on</span>
          </div>
          <div class="flex-1 min-w-0">
            <div class="flex items-center gap-2 mb-1">
              <h3 class="font-headline font-bold text-lg" style="color:#003345;">曼谷地图标记</h3>
              <span class="text-[10px] font-black uppercase tracking-wider px-2 py-0.5 rounded-full" style="background:rgba(52,199,89,0.1);color:#16a34a;">最适合酒店 &amp; 酒吧</span>
            </div>
            <p class="text-sm mb-3" style="color:#326177;line-height:1.6;">在我们的<a href="/zh/map" class="underline font-semibold" style="color:#006479;">曼谷互动地图</a>上标记你的位置 — 这是访客查找节日区域附近酒吧、夜店、酒店和餐厅的首选参考。赞助标记优先显示在各类别顶部。</p>
            <div class="flex flex-wrap gap-3 text-xs font-semibold" style="color:#6b8fa3;">
              <span class="flex items-center gap-1"><span class="material-symbols-outlined text-xs">check_circle</span> 高亮赞助标记</span>
              <span class="flex items-center gap-1"><span class="material-symbols-outlined text-xs">check_circle</span> 名称、简介 &amp; 网站链接</span>
              <span class="flex items-center gap-1"><span class="material-symbols-outlined text-xs">check_circle</span> 类别置顶展示</span>
            </div>
          </div>
        </div>

        <!-- 文章中部横幅 -->
        <div class="card p-6 flex gap-5 items-start">
          <div class="w-12 h-12 rounded-2xl flex-shrink-0 flex items-center justify-center" style="background:linear-gradient(135deg,rgba(64,206,243,0.1),rgba(0,100,121,0.1));">
            <span class="material-symbols-outlined text-2xl" style="color:#0ea5e9;font-variation-settings:'FILL' 1;">article</span>
          </div>
          <div class="flex-1 min-w-0">
            <div class="flex items-center gap-2 mb-1">
              <h3 class="font-headline font-bold text-lg" style="color:#003345;">文章中部横幅</h3>
              <span class="text-[10px] font-black uppercase tracking-wider px-2 py-0.5 rounded-full" style="background:rgba(14,165,233,0.1);color:#0ea5e9;">最适合旅行品牌</span>
            </div>
            <p class="text-sm mb-3" style="color:#326177;line-height:1.6;">在我们的<a href="/zh/blog" class="underline font-semibold" style="color:#006479;">12篇深度攻略文章</a>中投放赞助广告 — 这些内容被深度规划行程的访客阅读。高意向，低干扰。</p>
            <div class="flex flex-wrap gap-3 text-xs font-semibold" style="color:#6b8fa3;">
              <span class="flex items-center gap-1"><span class="material-symbols-outlined text-xs">check_circle</span> 内容中部矩形广告位</span>
              <span class="flex items-center gap-1"><span class="material-symbols-outlined text-xs">check_circle</span> 明确标注"赞助内容"</span>
              <span class="flex items-center gap-1"><span class="material-symbols-outlined text-xs">check_circle</span> 全部12篇或指定文章</span>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- 联系表单 -->
  <section class="px-6 py-16" id="contact-form">
    <div class="max-w-xl mx-auto">
      <h2 class="font-headline font-extrabold text-3xl mb-2" style="color:#003345;">联系我们</h2>
      <p class="text-sm mb-8" style="color:#6b8fa3;">请告诉我们你的业务及感兴趣的广告位。我们将在24小时内回复。</p>

      <div class="card p-6 space-y-4">

        <div>
          <label class="block text-xs font-bold uppercase tracking-wider mb-1.5" style="color:#6b8fa3;">你的姓名 <span style="color:#b31b25;">*</span></label>
          <input id="adv-name" type="text" maxlength="100" placeholder="Marco, Alex..." class="w-full px-4 py-3 rounded-xl text-sm font-medium outline-none" style="background:rgba(225,243,255,0.7);border:1.5px solid rgba(192,232,255,0.8);color:#003345;" />
        </div>

        <div>
          <label class="block text-xs font-bold uppercase tracking-wider mb-1.5" style="color:#6b8fa3;">商务邮箱 <span style="color:#b31b25;">*</span></label>
          <input id="adv-email" type="email" maxlength="254" placeholder="you@company.com" class="w-full px-4 py-3 rounded-xl text-sm font-medium outline-none" style="background:rgba(225,243,255,0.7);border:1.5px solid rgba(192,232,255,0.8);color:#003345;" />
        </div>

        <div>
          <label class="block text-xs font-bold uppercase tracking-wider mb-1.5" style="color:#6b8fa3;">感兴趣的广告位</label>
          <div class="flex flex-wrap gap-2">
            {['首页横幅', '活动列表', '地图标记', '文章横幅', '其他'].map(p => (
              <button class="adv-placement-btn px-3 py-1.5 rounded-full text-xs font-bold border-2 transition-all" data-placement={p}
                style="border-color:rgba(192,232,255,0.8);color:#326177;background:white;">
                {p}
              </button>
            ))}
          </div>
          <input type="hidden" id="adv-placement" value="" />
        </div>

        <div>
          <label class="block text-xs font-bold uppercase tracking-wider mb-1.5" style="color:#6b8fa3;">留言 <span style="color:#b31b25;">*</span></label>
          <textarea id="adv-message" maxlength="2000" rows="5" placeholder="请告诉我们你的业务、希望推广的内容，以及任何关于定价或可用性的问题..." class="w-full px-4 py-3 rounded-xl text-sm font-medium outline-none resize-none" style="background:rgba(225,243,255,0.7);border:1.5px solid rgba(192,232,255,0.8);color:#003345;"></textarea>
        </div>

        <div id="turnstile-advertise" class="mt-1"></div>

        <p id="adv-error" class="hidden text-xs font-bold" style="color:#b31b25;"></p>
        <p id="adv-success" class="hidden text-sm font-bold" style="color:#16a34a;">消息已发送！我们将在24小时内回复你。</p>

        <button id="adv-submit" class="w-full flex items-center justify-center gap-2 px-6 py-3 rounded-xl text-sm font-bold text-white transition-all" style="background:linear-gradient(135deg,#006479,#40cef3);">
          <span class="material-symbols-outlined text-base" style="font-variation-settings:'FILL' 1;">send</span>
          发送咨询
        </button>

        <p class="text-[11px] text-center" style="color:#6b8fa3;">我们对所有咨询进行人工审核，只与节日旅行者相关的品牌合作。</p>
      </div>
    </div>
  </section>

</BaseLayout>

<script>
// 广告位切换按钮
document.querySelectorAll('.adv-placement-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    const val = (btn as HTMLElement).dataset.placement!;
    const input = document.getElementById('adv-placement') as HTMLInputElement;
    const alreadyActive = input.value === val;

    document.querySelectorAll('.adv-placement-btn').forEach((b: Element) => {
      const el = b as HTMLElement;
      el.style.background   = 'white';
      el.style.color        = '#326177';
      el.style.borderColor  = 'rgba(192,232,255,0.8)';
    });

    if (!alreadyActive) {
      (btn as HTMLElement).style.background  = '#006479';
      (btn as HTMLElement).style.color       = '#fff';
      (btn as HTMLElement).style.borderColor = '#006479';
      input.value = val;
    } else {
      input.value = '';
    }
  });
});

document.getElementById('adv-submit')!.addEventListener('click', async () => {
  const btn       = document.getElementById('adv-submit')!;
  const errEl     = document.getElementById('adv-error')!;
  const sucEl     = document.getElementById('adv-success')!;
  const name      = (document.getElementById('adv-name') as HTMLInputElement).value.trim();
  const email     = (document.getElementById('adv-email') as HTMLInputElement).value.trim();
  const placement = (document.getElementById('adv-placement') as HTMLInputElement).value;
  const message   = (document.getElementById('adv-message') as HTMLTextAreaElement).value.trim();

  errEl.classList.add('hidden');
  sucEl.classList.add('hidden');

  if (!name)    { errEl.textContent = '请输入你的姓名。'; errEl.classList.remove('hidden'); return; }
  if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) { errEl.textContent = '请输入有效的电子邮箱。'; errEl.classList.remove('hidden'); return; }
  if (!message) { errEl.textContent = '请输入留言内容。'; errEl.classList.remove('hidden'); return; }

  const turnstileToken = (window as any).__advTurnstileId !== null
    ? ((window as any).turnstile?.getResponse((window as any).__advTurnstileId) || '')
    : '';
  if (!turnstileToken) { errEl.textContent = '请完成安全验证。'; errEl.classList.remove('hidden'); return; }

  const fullMessage = placement ? `[广告位偏好: ${placement}]\n\n${message}` : message;

  btn.setAttribute('disabled', 'true'); btn.style.opacity = '0.6';
  try {
    const res = await fetch('/api/contact', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ type: 'advertise', name, email, message: fullMessage, turnstileToken }),
    });
    const data = await res.json();
    if (!res.ok) throw new Error(data.error || 'Failed');
    sucEl.classList.remove('hidden');
    (document.getElementById('adv-name') as HTMLInputElement).value = '';
    (document.getElementById('adv-email') as HTMLInputElement).value = '';
    (document.getElementById('adv-message') as HTMLTextAreaElement).value = '';
    (document.getElementById('adv-placement') as HTMLInputElement).value = '';
    document.querySelectorAll('.adv-placement-btn').forEach((b: Element) => {
      const el = b as HTMLElement;
      el.style.background = 'white'; el.style.color = '#326177'; el.style.borderColor = 'rgba(192,232,255,0.8)';
    });
    if ((window as any).turnstile && (window as any).__advTurnstileId !== null) (window as any).turnstile.reset((window as any).__advTurnstileId);
  } catch (e: any) {
    errEl.textContent = e.message || '出现错误，请重试。';
    errEl.classList.remove('hidden');
  } finally {
    btn.removeAttribute('disabled'); btn.style.opacity = '1';
  }
});
</script>

<script src="https://challenges.cloudflare.com/turnstile/v0/api.js?render=explicit" async defer></script>
<script is:inline>
  window.__advTurnstileId = null;
  function onAdvTurnstileLoad() {
    if (window.turnstile && window.__advTurnstileId === null) {
      window.__advTurnstileId = window.turnstile.render('#turnstile-advertise', {
        sitekey: '0x4AAAAAACxlzbfzLTTpR49t',
        theme: 'light',
      });
    }
  }
  var _at = setInterval(function() { if (window.turnstile) { clearInterval(_at); onAdvTurnstileLoad(); } }, 100);
</script>
