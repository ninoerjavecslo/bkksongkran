---
import BaseLayout from '../../../components/layout/BaseLayout.astro';
import { zhArticles as articles } from '../../../data/articles.zh';
import Breadcrumb from '../../../components/atoms/Breadcrumb.astro';
import { zh } from '../../../data/zh';

const t = zh;
---

<BaseLayout
  title={t.blog.metaTitle}
  description={t.blog.metaDescription}
  canonical="https://bkksongkran.com/zh/blog"
  lang="zh"
  enUrl="https://bkksongkran.com/blog"
>

  <!-- SEO structured data -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Blog",
    "name": "曼谷宋干节攻略",
    "description": "2026年曼谷宋干节完整指南。由本地人撰写，为2026年更新。",
    "url": "https://bkksongkran.com/zh/blog",
    "blogPost": articles.map(a => ({
      "@type": "BlogPosting",
      "headline": a.title,
      "description": a.metaDescription,
      "datePublished": a.publishedDate,
      "dateModified": a.modifiedDate,
      "url": `https://bkksongkran.com/blog/${a.slug}`,
    })),
  })} />

  <!-- HEADER -->
  <section class="pt-36 pb-16 px-6" style="background:linear-gradient(180deg,rgba(225,243,255,0.8),rgba(238,248,255,0));">
    <div class="max-w-7xl mx-auto">
      <Breadcrumb crumbs={[{ label: "首页", href: "/zh" }, { label: t.blog.h1Line1 + t.blog.h1Line2 }]} />
      <div class="text-xs font-bold tracking-[0.2em] uppercase mb-3" style="color:#006479;">{t.blog.pageLabel}</div>
      <h1 class="font-headline font-extrabold tracking-tighter mb-4" style="font-size:clamp(3rem,8vw,6rem);color:#003345;line-height:0.9;">
        {t.blog.h1Line1}<br/>
        <span style="background:linear-gradient(135deg,#006479,#40cef3);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;">{t.blog.h1Line2}</span>
      </h1>
      <p class="text-lg max-w-2xl" style="color:#326177;">{t.blog.intro}</p>
    </div>
  </section>

  <!-- FEATURED ARTICLE -->
  <section class="px-6 pb-8">
    <div class="max-w-7xl mx-auto">
      <a href={`/zh/blog/${articles[0].slug}`} class="block group">
        <div class="card overflow-hidden relative" style="min-height:280px;">
          <div class="absolute inset-0">
            <img src={articles[0].featuredImage} alt={articles[0].title} width="1200" height="630" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" loading="lazy" />
            <div class="absolute inset-0" style="background:linear-gradient(to top,rgba(0,20,35,0.95) 0%,rgba(0,25,40,0.7) 50%,rgba(0,20,35,0.5) 100%);"></div>
          </div>
          <div class="relative p-8 flex flex-col justify-end" style="min-height:280px;">
            <span class="inline-block px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-wider mb-3 self-start" style={`background:${articles[0].categoryColor}30;color:${articles[0].categoryColor};border:1px solid ${articles[0].categoryColor}40;`}>
              {articles[0].category}
            </span>
            <h2 class="font-headline font-extrabold text-2xl md:text-3xl text-white mb-2 leading-tight" style="text-shadow:0 2px 12px rgba(0,0,0,0.6);">{articles[0].title}</h2>
            <p class="text-sm text-white max-w-lg">{articles[0].excerpt}</p>
            <div class="flex items-center gap-4 mt-3 text-xs text-white/80">
              <span>{articles[0].readTime} {t.blog.minRead}</span>
              <span>{new Date(articles[0].modifiedDate).toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })} 更新</span>
            </div>
          </div>
        </div>
      </a>
    </div>
  </section>

  <!-- ALL ARTICLES GRID -->
  <section class="px-6 pb-20">
    <div class="max-w-7xl mx-auto">
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
        {articles.slice(1).map(article => (
          <a href={`/zh/blog/${article.slug}`} class="card p-0 overflow-hidden group block">
            <div class="h-1.5 w-full" style={`background:${article.categoryColor};`}></div>
            <div class="p-5 space-y-3">
              <div class="flex items-center gap-2">
                <span class="inline-block px-2.5 py-0.5 rounded-full text-[10px] font-bold uppercase tracking-wider" style={`background:${article.categoryColor}15;color:${article.categoryColor};`}>
                  {article.category}
                </span>
                <span class="text-[10px] font-medium" style="color:#86b3cc;">{article.readTime} {t.blog.minRead}</span>
              </div>
              <h3 class="font-headline font-bold text-base leading-snug group-hover:text-primary transition-colors" style="color:#003345;">{article.title}</h3>
              <p class="text-xs leading-relaxed line-clamp-2" style="color:#326177;">{article.excerpt}</p>
              <div class="flex items-center gap-1 text-xs font-bold group-hover:gap-2 transition-all" style="color:#006479;">
                {t.common.readMore}
                <span class="material-symbols-outlined text-sm transition-transform group-hover:translate-x-1">arrow_forward</span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>
