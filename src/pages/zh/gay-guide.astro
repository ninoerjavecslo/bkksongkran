---
import BaseLayout from '../../components/layout/BaseLayout.astro';
import Breadcrumb from '../../components/atoms/Breadcrumb.astro';
import { zh } from '../../data/zh';
---

<BaseLayout
  title="曼谷宋干节同志指南2026 — LGBTQ+完整攻略"
  description="2026年曼谷宋干节完整同志攻略。GCircuit、Silom、同志俱乐部、交通贴士、生存建议及更多。"
  lang="zh"
  canonical="https://bkksongkran.com/zh/gay-guide"
  enUrl="https://bkksongkran.com/gay-guide"
>

<style>
  .guide-sidebar a {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 8px 12px;
    border-radius: 10px;
    font-size: 13px;
    font-weight: 600;
    color: #326177;
    text-decoration: none;
    transition: all 0.15s;
  }
  .guide-sidebar a:hover { background: rgba(168,85,247,0.1); color: #7c3aed; }
  .guide-sidebar a.active { background: rgba(168,85,247,0.08); color: #7c3aed; border-left: 3px solid #a855f7; padding-left: 9px; }
  .guide-sidebar .section-group { margin-bottom: 6px; }
  .guide-sidebar .section-group-label {
    font-size: 10px;
    font-weight: 800;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #6b8fa3;
    padding: 10px 12px 4px;
  }
  .section-anchor { scroll-margin-top: 100px; }
  .tip-card {
    background: white;
    border: 1px solid rgba(192,232,255,0.5);
    border-radius: 16px;
    padding: 18px 20px;
  }
  .tip-card.warn   { border-left: 4px solid #FF9F0A; background: rgba(255,159,10,0.03); }
  .tip-card.danger { border-left: 4px solid #ef4444; background: rgba(239,68,68,0.03); }
  .tip-card.good   { border-left: 4px solid #34C759; background: rgba(52,199,89,0.03); }
  .tip-card.info   { border-left: 4px solid #40cef3; background: rgba(64,206,243,0.03); }
  .tip-card.purple { border-left: 4px solid #a855f7; background: rgba(168,85,247,0.03); }
  .section-title {
    font-size: clamp(1.5rem, 4vw, 2.2rem);
    font-weight: 800;
    color: #003345;
    margin-bottom: 6px;
    line-height: 1.1;
  }
  .section-label {
    font-size: 10px;
    font-weight: 800;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #a855f7;
    margin-bottom: 8px;
    display: block;
  }
  .venue-card {
    background: white;
    border: 1px solid rgba(192,232,255,0.5);
    border-radius: 16px;
    padding: 18px 20px;
    display: flex;
    gap: 14px;
    align-items: flex-start;
  }
  .venue-icon {
    width: 44px; height: 44px;
    border-radius: 12px;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
  }
  .badge {
    display: inline-flex; align-items: center; gap: 4px;
    padding: 3px 10px;
    border-radius: 100px;
    font-size: 11px; font-weight: 700;
  }
  .btn {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 10px 18px;
    border-radius: 12px;
    font-size: 13px; font-weight: 700;
    text-decoration: none;
    transition: all 0.15s;
    cursor: pointer; border: none;
  }
  .btn:hover { opacity: 0.85; transform: translateY(-1px); box-shadow: 0 4px 14px rgba(0,0,0,0.12); }
  .btn-primary { background: linear-gradient(135deg,#a855f7,#ec4899); color: white; }
  .btn-outline { background: rgba(168,85,247,0.08); color: #7c3aed; border: 1px solid rgba(168,85,247,0.2); }
  .btn-dark { background: rgba(0,100,121,0.08); color: #006479; border: 1px solid rgba(0,100,121,0.15); }
  .event-card {
    background: white;
    border: 1px solid rgba(192,232,255,0.5);
    border-radius: 16px;
    overflow: hidden;
    transition: box-shadow 0.15s;
  }
  .event-card:hover { box-shadow: 0 4px 20px rgba(168,85,247,0.1); }
  .event-card-header { padding: 16px 18px 12px; border-bottom: 1px solid rgba(192,232,255,0.3); }
  .event-card-body { padding: 14px 18px 16px; }
  .festival-card {
    background: white;
    border: 1px solid rgba(192,232,255,0.5);
    border-radius: 18px;
    padding: 20px;
    display: flex; flex-direction: column; gap: 10px;
    transition: all 0.15s;
  }
  .festival-card:hover { box-shadow: 0 4px 20px rgba(0,0,0,0.07); transform: translateY(-2px); }

  /* Mobile */
  #mobile-nav-toggle { display: block; }
  #guide-sidebar { display: none; }
  #guide-sidebar.open {
    display: block !important;
    position: fixed; inset: 0; z-index: 100;
    background: white; overflow-y: auto; padding: 24px;
  }
  #guide-layout { display: block; }
  #guide-sidebar-desktop { display: none; }

  @media (min-width: 1024px) {
    #mobile-nav-toggle { display: none !important; }
    #guide-layout { display: flex; gap: 40px; align-items: flex-start; }
    #guide-sidebar-desktop { display: block; width: 256px; flex-shrink: 0; position: sticky; top: 96px; }
    #guide-sidebar { display: none; }
  }
</style>

<!-- HEADER -->
<section class="pt-36 pb-12 px-6" style="background:linear-gradient(160deg,rgba(88,28,135,0.06) 0%,rgba(225,243,255,0.7) 60%,rgba(238,248,255,0) 100%);">
  <div class="max-w-7xl mx-auto">
    <Breadcrumb crumbs={[{ label: "首页", href: "/zh" }, { label: "同志指南" }]} />
    <span class="section-label">LGBTQ+ 指南</span>
    <h1 class="font-headline font-extrabold tracking-tighter mb-4" style="font-size:clamp(2.8rem,8vw,5.5rem);color:#003345;line-height:0.9;">
      同志<br/>
      <span style="background:linear-gradient(135deg,#a855f7,#ec4899);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;">宋干节</span><br/>
      <span style="font-size:0.5em;color:#003345;">曼谷 2026</span>
    </h1>
    <p class="text-lg max-w-2xl mt-4 mb-6" style="color:#326177;line-height:1.6;">GCircuit、Silom、GOD club、cruising bar、派对后续——亚洲最嗨同志周完整攻略。</p>
    <div class="flex flex-wrap gap-3">
      <a href="/zh/events" class="btn btn-dark"><span class="material-symbols-outlined text-base">calendar_month</span>全部活动</a>
      <a href="/meetup" class="btn btn-dark"><span class="material-symbols-outlined text-base">diversity_3</span>谁要去？</a>
      <a href="/tickets" class="btn btn-dark"><span class="material-symbols-outlined text-base">confirmation_number</span>购买/出售门票</a>
      <a href="/zh/survival-kit" class="btn btn-dark"><span class="material-symbols-outlined text-base">backpack</span>生存指南</a>
    </div>
  </div>
</section>

<!-- Mobile floating button -->
<div id="mobile-nav-toggle" style="position:fixed;bottom:24px;left:50%;transform:translateX(-50%);z-index:50;">
  <button onclick="document.getElementById('guide-sidebar').classList.toggle('open')" class="btn btn-primary" style="box-shadow:0 4px 20px rgba(168,85,247,0.4);">
    <span class="material-symbols-outlined" style="font-size:18px;">menu_book</span>
    跳转章节
  </button>
</div>

<!-- Mobile sidebar overlay -->
<aside id="guide-sidebar" class="guide-sidebar">
  <div style="display:flex;align-items:center;justify-content:space-between;padding:16px;border-bottom:1px solid rgba(192,232,255,0.4);margin-bottom:8px;">
    <span style="font-weight:700;font-size:15px;color:#003345;">目录</span>
    <button onclick="document.getElementById('guide-sidebar').classList.remove('open')" style="background:none;border:none;cursor:pointer;" class="material-symbols-outlined">close</button>
  </div>
  <div class="section-group"><div class="section-group-label">节日与活动</div>
    <a href="#festivals" onclick="closeMobileNav()"><span class="material-symbols-outlined text-sm" style="color:#a855f7;">festival</span>主要节日</a>
    <a href="#gcircuit" onclick="closeMobileNav()"><span class="material-symbols-outlined text-sm" style="color:#a855f7;">nightlife</span>GCircuit</a>
    <a href="#silom" onclick="closeMobileNav()"><span class="material-symbols-outlined text-sm" style="color:#ec4899;">celebration</span>Silom Soi 2 & 4</a>
    <a href="#special" onclick="closeMobileNav()"><span class="material-symbols-outlined text-sm" style="color:#a855f7;">local_activity</span>特别活动</a>
    <a href="#clubs" onclick="closeMobileNav()"><span class="material-symbols-outlined text-sm" style="color:#ec4899;">nightlife</span>俱乐部与酒吧</a>
    <a href="#totems" onclick="closeMobileNav()"><span class="material-symbols-outlined text-sm" style="color:#FF9F0A;">flag</span>图腾与集合点</a>
  </div>
  <div class="section-group"><div class="section-group-label">社区</div>
    <a href="#tickets-section" onclick="closeMobileNav()"><span class="material-symbols-outlined text-sm" style="color:#34C759;">confirmation_number</span>购买/出售门票</a>
    <a href="#whos-going" onclick="closeMobileNav()"><span class="material-symbols-outlined text-sm" style="color:#006479;">diversity_3</span>谁要去？</a>
  </div>
  <div class="section-group"><div class="section-group-label">实用信息</div>
    <a href="#transport" onclick="closeMobileNav()"><span class="material-symbols-outlined text-sm" style="color:#34C759;">directions_transit</span>交通</a>
    <a href="#safety" onclick="closeMobileNav()"><span class="material-symbols-outlined text-sm" style="color:#ef4444;">health_and_safety</span>安全与贴士</a>
    <a href="#map" onclick="closeMobileNav()"><span class="material-symbols-outlined text-sm" style="color:#006479;">map</span>曼谷同志地图</a>
  </div>
</aside>

<!-- LAYOUT -->
<div id="guide-layout" class="max-w-7xl mx-auto px-4 pb-32" style="overflow-x:clip;">

  <!-- Desktop sidebar -->
  <aside id="guide-sidebar-desktop" class="guide-sidebar">
    <div class="rounded-2xl overflow-hidden" style="background:white;border:1px solid rgba(192,232,255,0.5);box-shadow:0 2px 12px rgba(0,0,0,0.04);">
      <div class="section-group"><div class="section-group-label">节日与活动</div>
        <a href="#festivals"><span class="material-symbols-outlined text-sm" style="color:#a855f7;">festival</span>主要节日</a>
        <a href="#gcircuit"><span class="material-symbols-outlined text-sm" style="color:#a855f7;">nightlife</span>GCircuit</a>
        <a href="#silom"><span class="material-symbols-outlined text-sm" style="color:#ec4899;">celebration</span>Silom Soi 2 & 4</a>
        <a href="#special"><span class="material-symbols-outlined text-sm" style="color:#a855f7;">local_activity</span>特别活动</a>
        <a href="#clubs"><span class="material-symbols-outlined text-sm" style="color:#ec4899;">nightlife</span>俱乐部与酒吧</a>
        <a href="#totems"><span class="material-symbols-outlined text-sm" style="color:#FF9F0A;">flag</span>图腾与集合点</a>
      </div>
      <div class="section-group"><div class="section-group-label">社区</div>
        <a href="#tickets-section"><span class="material-symbols-outlined text-sm" style="color:#34C759;">confirmation_number</span>购买/出售门票</a>
        <a href="#whos-going"><span class="material-symbols-outlined text-sm" style="color:#006479;">diversity_3</span>谁要去？</a>
      </div>
      <div class="section-group"><div class="section-group-label">实用信息</div>
        <a href="#transport"><span class="material-symbols-outlined text-sm" style="color:#34C759;">directions_transit</span>交通</a>
        <a href="#safety"><span class="material-symbols-outlined text-sm" style="color:#ef4444;">health_and_safety</span>安全与贴士</a>
        <a href="#map"><span class="material-symbols-outlined text-sm" style="color:#006479;">map</span>曼谷同志地图</a>
      </div>
    </div>
  </aside>

  <!-- MAIN CONTENT -->
  <main class="flex-1 min-w-0 space-y-16">

    <!-- ── MAIN FESTIVALS ── -->
    <section id="festivals" class="section-anchor">
      <span class="section-label">主要节日</span>
      <h2 class="section-title">三大盛会</h2>
      <p class="text-sm mb-5" style="color:#326177;line-height:1.7;">长周末期间有三大付费节日同时举行。所有活动均对LGBTQ+友好——但GCircuit是同志旗舰活动。</p>
      <div class="grid gap-4 sm:grid-cols-3">
        <!-- S2O -->
        <div class="festival-card">
          <div>
            <div class="flex flex-wrap gap-1.5 mb-2">
              <span class="badge" style="background:rgba(64,206,243,0.12);color:#006479;">4月11–13日</span>
              <span class="badge" style="background:rgba(64,206,243,0.08);color:#006479;">S2O Land, Ratchada</span>
            </div>
            <div class="font-headline font-bold text-xl" style="color:#003345;">S2O Songkran</div>
            <div class="text-xs font-semibold mt-0.5 mb-2" style="color:#40cef3;">全球最湿派对</div>
            <p class="text-sm" style="color:#326177;line-height:1.5;">每次Drop都有巨型水炮齐射。国际EDM。非常同志友好，混合人群。你<strong style="color:#003345;">全程都会被淋透</strong>。</p>
          </div>
          <a href="/zh/events#s2o" class="btn btn-primary mt-auto" style="font-size:12px;">
            <span class="material-symbols-outlined" style="font-size:14px;">arrow_forward</span>完整阵容
          </a>
        </div>
        <!-- Siam -->
        <div class="festival-card">
          <div>
            <div class="flex flex-wrap gap-1.5 mb-2">
              <span class="badge" style="background:rgba(180,0,93,0.1);color:#b4005d;">4月11–14日</span>
              <span class="badge" style="background:rgba(180,0,93,0.07);color:#b4005d;">Bravo BKK Arena, RCA</span>
            </div>
            <div class="font-headline font-bold text-xl" style="color:#003345;">Siam Songkran</div>
            <div class="text-xs font-semibold mt-0.5 mb-2" style="color:#b4005d;">4晚EDM盛宴</div>
            <p class="text-sm" style="color:#326177;line-height:1.5;">室内场馆，水量少于S2O。Martin Garrix、Marshmello、John Summit。RCA旁边有很多俱乐部适合散场后继续嗨。</p>
          </div>
          <a href="/zh/events#siam" class="btn btn-primary mt-auto" style="font-size:12px;">
            <span class="material-symbols-outlined" style="font-size:14px;">arrow_forward</span>完整阵容
          </a>
        </div>
        <!-- GCircuit -->
        <div id="gcircuit" class="festival-card section-anchor">
          <div>
            <div class="flex flex-wrap gap-1.5 mb-2">
              <span class="badge" style="background:rgba(168,85,247,0.12);color:#7c3aed;">4月11–14日</span>
              <span class="badge" style="background:rgba(168,85,247,0.1);color:#7c3aed;">Emsphere + Tribe Sky</span>
            </div>
            <div class="font-headline font-bold text-xl" style="color:#003345;">GCircuit</div>
            <div class="text-xs font-semibold mt-0.5 mb-2" style="color:#a855f7;">亚洲第一同志Circuit派对</div>
            <p class="text-sm" style="color:#326177;line-height:1.5;">4场活动，4天，10,000+同志男生。泳池派对门票早早售罄。<strong style="color:#003345;">这才是重头戏。</strong></p>
          </div>
          <a href="/zh/events#gcircuit" class="btn btn-primary mt-auto" style="font-size:12px;">
            <span class="material-symbols-outlined" style="font-size:14px;">arrow_forward</span>完整阵容
          </a>
        </div>
      </div>
    </section>

    <!-- ── SILOM ── -->
    <section id="silom" class="section-anchor">
      <span class="section-label">免费街头派对</span>
      <h2 class="section-title">Silom Soi 2 & 4</h2>
      <div class="space-y-3">
        <div class="tip-card purple">
          <div class="flex items-start gap-3">
            <span class="material-symbols-outlined flex-shrink-0 mt-0.5" style="color:#a855f7;font-size:20px;font-variation-settings:'FILL' 1;">celebration</span>
            <div>
              <p class="font-bold text-sm mb-1" style="color:#003345;">4月12–14日 · 免费 · 欢迎所有人</p>
              <p class="text-sm" style="color:#326177;line-height:1.6;">曼谷历史悠久的同志区封街，化身全球最大免费LGBTQ+街头派对。每个路口都有音响车，泼水大战、泡沫、变装表演。整个同志社群加上成千上万游客齐聚。4月13日达到高峰。</p>
            </div>
          </div>
        </div>
        <div class="tip-card warn">
          <div class="flex items-start gap-3">
            <span class="material-symbols-outlined flex-shrink-0 mt-0.5" style="color:#FF9F0A;font-size:20px;font-variation-settings:'FILL' 1;">warning</span>
            <div>
              <p class="font-bold text-sm mb-1" style="color:#003345;">4月12–14日Silom路单行道且完全堵死</p>
              <p class="text-sm" style="color:#326177;">不要叫Grab穿越Silom。从BTS Sala Daeng或Chong Nonsi步行前往。BTS是唯一可靠的交通方式。</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ── SPECIAL EVENTS ── -->
    <section id="special" class="section-anchor">
      <span class="section-label">特别活动</span>
      <h2 class="section-title">不容错过</h2>
      <div class="space-y-3">

        <!-- Unleash -->
        <div class="event-card" style="border-color:rgba(168,85,247,0.25);">
          <div class="event-card-header" style="background:linear-gradient(135deg,rgba(168,85,247,0.08),rgba(236,72,153,0.05));">
            <div class="flex flex-wrap gap-2 mb-2">
              <span class="badge" style="background:rgba(168,85,247,0.12);color:#7c3aed;"><span class="material-symbols-outlined" style="font-size:11px;">calendar_today</span>4月13日 · 下午4–9时</span>
              <span class="badge" style="background:rgba(168,85,247,0.08);color:#7c3aed;"><span class="material-symbols-outlined" style="font-size:11px;">location_on</span>Side Bar, Silom</span>
              <span class="badge" style="background:rgba(236,72,153,0.1);color:#be185d;"><span class="material-symbols-outlined" style="font-size:11px;">local_activity</span>需购票</span>
            </div>
            <div class="font-headline font-bold text-lg" style="color:#003345;">Unleash — Wet Your Throat</div>
            <div class="text-sm font-semibold mt-0.5" style="color:#a855f7;">by Party Gay Asia</div>
          </div>
          <div class="event-card-body">
            <p class="text-sm mb-3" style="color:#326177;line-height:1.6;">一场下午cruising bar派对。暗室氛围、主题玩乐区、无拘cruising，让你完全做自己的空间。全程现场DJ。完美衔接下午泼水大战与夜晚俱乐部之间的空档。</p>
            <div class="flex flex-wrap gap-2 mb-3">
              <span class="badge" style="background:rgba(168,85,247,0.08);color:#7c3aed;"><span class="material-symbols-outlined" style="font-size:11px;">wb_twilight</span>暗室</span>
              <span class="badge" style="background:rgba(168,85,247,0.08);color:#7c3aed;"><span class="material-symbols-outlined" style="font-size:11px;">music_note</span>现场DJ</span>
              <span class="badge" style="background:rgba(168,85,247,0.08);color:#7c3aed;"><span class="material-symbols-outlined" style="font-size:11px;">groups</span>Cruising</span>
            </div>
            <div class="flex flex-wrap gap-2">
              <a href="https://yourtessera.com/e/unleash" target="_blank" rel="noopener" class="btn btn-primary">
                <span class="material-symbols-outlined" style="font-size:14px;">confirmation_number</span>购票
              </a>
              <a href="https://instagram.com/partygayasia" target="_blank" rel="noopener" class="btn btn-outline">
                <span class="material-symbols-outlined" style="font-size:14px;">photo_camera</span>@partygayasia
              </a>
            </div>
          </div>
        </div>

      </div>
    </section>

    <!-- ── CLUBS & BARS ── -->
    <section id="clubs" class="section-anchor">
      <span class="section-label">夜生活</span>
      <h2 class="section-title">同志俱乐部与酒吧</h2>
      <div class="space-y-3">

        {[
          {
            name: 'GOD Club',
            area: 'Silom附近',
            icon: 'nightlife', color: '#1a1a2e',
            badges: [
              {label:'散场后继续', bg:'rgba(0,0,0,0.06)', c:'#003345'},
              {label:'凌晨3时关门', bg:'rgba(52,199,89,0.1)', c:'#16a34a'},
              {label:'宋干节排队极长', bg:'rgba(239,68,68,0.1)', c:'#dc2626'},
            ],
            desc: '曼谷最著名的同志散场俱乐部。多层楼，暗黑氛围，circuit音乐。宋干节期间排队可达45–60分钟——午夜前到达可避开长龙。',
            hours: '深夜开始 · 凌晨3时关门',
            entry: '฿400',
          },
          {
            name: 'DJ Station',
            area: 'Silom Soi 2',
            icon: 'nightlife', color: '#a855f7',
            badges: [
              {label:'旗舰同志俱乐部', bg:'rgba(168,85,247,0.1)', c:'#7c3aed'},
            ],
            desc: '曼谷最具代表性的同志俱乐部。3层楼，宋干节期间人山人海。入场含一杯饮品。跳舞，氛围极好。早点来——排队会很长。',
            hours: '凌晨3时关门',
            entry: '฿400 含饮品',
          },
          {
            name: 'Balcony Bar',
            area: 'Silom Soi 4',
