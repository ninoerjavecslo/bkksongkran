<script>
const sections = document.querySelectorAll('.section-anchor');
const navLinks = document.querySelectorAll('.guide-sidebar a[href^="#"]');

function updateActive() {
  let current = '';
  sections.forEach(s => {
    if (window.scrollY >= (s as HTMLElement).offsetTop - 120) current = '#' + s.id;
  });
  navLinks.forEach(a => a.classList.toggle('active', a.getAttribute('href') === current));
}

window.addEventListener('scroll', updateActive, { passive: true });
updateActive();

(window as any).closeMobileNav = function() {
  document.getElementById('guide-sidebar')?.classList.remove('open');
};
</script>
