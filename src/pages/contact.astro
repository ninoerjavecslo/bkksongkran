---
import BaseLayout from '../components/layout/BaseLayout.astro';
const type = Astro.url.searchParams.get('type') || 'general';
---

<BaseLayout
  title="Contact — Bangkok Songkran 2026"
  description="Get in touch — feature your event, ask about Who's Going?, or send a general enquiry."
  canonical="https://bkksongkran.com/contact"
>

  <section class="pt-36 pb-20 px-6" style="background:linear-gradient(180deg,rgba(225,243,255,0.8),rgba(238,248,255,0));">
    <div class="max-w-xl mx-auto">

      <div class="text-xs font-bold tracking-[0.2em] uppercase mb-3" style="color:#006479;">Get in touch</div>
      <h1 class="font-headline font-extrabold tracking-tighter mb-4" style="font-size:clamp(2.5rem,7vw,4rem);color:#003345;line-height:0.95;">
        CONTACT<br/>
        <span style="background:linear-gradient(135deg,#006479,#40cef3);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;">US</span>
      </h1>

      <!-- Type selector -->
      <div class="flex flex-wrap gap-2 mb-8">
        {[
          { val: 'feature-event', label: 'Feature my event', icon: 'star' },
          { val: 'report-scam',  label: 'Report scammer',   icon: 'report' },
          { val: 'general',      label: 'General enquiry',  icon: 'mail' },
        ].map(t => (
          <button
            class="contact-type-btn flex items-center gap-2 px-4 py-2 rounded-full text-sm font-bold border-2 transition-all"
            data-type={t.val}
            style={type === t.val
              ? 'border-color:#006479;color:#fff;background:#006479;'
              : 'border-color:rgba(192,232,255,0.8);color:#326177;background:white;'}
          >
            <span class="material-symbols-outlined text-sm" style="font-variation-settings:'FILL' 1;">{t.icon}</span>
            {t.label}
          </button>
        ))}
      </div>

      <!-- Context hints -->
      <div id="hint-feature-event" class="tip-hint mb-6" style={type !== 'feature-event' ? 'display:none' : ''}>
        <div class="flex items-start gap-3 p-4 rounded-xl" style="background:rgba(64,206,243,0.07);border:1px solid rgba(64,206,243,0.2);">
          <span class="material-symbols-outlined flex-shrink-0 mt-0.5" style="color:#006479;font-variation-settings:'FILL' 1;">info</span>
          <p class="text-sm" style="color:#326177;line-height:1.6;">Want your event featured on the events page? Share the details below — name, dates, venue, website, and a short description. We'll review and add it if it fits.</p>
        </div>
      </div>
      <div id="hint-report-scam" class="tip-hint mb-6" style={type !== 'report-scam' ? 'display:none' : ''}>
        <div class="flex items-start gap-3 p-4 rounded-xl" style="background:rgba(239,68,68,0.06);border:1px solid rgba(239,68,68,0.15);">
          <span class="material-symbols-outlined flex-shrink-0 mt-0.5" style="color:#dc2626;font-variation-settings:'FILL' 1;">warning</span>
          <p class="text-sm" style="color:#326177;line-height:1.6;">Got scammed or spotted a fraudulent ticket listing? Share the details — username, contact info, what happened — and we'll remove the listing and warn others.</p>
        </div>
      </div>

      <!-- Form -->
      <div class="card p-6 space-y-4">
        <input type="hidden" id="contact-type" value={type} />

        <div>
          <label class="block text-xs font-bold uppercase tracking-wider mb-1.5" style="color:#6b8fa3;">Your name <span style="color:#b31b25;">*</span></label>
          <input id="contact-name" type="text" maxlength="100" placeholder="Marco, Alex..." class="w-full px-4 py-3 rounded-xl text-sm font-medium outline-none" style="background:rgba(225,243,255,0.7);border:1.5px solid rgba(192,232,255,0.8);color:#003345;" />
        </div>
        <div>
          <label class="block text-xs font-bold uppercase tracking-wider mb-1.5" style="color:#6b8fa3;">Your email <span style="color:#b31b25;">*</span></label>
          <input id="contact-email" type="email" maxlength="254" placeholder="you@email.com" class="w-full px-4 py-3 rounded-xl text-sm font-medium outline-none" style="background:rgba(225,243,255,0.7);border:1.5px solid rgba(192,232,255,0.8);color:#003345;" />
        </div>
        <div>
          <label class="block text-xs font-bold uppercase tracking-wider mb-1.5" style="color:#6b8fa3;">Message <span style="color:#b31b25;">*</span></label>
          <textarea id="contact-message" maxlength="2000" rows="6" placeholder="Tell us more..." class="w-full px-4 py-3 rounded-xl text-sm font-medium outline-none resize-none" style="background:rgba(225,243,255,0.7);border:1.5px solid rgba(192,232,255,0.8);color:#003345;"></textarea>
        </div>

        <p id="contact-error" class="hidden text-xs font-bold" style="color:#b31b25;"></p>
        <p id="contact-success" class="hidden text-sm font-bold" style="color:#16a34a;">Message sent! We'll get back to you soon.</p>

        <button id="contact-submit" class="w-full flex items-center justify-center gap-2 px-6 py-3 rounded-xl text-sm font-bold text-white transition-all" style="background:linear-gradient(135deg,#006479,#40cef3);">
          <span class="material-symbols-outlined text-base" style="font-variation-settings:'FILL' 1;">send</span>
          Send Message
        </button>
      </div>

    </div>
  </section>

</BaseLayout>

<script>
const typeButtons = document.querySelectorAll('.contact-type-btn');
const typeInput   = document.getElementById('contact-type') as HTMLInputElement;
const hints       = document.querySelectorAll('.tip-hint');

typeButtons.forEach(btn => {
  btn.addEventListener('click', () => {
    const t = (btn as HTMLElement).dataset.type!;
    typeInput.value = t;

    typeButtons.forEach(b => {
      const el = b as HTMLElement;
      const active = el.dataset.type === t;
      el.style.background     = active ? '#006479' : 'white';
      el.style.color          = active ? '#fff'    : '#326177';
      el.style.borderColor    = active ? '#006479' : 'rgba(192,232,255,0.8)';
    });

    hints.forEach(h => {
      (h as HTMLElement).style.display = (h as HTMLElement).id === 'hint-' + t ? '' : 'none';
    });
  });
});

document.getElementById('contact-submit')!.addEventListener('click', async () => {
  const btn     = document.getElementById('contact-submit')!;
  const errEl   = document.getElementById('contact-error')!;
  const sucEl   = document.getElementById('contact-success')!;
  const name    = (document.getElementById('contact-name') as HTMLInputElement).value.trim();
  const email   = (document.getElementById('contact-email') as HTMLInputElement).value.trim();
  const message = (document.getElementById('contact-message') as HTMLTextAreaElement).value.trim();
  const type    = typeInput.value;

  errEl.classList.add('hidden');
  sucEl.classList.add('hidden');

  if (!name)    { errEl.textContent = 'Please enter your name.'; errEl.classList.remove('hidden'); return; }
  if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) { errEl.textContent = 'Please enter a valid email.'; errEl.classList.remove('hidden'); return; }
  if (!message) { errEl.textContent = 'Please enter a message.'; errEl.classList.remove('hidden'); return; }

  btn.setAttribute('disabled', 'true'); btn.style.opacity = '0.6';
  try {
    const res = await fetch('/api/contact', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ type, name, email, message }),
    });
    const data = await res.json();
    if (!res.ok) throw new Error(data.error || 'Failed');
    sucEl.classList.remove('hidden');
    (document.getElementById('contact-name') as HTMLInputElement).value = '';
    (document.getElementById('contact-email') as HTMLInputElement).value = '';
    (document.getElementById('contact-message') as HTMLTextAreaElement).value = '';
  } catch (e: any) {
    errEl.textContent = e.message || 'Something went wrong. Try again.';
    errEl.classList.remove('hidden');
  } finally {
    btn.removeAttribute('disabled'); btn.style.opacity = '1';
  }
});
</script>
