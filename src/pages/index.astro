---
import BaseLayout from '../components/layout/BaseLayout.astro';
import EventCard from '../components/molecules/EventCard.astro';
import { festivals, additionalEvents } from '../data/index';
import { articles } from '../data/articles';

// Combine all events for the slider
const allEvents = [
  ...festivals.map(f => ({ ...f, isFestival: true })),
  ...additionalEvents.filter(e => e.type === 'festival').map(e => ({ ...e, isFestival: false })),
];
const featuredArticles = articles.slice(0, 3);
---

<BaseLayout title="Bangkok Songkran 2026 — Complete Festival Guide, Lineups & Live Map" description="The complete guide to Songkran 2026 in Bangkok. Real lineups (S2O, Siam Songkran, GCircuit), live crowd map, AI trip planner, and survival checklist. April 10-15, 2026." canonical="https://bkksongkran.com">

  <!-- Website Schema -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "Bangkok Songkran",
    "url": "https://bkksongkran.com",
    "description": "The complete guide to Songkran 2026 in Bangkok. Festival lineups, live crowd map, AI planner.",
    "potentialAction": {
      "@type": "SearchAction",
      "target": "https://bkksongkran.com/blog?q={search_term_string}",
      "query-input": "required name=search_term_string"
    }
  })} />

  <!-- Event Schema -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Event",
    "name": "Songkran Festival Bangkok 2026",
    "startDate": "2026-04-10",
    "endDate": "2026-04-15",
    "location": { "@type": "Place", "name": "Bangkok, Thailand", "address": { "@type": "PostalAddress", "addressLocality": "Bangkok", "addressCountry": "TH" }},
    "description": "Thailand's famous New Year water festival. Music festivals, street water fights, cultural events across Bangkok.",
    "eventAttendanceMode": "https://schema.org/OfflineEventAttendanceMode",
    "eventStatus": "https://schema.org/EventScheduled",
  })} />

  <!-- ═══ HERO ═══ -->
  <section class="relative min-h-screen flex items-center pt-28 pb-20 px-6 overflow-hidden">
    <div class="absolute inset-0 z-0">
      <img src="/hero-songkran.jpg" alt="Songkran Bangkok 2026 water fight festival crowd" class="w-full h-full object-cover" loading="eager" />
      <div class="absolute inset-0" style="background:linear-gradient(135deg,rgba(0,30,50,0.85) 0%,rgba(0,100,121,0.6) 50%,rgba(0,51,69,0.8) 100%);"></div>
    </div>

    <div class="relative z-10 max-w-7xl mx-auto w-full grid md:grid-cols-2 gap-12 lg:gap-20 items-center">
      <div class="space-y-7">
        <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full text-xs font-bold" style="background:rgba(255,197,166,0.2);color:#ffdcc8;border:1px solid rgba(255,197,166,0.35);">
          <span class="relative flex h-2 w-2">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-secondary-fixed opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-secondary-fixed"></span>
          </span>
          Live from Bangkok · April 10–15, 2026
        </div>

        <h1 class="font-headline font-extrabold leading-[0.88] tracking-tighter text-white" style="font-size:clamp(3rem,8vw,6rem);text-shadow:0 4px 32px rgba(0,100,121,0.5);">
          BANGKOK<br/>
          <span class="text-hero-accent">SONGKRAN</span><br/>
          2026
        </h1>

        <p class="text-lg font-medium leading-relaxed text-hero-text max-w-[480px]">
          Every festival. Every lineup. Every water fight zone. The only guide you need for Songkran in Bangkok.
        </p>

        <div class="flex gap-4 flex-wrap">
          <a href="/events" class="btn-primary px-8 py-4 text-base">
            <span class="material-symbols-outlined text-xl" style="font-variation-settings:'FILL' 1;">calendar_month</span>
            See All Events
          </a>
          <a href="/survival-kit" class="btn px-8 py-4 text-base text-white transition-all hover:bg-white/20 hover:scale-105" style="background:rgba(255,255,255,0.12);border:1px solid rgba(255,255,255,0.3);">
            <span class="material-symbols-outlined text-xl text-hero-accent" style="font-variation-settings:'FILL' 1;">backpack</span>
            Survival Kit
          </a>
        </div>

        <div class="flex gap-10 pt-2">
          {[{n:'20+',l:'Festivals & Events'},{n:'8',l:'Water Fight Zones'},{n:'7',l:'Days of Action'}].map(s => (
            <div>
              <div class="font-headline font-black text-3xl text-hero-accent">{s.n}</div>
              <div class="text-xs font-semibold text-hero-text-muted">{s.l}</div>
            </div>
          ))}
        </div>
      </div>

      <!-- COUNTDOWN -->
      <div class="flex flex-col items-center gap-6">
        <div class="rounded-3xl p-8 text-center w-full" style="background:rgba(0,30,50,0.5);backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);border:1px solid rgba(93,216,247,0.2);">
          <div class="text-xs font-bold uppercase tracking-[0.25em] mb-5 text-hero-accent">Songkran starts in</div>
          <div class="grid grid-cols-4 gap-3" id="countdown-grid">
            <div>
              <div class="font-headline font-black text-4xl md:text-5xl text-white" id="cd-days">--</div>
              <div class="text-[10px] font-bold uppercase tracking-widest mt-1 text-hero-accent">Days</div>
            </div>
            <div>
              <div class="font-headline font-black text-4xl md:text-5xl text-white" id="cd-hours">--</div>
              <div class="text-[10px] font-bold uppercase tracking-widest mt-1 text-hero-accent">Hours</div>
            </div>
            <div>
              <div class="font-headline font-black text-4xl md:text-5xl text-white" id="cd-mins">--</div>
              <div class="text-[10px] font-bold uppercase tracking-widest mt-1 text-hero-accent">Mins</div>
            </div>
            <div>
              <div class="font-headline font-black text-4xl md:text-5xl text-white" id="cd-secs">--</div>
              <div class="text-[10px] font-bold uppercase tracking-widest mt-1 text-hero-accent">Secs</div>
            </div>
          </div>
          <div class="mt-6 pt-4" style="border-top:1px solid rgba(93,216,247,0.15);">
            <span class="text-sm font-semibold text-hero-text-muted">April 10–15, 2026 · Bangkok, Thailand</span>
          </div>
        </div>
      </div>
    </div>

    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 opacity-50">
      <span class="text-xs font-bold uppercase tracking-widest text-white">Scroll</span>
      <div class="w-px h-10" style="background:linear-gradient(to bottom,#fff,transparent);"></div>
    </div>
  </section>

  <!-- ═══ BENTO HIGHLIGHTS ═══ -->
  <section class="section">
    <div class="section-inner">
      <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-12">
        <div>
          <div class="text-xs font-bold tracking-[0.2em] uppercase mb-2 text-primary">Festival Highlights</div>
          <h2 class="font-headline text-4xl md:text-5xl font-extrabold text-on-surface">The Big Three</h2>
        </div>
        <a href="/events" class="flex items-center gap-2 text-sm font-bold text-primary transition-all hover:gap-4 group">
          Full lineup details
          <span class="material-symbols-outlined transition-transform group-hover:translate-x-1">arrow_forward</span>
        </a>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-12 gap-6">
        <a href="/events#siam" class="md:col-span-7 relative group overflow-hidden rounded-2xl block" style="min-height:380px;">
          <img src="/festival-siam-songkran.webp" alt="Siam Songkran festival Bangkok 2026" class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" />
          <div class="absolute inset-0" style="background:linear-gradient(to top,rgba(0,51,69,0.97) 0%,rgba(0,51,69,0.55) 55%,rgba(0,51,69,0.2) 100%);"></div>
          <div class="absolute bottom-0 left-0 p-8 w-full">
            <span class="inline-block px-3 py-1 rounded-full text-xs font-bold mb-3" style="background:rgba(93,216,247,0.25);color:#b0ecff;border:1px solid rgba(93,216,247,0.35);">Main Stage · Apr 11–14</span>
            <h3 class="font-headline text-3xl md:text-4xl font-black text-white mb-2">Siam Songkran</h3>
            <p class="text-sm font-medium text-hero-text-dim">Martin Garrix · Marshmello · John Summit · ARTBAT</p>
            <div class="flex items-center gap-3 mt-4">
              <span class="font-headline font-black text-xl text-hero-accent">฿1,500+</span>
              <span class="text-xs px-3 py-1 rounded-full font-bold" style="background:rgba(255,142,178,0.25);color:#ffb8d0;">4 NIGHTS</span>
            </div>
          </div>
        </a>

        <div class="md:col-span-5 grid grid-rows-2 gap-6">
          <a href="/events#s2o" class="relative group overflow-hidden rounded-2xl block">
            <img src="/festival-s2o.jpeg" alt="S2O Songkran water music festival Bangkok" class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" />
            <div class="absolute inset-0" style="background:linear-gradient(to top,rgba(0,51,69,0.97) 0%,rgba(0,51,69,0.5) 55%,rgba(0,51,69,0.15) 100%);"></div>
            <div class="absolute bottom-0 left-0 p-6">
              <span class="inline-block px-2 py-0.5 rounded-full text-[10px] font-bold mb-1" style="background:rgba(93,216,247,0.25);color:#b0ecff;">EDM · Apr 11–13</span>
              <h3 class="font-headline text-2xl font-black text-white">S2O Festival</h3>
              <p class="text-xs font-medium mt-1 text-hero-text-muted">Alan Walker × Steve Aoki · Zedd · Kygo</p>
            </div>
          </a>
          <a href="/events#gcircuit" class="relative group overflow-hidden rounded-2xl block">
            <img src="/festival-gcircuit.jpg" alt="GCircuit Songkran LGBTQ+ circuit party Bangkok" class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" />
            <div class="absolute inset-0" style="background:linear-gradient(to top,rgba(76,29,149,0.97) 0%,rgba(76,29,149,0.6) 55%,rgba(180,0,93,0.25) 100%);"></div>
            <div class="absolute bottom-0 left-0 p-6">
              <span class="inline-block px-2 py-0.5 rounded-full text-[10px] font-bold mb-1" style="background:rgba(255,142,178,0.25);color:#ffb8d0;border:1px solid rgba(255,142,178,0.35);"><span class="material-symbols-outlined text-[10px]" style="font-variation-settings:'FILL' 1;">diversity_3</span> LGBTQ+ · Apr 10–13</span>
              <h3 class="font-headline text-2xl font-black text-white">GCircuit 20th</h3>
              <p class="text-xs font-medium mt-1" style="color:#ecc4d4;">ADRO-MADA: City of Tomorrow</p>
            </div>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ QUICK LINKS ═══ -->
  <section class="px-6 py-12">
    <div class="section-inner grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
      <a href="/events" class="card p-5 space-y-3 group block bg-surface-container-low cursor-pointer">
        <div class="w-11 h-11 rounded-xl flex items-center justify-center flex-shrink-0 bg-primary">
          <span class="material-symbols-outlined text-white text-lg" style="font-variation-settings:'FILL' 1;">calendar_month</span>
        </div>
        <h3 class="font-headline font-bold text-base text-on-surface">All Events</h3>
        <p class="text-sm text-content-muted">20+ festivals, street parties, and cultural events.</p>
        <div class="flex items-center gap-1 text-sm font-bold text-primary group-hover:gap-3 transition-all">
          Browse events
          <span class="material-symbols-outlined text-base transition-transform group-hover:translate-x-1">arrow_forward</span>
        </div>
      </a>

      <a href="/survival-kit" class="card p-5 space-y-3 group block bg-secondary-on cursor-pointer">
        <div class="w-11 h-11 rounded-xl flex items-center justify-center flex-shrink-0 bg-secondary">
          <span class="material-symbols-outlined text-white text-lg" style="font-variation-settings:'FILL' 1;">checklist</span>
        </div>
        <h3 class="font-headline font-bold text-base text-on-surface">Survival Kit</h3>
        <p class="text-sm text-content-muted">Everything to pack. Track your readiness.</p>
        <div class="flex items-center gap-1 text-sm font-bold text-secondary group-hover:gap-3 transition-all">
          Check list
          <span class="material-symbols-outlined text-base transition-transform group-hover:translate-x-1">arrow_forward</span>
        </div>
      </a>

      <a href="/blog" class="card p-5 space-y-3 group block bg-emerald-50 cursor-pointer">
        <div class="w-11 h-11 rounded-xl flex items-center justify-center flex-shrink-0 bg-emerald-600">
          <span class="material-symbols-outlined text-white text-lg" style="font-variation-settings:'FILL' 1;">travel_explore</span>
        </div>
        <h3 class="font-headline font-bold text-base text-on-surface">Travel Tips</h3>
        <p class="text-sm text-content-muted">Packing lists, safety advice, and local insights.</p>
        <div class="flex items-center gap-1 text-sm font-bold text-emerald-600 group-hover:gap-3 transition-all">
          Read guides
          <span class="material-symbols-outlined text-base transition-transform group-hover:translate-x-1">arrow_forward</span>
        </div>
      </a>

      <div class="card p-5 space-y-3 block bg-surface-container-low opacity-70 cursor-default">
        <div class="flex items-center justify-between">
          <div class="w-11 h-11 rounded-xl flex items-center justify-center flex-shrink-0 bg-primary">
            <span class="material-symbols-outlined text-white text-lg" style="font-variation-settings:'FILL' 1;">map</span>
          </div>
          <span class="inline-flex items-center px-2.5 py-1 rounded-full text-[10px] font-bold uppercase tracking-wider bg-amber-100 text-amber-600">Coming Soon</span>
        </div>
        <h3 class="font-headline font-bold text-base text-on-surface">Live Heat Map</h3>
        <p class="text-sm text-content-muted">Real-time crowd levels at every zone. Goes live during Songkran.</p>
      </div>
    </div>
  </section>

  <!-- ═══ ARTICLES ═══ -->
  <section class="px-6 pb-20 pt-12">
    <div class="section-inner">
      <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-8">
        <div>
          <div class="text-xs font-bold tracking-[0.2em] uppercase mb-2 text-primary">Songkran Guide</div>
          <h2 class="font-headline text-4xl font-extrabold text-on-surface">Plan Your Trip</h2>
        </div>
        <a href="/blog" class="flex items-center gap-1 text-sm font-bold text-primary transition-all hover:gap-3 group">
          All articles
          <span class="material-symbols-outlined text-base transition-transform group-hover:translate-x-1">arrow_forward</span>
        </a>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {featuredArticles.map((article, i) => (
          <a href={`/blog/${article.slug}`} class="card p-0 overflow-hidden group block">
            {i === 0 ? (
              <div class="relative" style="height:200px;">
                <img src={article.featuredImage} alt={article.title} class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" loading="lazy" />
                <div class="absolute inset-0" style="background:linear-gradient(to top,rgba(0,51,69,0.9),transparent 60%);"></div>
                <div class="absolute bottom-0 left-0 p-5">
                  <span class="inline-block px-2 py-0.5 rounded-full text-[10px] font-bold uppercase text-white" style={`background:${article.categoryColor}30;`}>{article.category}</span>
                  <h3 class="font-headline font-bold text-base text-white mt-2 leading-snug">{article.h1}</h3>
                </div>
              </div>
            ) : (
              <Fragment>
                <div class="h-1.5 w-full" style={`background:${article.categoryColor};`}></div>
                <div class="p-5 space-y-2">
                  <div class="flex items-center gap-2">
                    <span class="text-[10px] font-bold uppercase" style={`color:${article.categoryColor};`}>{article.category}</span>
                    <span class="text-[10px] text-content-light">{article.readTime} min</span>
                  </div>
                  <h3 class="font-headline font-bold text-base leading-snug text-on-surface group-hover:text-primary transition-colors">{article.h1}</h3>
                  <p class="text-xs line-clamp-2 text-content-muted">{article.excerpt}</p>
                  <span class="flex items-center gap-1 text-xs font-bold text-primary group-hover:gap-2 transition-all">
                    Read more <span class="material-symbols-outlined text-xs">arrow_forward</span>
                  </span>
                </div>
              </Fragment>
            )}
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ EVENTS SLIDER ═══ -->
  <section class="section">
    <div class="section-inner">
      <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-8">
        <div>
          <div class="text-xs font-bold tracking-[0.2em] uppercase mb-2 text-primary">April 10–15, 2026</div>
          <h2 class="font-headline text-4xl md:text-5xl font-extrabold text-on-surface">All Events</h2>
        </div>
        <div class="flex items-center gap-2">
          <button id="slider-prev" class="w-10 h-10 rounded-full flex items-center justify-center border-2 border-surface-container-high text-outline transition-all hover:bg-primary hover:text-white hover:border-primary">
            <span class="material-symbols-outlined text-lg">chevron_left</span>
          </button>
          <button id="slider-next" class="w-10 h-10 rounded-full flex items-center justify-center border-2 border-surface-container-high text-outline transition-all hover:bg-primary hover:text-white hover:border-primary">
            <span class="material-symbols-outlined text-lg">chevron_right</span>
          </button>
          <a href="/events" class="flex items-center gap-1 text-sm font-bold ml-3 text-primary transition-all hover:gap-3 group">
            View all
            <span class="material-symbols-outlined text-base transition-transform group-hover:translate-x-1">arrow_forward</span>
          </a>
        </div>
      </div>

      <div class="overflow-hidden" id="events-slider-wrap">
        <div class="flex gap-5 transition-transform duration-500 ease-out" id="events-slider">
          {allEvents.map(e => (
            <div class="flex-shrink-0" style="width:320px;">
              <a href={`/events#${e.id}`} class="card p-0 overflow-hidden block group" style="height:100%;">
                <div class="h-1.5 w-full" style={`background:${e.color};`}></div>
                <div class="p-5 space-y-3">
                  <div class="flex items-center gap-2 flex-wrap">
                    <span class="inline-block px-2.5 py-0.5 rounded-full text-[10px] font-bold uppercase tracking-wider" style={`background:${e.color}15;color:${e.colorDark || e.color};`}>
                      {(e as any).type === 'circuit' ? 'LGBTQ+' : 'Festival'}
                    </span>
                    <span class="text-xs font-bold text-outline">{e.dates}</span>
                  </div>
                  <h3 class="font-headline text-lg font-extrabold leading-tight text-on-surface group-hover:text-primary transition-colors">{e.name}</h3>
                  <p class="text-xs leading-relaxed line-clamp-2 text-content-muted">
                    {(e as any).description || (e as any).desc || (e as any).tagline}
                  </p>
                  <div class="flex items-center gap-1.5 text-xs text-outline">
                    <span class="material-symbols-outlined text-sm" style="font-variation-settings:'FILL' 1;">location_on</span>
                    {(e as any).venue || (e as any).area}
                  </div>
                  <div class="flex items-center justify-between pt-2 border-t border-surface-container-high/50">
                    <span class="font-headline font-black text-base" style={`color:${e.colorDark || e.color};`}>
                      {(e as any).price || 'Free'}
                    </span>
                    <span class="flex items-center gap-1 text-xs font-bold text-primary group-hover:gap-2 transition-all">
                      Details <span class="material-symbols-outlined text-xs">arrow_forward</span>
                    </span>
                  </div>
                </div>
              </a>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>


</BaseLayout>

<script>
// Countdown
function updateCountdown() {
  const target = new Date('2026-04-10T00:00:00+07:00');
  const diff = target.getTime() - Date.now();

  const days = document.getElementById('cd-days');
  const hours = document.getElementById('cd-hours');
  const mins = document.getElementById('cd-mins');
  const secs = document.getElementById('cd-secs');

  if (!days || !hours || !mins || !secs) return;

  if (diff <= 0) {
    days.textContent = '0';
    hours.textContent = '0';
    mins.textContent = '0';
    secs.textContent = '0';
    return;
  }

  days.textContent = String(Math.floor(diff / 86400000));
  hours.textContent = String(Math.floor((diff % 86400000) / 3600000));
  mins.textContent = String(Math.floor((diff % 3600000) / 60000));
  secs.textContent = String(Math.floor((diff % 60000) / 1000));
}
updateCountdown();
setInterval(updateCountdown, 1000);

// Events slider
const slider = document.getElementById('events-slider');
const wrap = document.getElementById('events-slider-wrap');
const prevBtn = document.getElementById('slider-prev');
const nextBtn = document.getElementById('slider-next');

if (slider && wrap && prevBtn && nextBtn) {
  let pos = 0;
  const cardW = 340; // 320 + 20 gap

  function getMaxScroll() {
    return Math.max(0, slider.scrollWidth - wrap.clientWidth);
  }

  function slide(dir: number) {
    const max = getMaxScroll();
    pos = Math.min(max, Math.max(0, pos + dir * cardW * 2));
    slider.style.transform = `translateX(-${pos}px)`;
  }

  prevBtn.addEventListener('click', () => slide(-1));
  nextBtn.addEventListener('click', () => slide(1));

  // Touch swipe
  let touchStart = 0;
  wrap.addEventListener('touchstart', (e) => { touchStart = e.touches[0].clientX; }, { passive: true });
  wrap.addEventListener('touchend', (e) => {
    const diff = touchStart - e.changedTouches[0].clientX;
    if (Math.abs(diff) > 50) slide(diff > 0 ? 1 : -1);
  }, { passive: true });
}
</script>
