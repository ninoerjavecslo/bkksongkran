<script define:vars={{ partiesJson, SUPABASE_URL, SUPABASE_KEY }}>
const PARTIES = JSON.parse(partiesJson);
const API = SUPABASE_URL + '/rest/v1/meetup_entries';
const HDRS = {
  'apikey': SUPABASE_KEY,
  'Authorization': 'Bearer ' + SUPABASE_KEY,
  'Content-Type': 'application/json',
};

const colorMap = {};
PARTIES.forEach(p => { colorMap[p.id] = p.color; });

let byParty = {};
let customByDay = {};

// ── Rate limiting (max 3 submissions per session) ─────────────
let sessionSubmits = 0;
const MAX_SUBMITS = 3;

// ── Spam / promo detection ────────────────────────────────────
const SPAM_PATTERNS = [
  /https?:\/\//i,           // URLs
  /www\./i,                 // URLs without protocol
  /\.com|\.net|\.io|\.co\b/i, // domains
  /discount|promo|promotion/i,
  /free\s*ticket/i,
  /buy\s*ticket/i,
  /vip\s*table/i,
  /bottle\s*service/i,
  /guestlist|guest\s*list/i,
  /\bsell\b|\bselling\b/i,
  /whatsapp\.com|t\.me|linktree/i,
  /\d{3,}% off/i,
  /only ฿|฿\d+.*deal/i,
];

function isSpam(text) {
  return SPAM_PATTERNS.some(p => p.test(text));
}

function validateContact(contact) {
  const c = contact.trim();
  if (!c) return 'Instagram or WhatsApp is required so others can reach you.';
  // Instagram: starts with @ or is just letters/numbers/dots/underscores
  const isIG = /^@?[\w.]{1,30}$/.test(c);
  // WhatsApp: phone number with optional + and country code
  const isWA = /^\+?[\d\s\-()]{7,20}$/.test(c);
  if (!isIG && !isWA) return 'Please enter a valid Instagram handle (e.g. @yourname) or WhatsApp number (e.g. +66 812 345 678).';
  return null;
}

function validateText(name, contact, note) {
  if (isSpam(name))    return '⚠️ That name looks like a promotion. This space is for personal meetups only.';
  if (isSpam(contact)) return '⚠️ Please enter just your Instagram handle or phone number.';
  if (note && isSpam(note)) return '⚠️ Your note looks like a promotion. No ticket selling or advertising allowed.';
  const contactErr = validateContact(contact);
  if (contactErr) return contactErr;
  return null;
}

// ── Load ─────────────────────────────────────────────────────
async function load() {
  try {
    const res = await fetch(API + '?select=*&order=created_at.asc', { headers: HDRS });
    if (!res.ok) throw new Error();
    const rows = await res.json();

    byParty = {};
    customByDay = {};

    rows.forEach(r => {
      if (r.is_custom) {
        if (!customByDay[r.day]) customByDay[r.day] = {};
        const key = r.event_name || 'Community Event';
        if (!customByDay[r.day][key]) {
          customByDay[r.day][key] = {
            id: 'c-' + key.toLowerCase().replace(/[^a-z0-9]/g,'-').slice(0,30),
            name: key,
            entries: []
          };
        }
        customByDay[r.day][key].entries.push(r);
      } else {
        if (!byParty[r.party]) byParty[r.party] = [];
        byParty[r.party].push(r);
      }
    });

    PARTIES.forEach(p => renderParty(p.id));
    renderAllCustom();
    document.getElementById('loading-state').style.display = 'none';
  } catch {
    document.getElementById('loading-state').style.display = 'none';
    document.getElementById('error-state').classList.remove('hidden');
    PARTIES.forEach(p => renderParty(p.id));
  }
}

// ── Render official party ─────────────────────────────────────
function renderParty(pid) {
  const entries = byParty[pid] || [];
  const peopleEl = document.getElementById('people-' + pid);
  const countEl  = document.getElementById('count-' + pid);
  if (!peopleEl || !countEl) return;

  const n = entries.length;
  countEl.textContent = n === 0 ? 'Be first!' : n + ' going';
  renderChips(peopleEl, entries, colorMap[pid] || '#40cef3');
}

// ── Chip ──────────────────────────────────────────────────────
function chip(entry, color) {
  const c = document.createElement('div');
  c.style.cssText = 'display:inline-flex;align-items:center;gap:6px;padding:4px 10px 4px 4px;border-radius:9999px;background:white;border:1px solid rgba(192,232,255,0.8);box-shadow:0 1px 4px rgba(0,51,69,0.06);max-width:240px;';

  const av = document.createElement('div');
  av.style.cssText = `width:24px;height:24px;border-radius:50%;display:inline-flex;align-items:center;justify-content:center;font-size:10px;font-weight:800;color:white;flex-shrink:0;text-transform:uppercase;background:${color};`;
  av.textContent = (entry.name || '?').trim()[0];

  const nm = document.createElement('span');
  nm.style.cssText = 'font-size:14px;font-weight:800;color:#000;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;max-width:90px;flex-shrink:0;';
  nm.textContent = entry.name || '';

  c.appendChild(av);
  c.appendChild(nm);

  // note field: "contact · optional-note"
  const rawNote = (entry.note || '').trim();
  if (rawNote) {
    const parts = rawNote.split(' · ');
    const contact = parts[0].trim();
    const noteText = parts.slice(1).join(' · ').trim();

    let href = null;
    if (contact.startsWith('@')) {
      href = 'https://instagram.com/' + contact.slice(1);
    } else if (/^\+?[\d\s\-()]{7,}$/.test(contact)) {
      href = 'https://wa.me/' + contact.replace(/\D/g, '');
    }

    if (href) {
      const link = document.createElement('a');
      link.href = href;
      link.target = '_blank';
      link.rel = 'noopener noreferrer';
      link.style.cssText = 'display:inline-flex;align-items:center;padding:2px 8px;border-radius:20px;background:rgba(0,51,69,0.07);font-size:12px;font-weight:700;color:#003345;text-decoration:none;white-space:nowrap;flex-shrink:0;';
      link.textContent = contact;
      link.addEventListener('mouseover', () => { link.style.background = 'rgba(0,51,69,0.15)'; });
      link.addEventListener('mouseout',  () => { link.style.background = 'rgba(0,51,69,0.07)'; });
      c.appendChild(link);
    } else if (contact) {
      const ct = document.createElement('span');
      ct.style.cssText = 'font-size:12px;font-weight:700;color:#003345;';
      ct.textContent = contact;
      c.appendChild(ct);
    }

    if (noteText) {
      const nt = document.createElement('span');
      nt.style.cssText = 'font-size:11px;color:#6b8fa3;font-style:italic;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;max-width:80px;';
      nt.textContent = '· ' + noteText;
      c.appendChild(nt);
    }
  }
  return c;
}

// ── Render chips with collapse at 20 ─────────────────────────
function renderChips(containerEl, entries, color) {
  while (containerEl.firstChild) containerEl.removeChild(containerEl.firstChild);
  const MAX = 20;
  entries.slice(0, MAX).forEach(e => containerEl.appendChild(chip(e, color)));
  if (entries.length > MAX) {
    const extra = entries.slice(MAX);
    const more = document.createElement('div');
    more.style.cssText = 'display:inline-flex;align-items:center;padding:4px 12px;border-radius:9999px;background:rgba(0,51,69,0.06);border:1px dashed rgba(0,51,69,0.15);font-size:12px;font-weight:700;color:#6b8fa3;cursor:pointer;user-select:none;';
    more.textContent = '+' + extra.length + ' more';
    more.addEventListener('click', () => {
      more.remove();
      extra.forEach(e => containerEl.appendChild(chip(e, color)));
    });
    containerEl.appendChild(more);
  }
}

// ── Custom events ─────────────────────────────────────────────
function renderAllCustom() {
  ['apr11','apr12','apr13','apr14'].forEach(day => {
    const el = document.getElementById('custom-events-' + day);
    if (!el) return;
    while (el.firstChild) el.removeChild(el.firstChild);
    Object.values(customByDay[day] || {}).forEach(ev => el.appendChild(buildCustomCard(ev, day)));
  });
}

const CAT_META = {
  'pre-drinks': { label: 'Pre-drinks',  icon: 'local_bar'    },
  'afterparty': { label: 'Afterparty',  icon: 'nightlife'    },
  'meetup':     { label: 'Meetup',      icon: 'diversity_3'  },
  'other':      { label: 'Community',   icon: 'celebration'  },
};

function buildCustomCard(ev, day) {
  const cat = ev.entries[0]?.category || 'other';
  const meta = CAT_META[cat] || CAT_META['other'];

  const wrap = document.createElement('div');
  wrap.className = 'custom-card';
  wrap.id = 'card-' + ev.id;
  wrap.dataset.filterCat = cat;

  // Pink top bar
  const bar = document.createElement('div');
  bar.style.cssText = 'height:4px;background:linear-gradient(90deg,#b4005d,#e91e8c);';
  wrap.appendChild(bar);

  const body = document.createElement('div');
  body.style.cssText = 'padding:20px;background:white;';

  // Header
  const hdr = document.createElement('div');
  hdr.style.cssText = 'display:flex;align-items:flex-start;gap:14px;';

  const iconBox = document.createElement('div');
  iconBox.style.cssText = 'width:48px;height:48px;border-radius:14px;flex-shrink:0;display:flex;align-items:center;justify-content:center;background:rgba(180,0,93,0.1);';
  const ico = document.createElement('span');
  ico.className = 'material-symbols-outlined';
  ico.style.cssText = 'color:#b4005d;font-size:24px;font-variation-settings:"FILL" 1;';
  ico.textContent = meta.icon;
  iconBox.appendChild(ico);

  const info = document.createElement('div');
  info.style.cssText = 'flex:1;min-width:0;';

  const typeBadge = document.createElement('span');
  typeBadge.style.cssText = 'display:inline-block;font-size:9px;font-weight:800;text-transform:uppercase;letter-spacing:0.1em;padding:2px 8px;border-radius:9999px;background:rgba(180,0,93,0.1);color:#b4005d;margin-bottom:4px;';
  typeBadge.textContent = meta.label;

  const title = document.createElement('h3');
  title.className = 'font-headline font-extrabold';
  title.style.cssText = 'font-size:1.2rem;color:#003345;line-height:1.2;';
  title.textContent = ev.name;

  const by = document.createElement('p');
  by.style.cssText = 'font-size:12px;font-weight:600;color:#b4005d;margin-top:2px;';
  by.textContent = 'Hosted by ' + (ev.entries[0]?.name || 'someone') + ' · Contact to join';

  info.appendChild(typeBadge);
  info.appendChild(title);
  info.appendChild(by);

  const countBadge = document.createElement('div');
  countBadge.id = 'count-' + ev.id;
  countBadge.style.cssText = 'flex-shrink:0;font-size:12px;font-weight:700;padding:6px 12px;border-radius:10px;background:rgba(180,0,93,0.1);color:#b4005d;white-space:nowrap;';
  countBadge.textContent = ev.entries.length + ' going';

  hdr.appendChild(iconBox);
  hdr.appendChild(info);
  hdr.appendChild(countBadge);
  body.appendChild(hdr);

  // People
  const people = document.createElement('div');
  people.id = 'people-' + ev.id;
  people.style.cssText = 'display:flex;flex-wrap:wrap;gap:8px;margin-top:16px;';
  renderChips(people, ev.entries, '#b4005d');
  body.appendChild(people);

  // Divider + Contact Host button
  const divider = document.createElement('div');
  divider.style.cssText = 'margin-top:16px;padding-top:16px;border-top:1px solid rgba(192,232,255,0.4);display:flex;align-items:center;gap:12px;flex-wrap:wrap;';

  // Parse contact from host entry note field: "contact · optional note"
  const rawNote = ev.entries[0]?.note || '';
  const contactRaw = rawNote.split(' · ')[0].trim();

  let contactHref = null;
  if (contactRaw.startsWith('@')) {
    contactHref = 'https://instagram.com/' + contactRaw.slice(1);
  } else if (/^\+?[\d\s\-()]{7,}$/.test(contactRaw)) {
    contactHref = 'https://wa.me/' + contactRaw.replace(/\D/g, '');
  }

  if (contactHref) {
    const contactBtn = document.createElement('a');
    contactBtn.href = contactHref;
    contactBtn.target = '_blank';
    contactBtn.rel = 'noopener noreferrer';
    contactBtn.style.cssText = 'display:inline-flex;align-items:center;gap:8px;padding:10px 20px;border-radius:10px;font-size:14px;font-weight:700;color:white;background:linear-gradient(135deg,#b4005d,#e91e8c);box-shadow:0 4px 16px rgba(180,0,93,0.3);text-decoration:none;transition:transform 0.15s,opacity 0.15s;';
    contactBtn.addEventListener('mouseover', () => contactBtn.style.opacity = '0.88');
    contactBtn.addEventListener('mouseout', () => contactBtn.style.opacity = '1');
    const cIco = document.createElement('span');
    cIco.className = 'material-symbols-outlined';
    cIco.style.cssText = 'font-size:18px;font-variation-settings:"FILL" 1;';
    cIco.textContent = contactRaw.startsWith('@') ? 'photo_camera' : 'chat';
    contactBtn.appendChild(cIco);
    contactBtn.appendChild(document.createTextNode('Contact Host'));
    divider.appendChild(contactBtn);
  }

  // Show contact handle as hint
  if (contactRaw) {
    const hint = document.createElement('span');
    hint.style.cssText = 'font-size:12px;color:#6b8fa3;font-weight:600;';
    hint.textContent = contactRaw;
    divider.appendChild(hint);
  }

  body.appendChild(divider);
  wrap.appendChild(body);
  return wrap;
}


// ── Filter events ─────────────────────────────────────────────
window.filterEvents = function(cat) {
  document.querySelectorAll('.filter-btn').forEach(btn => {
    if (btn.getAttribute('data-filter') === cat) {
      btn.classList.add('active-filter'); btn.style.background = ''; btn.style.color = '';
    } else {
      btn.classList.remove('active-filter'); btn.style.background = 'rgba(0,0,0,0.04)'; btn.style.color = '#003345';
    }
  });
  let visible = 0;
  document.querySelectorAll('.party-card, .custom-card').forEach(card => {
    const cardCat = card.getAttribute('data-filter-cat') || '';
    const show = cat === 'all' || cardCat === cat;
    card.style.display = show ? '' : 'none';
    if (show) visible++;
  });
  const emptyEl = document.getElementById('empty-state');
  if (emptyEl) emptyEl.classList.toggle('hidden', visible > 0);
};

// ── Tab switch ────────────────────────────────────────────────
window.switchDay = function(id) {
  document.querySelectorAll('.day-panel').forEach(el => el.style.display = 'none');
  document.querySelectorAll('.day-tab').forEach(b => b.classList.remove('active-day'));
  const p = document.getElementById('day-' + id);
  if (p) p.style.display = '';
  const t = document.querySelector('[data-day="' + id + '"]');
  if (t) t.classList.add('active-day');
  // Reset empty state visibility after panel switch
  const emptyEl = document.getElementById('empty-state');
  if (emptyEl) emptyEl.classList.add('hidden');
  filterEvents('all');
};

// ── Official form toggles ─────────────────────────────────────
window.toggleForm = function(pid) {
  const form = document.getElementById('form-' + pid);
  const btn  = document.getElementById('btn-' + pid);
  const suc  = document.getElementById('success-' + pid);
  if (!form) return;
  const hidden = form.classList.contains('hidden');
  document.querySelectorAll('.signup-form').forEach(f => f.classList.add('hidden'));
  document.querySelectorAll('.im-going-btn span').forEach(s => s.textContent = 'add_circle');
  if (hidden) {
    form.classList.remove('hidden');
    if (btn) btn.querySelector('span').textContent = 'remove_circle';
    if (suc) suc.classList.add('hidden');
    setTimeout(() => { const ni = document.getElementById('name-' + pid); if (ni) ni.focus(); }, 50);
  }
};

window.cancelForm = function(pid) {
  const form = document.getElementById('form-' + pid);
  const btn  = document.getElementById('btn-' + pid);
  if (form) form.classList.add('hidden');
  if (btn) { const s = btn.querySelector('span'); if (s) s.textContent = 'add_circle'; }
};

window.submitEntry = async function(pid, dayId) {
  const nameI    = document.getElementById('name-' + pid);
  const contactI = document.getElementById('contact-' + pid);
  const noteI    = document.getElementById('note-' + pid);
  const errEl    = document.getElementById('error-' + pid);
  const subBtn   = document.getElementById('submit-' + pid);
  const form     = document.getElementById('form-' + pid);
  const sucEl    = document.getElementById('success-' + pid);

  const name    = (nameI.value || '').trim();
  const contact = (contactI.value || '').trim();
  const note    = (noteI.value || '').trim();

  errEl.classList.add('hidden'); errEl.textContent = '';

  if (!name) { errEl.textContent = 'Please enter your name.'; errEl.classList.remove('hidden'); nameI.focus(); return; }

  const valErr = validateText(name, contact, note);
  if (valErr) { errEl.textContent = valErr; errEl.classList.remove('hidden'); return; }

  if (sessionSubmits >= MAX_SUBMITS) {
    errEl.textContent = 'You\'ve reached the maximum of 3 sign-ups per session.';
    errEl.classList.remove('hidden');
    return;
  }

  subBtn.disabled = true; subBtn.style.opacity = '0.6';
  try {
    const res = await fetch(API, {
      method: 'POST',
      headers: { ...HDRS, 'Prefer': 'return=representation' },
      body: JSON.stringify({ name, party: pid, day: dayId, note: (contact ? contact + (note ? ' · ' + note : '') : note) || null, is_custom: false }),
    });
    if (!res.ok) throw new Error();
    const [entry] = await res.json();
    sessionSubmits++;
    if (!byParty[pid]) byParty[pid] = [];
    byParty[pid].push(entry);
    renderParty(pid);
    form.classList.add('hidden');
    sucEl.classList.remove('hidden');
    const ic = document.querySelector('#btn-' + pid + ' span');
    if (ic) ic.textContent = 'check_circle';
    nameI.value = ''; contactI.value = ''; noteI.value = '';
    document.getElementById('name-counter-' + pid).textContent = '0 / 30';
    document.getElementById('note-counter-' + pid).textContent = '0 / 100';
  } catch {
    errEl.textContent = 'Network error. Try again.';
    errEl.classList.remove('hidden');
  } finally {
    subBtn.disabled = false; subBtn.style.opacity = '1';
  }
};

// ── Add event modal ───────────────────────────────────────────
window.openAddEvent = function() {
  document.getElementById('add-event-modal').classList.remove('hidden');
  setTimeout(() => document.getElementById('custom-event-name').focus(), 50);
};
window.closeAddEvent = function() {
  document.getElementById('add-event-modal').classList.add('hidden');
  ['custom-event-name','custom-event-host','custom-event-contact','custom-event-email','custom-event-note'].forEach(id => { const el = document.getElementById(id); if (el) el.value = ''; });
  const catInput = document.getElementById('custom-event-category'); if (catInput) catInput.value = 'pre-drinks';
  const catLabel = document.querySelector('#cat-select-wrap [id$="-select-label"]'); if (catLabel) catLabel.textContent = '🍹 Pre-drinks';
  const dayInput = document.getElementById('custom-event-day'); if (dayInput) dayInput.value = 'apr11';
  const dayLabel = document.querySelector('#day-select-wrap [id$="-select-label"]'); if (dayLabel) dayLabel.textContent = 'April 11 — Friday';
  const gdprEl = document.getElementById('custom-event-gdpr'); if (gdprEl) gdprEl.checked = false;
  if (window.turnstile && meetupTurnstileId !== null) window.turnstile.reset(meetupTurnstileId);
  document.getElementById('custom-event-error').classList.add('hidden');
};
window.submitCustomEvent = async function() {
  const evNameEl   = document.getElementById('custom-event-name');
  const dayEl      = document.getElementById('custom-event-day');
  const catEl      = document.getElementById('custom-event-category');
  const hostEl     = document.getElementById('custom-event-host');
  const contactEl  = document.getElementById('custom-event-contact');
  const emailEl    = document.getElementById('custom-event-email');
  const noteEl     = document.getElementById('custom-event-note');
  const gdprEl     = document.getElementById('custom-event-gdpr');
  const errEl      = document.getElementById('custom-event-error');
  const subBtn     = document.getElementById('custom-event-submit');

  const evName   = (evNameEl.value || '').trim();
  const day      = dayEl.value;
  const category = catEl.value;
  const host     = (hostEl.value || '').trim();
  const contact  = (contactEl.value || '').trim();
  const email    = (emailEl.value || '').trim();
  const note     = (noteEl.value || '').trim();

  errEl.classList.add('hidden');
  if (!evName) { errEl.textContent = 'Please enter an event name.'; errEl.classList.remove('hidden'); evNameEl.focus(); return; }
  if (!host)   { errEl.textContent = 'Please enter your name.'; errEl.classList.remove('hidden'); hostEl.focus(); return; }
  if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) { errEl.textContent = 'Please enter a valid email address.'; errEl.classList.remove('hidden'); emailEl.focus(); return; }
  if (!gdprEl.checked) { errEl.textContent = 'Please accept the consent checkbox to continue.'; errEl.classList.remove('hidden'); return; }

  if (isSpam(evName) || isSpam(note)) { errEl.textContent = '⚠️ No promotions or advertising allowed. Events are for personal meetups only.'; errEl.classList.remove('hidden'); return; }
  const contactErr = validateContact(contact);
  if (contactErr) { errEl.textContent = contactErr; errEl.classList.remove('hidden'); contactEl.focus(); return; }

  if (sessionSubmits >= MAX_SUBMITS) { errEl.textContent = 'You\'ve reached the maximum of 3 sign-ups per session.'; errEl.classList.remove('hidden'); return; }

  const turnstileToken = (window.turnstile && meetupTurnstileId !== null) ? window.turnstile.getResponse(meetupTurnstileId) : '';
  if (!turnstileToken) { errEl.textContent = 'Please complete the security check.'; errEl.classList.remove('hidden'); return; }

  subBtn.disabled = true; subBtn.style.opacity = '0.6';
  try {
    const evId = 'c-' + evName.toLowerCase().replace(/[^a-z0-9]/g,'-').slice(0,25) + '-' + Date.now();
    const combinedNote = contact + (note ? ' · ' + note : '');
    const res = await fetch(API, {
      method: 'POST',
      headers: { ...HDRS, 'Prefer': 'return=representation' },
      body: JSON.stringify({ name: host, party: evId, day, note: combinedNote, event_name: evName, is_custom: true, category, email }),
    });
    if (!res.ok) throw new Error();
    const [entry] = await res.json();

    sessionSubmits++;
    if (!customByDay[day]) customByDay[day] = {};
    entry.category = category;
    customByDay[day][evName] = { id: evId, name: evName, entries: [entry] };

    switchDay(day);
    const container = document.getElementById('custom-events-' + day);
    if (container) container.appendChild(buildCustomCard(customByDay[day][evName], day));
    closeAddEvent();
  } catch {
    errEl.textContent = 'Something went wrong. Try again.';
    errEl.classList.remove('hidden');
  } finally {
    subBtn.disabled = false; subBtn.style.opacity = '1';
  }
};

// ── Custom selects ────────────────────────────────────────────
window.toggleSelect = function(wrapId) {
  const wrap = document.getElementById(wrapId);
  const menu = wrap.querySelector('.custom-select-menu');
  const isHidden = menu.classList.contains('hidden');
  // Close all other open menus
  document.querySelectorAll('.custom-select-menu').forEach(m => m.classList.add('hidden'));
  if (isHidden) menu.classList.remove('hidden');
};

window.selectOption = function(wrapId, inputId, value, label) {
  document.getElementById(inputId).value = value;
  const wrap = document.getElementById(wrapId);
  wrap.querySelector('[id$="-select-label"]').textContent = label;
  wrap.querySelectorAll('.custom-select-option').forEach(o => o.classList.remove('active'));
  event.currentTarget.classList.add('active');
  wrap.querySelector('.custom-select-menu').classList.add('hidden');
};

// Close dropdowns when clicking outside
document.addEventListener('click', (e) => {
  if (!e.target.closest('.custom-select-wrap')) {
    document.querySelectorAll('.custom-select-menu').forEach(m => m.classList.add('hidden'));
  }
});

// ── Counters ──────────────────────────────────────────────────
document.addEventListener('DOMContentLoaded', () => {
  document.querySelectorAll('.name-input').forEach(inp => {
    const pid = inp.id.replace('name-', '');
    inp.addEventListener('input', () => {
      const el = document.getElementById('name-counter-' + pid);
      if (el) { const l = inp.value.length; el.textContent = l + ' / 30'; el.style.color = l > 25 ? '#f59e0b' : '#6b8fa3'; }
    });
    inp.addEventListener('keydown', e => { if (e.key === 'Enter') { const ni = document.getElementById('note-' + pid); if (ni) ni.focus(); } });
  });
  document.querySelectorAll('.note-input').forEach(inp => {
    const pid = inp.id.replace('note-', '');
    inp.addEventListener('input', () => {
      const el = document.getElementById('note-counter-' + pid);
      if (el) { const l = inp.value.length; el.textContent = l + ' / 100'; el.style.color = l > 85 ? '#f59e0b' : '#6b8fa3'; }
    });
    inp.addEventListener('keydown', e => { if (e.key === 'Enter') { const p = PARTIES.find(x => x.id === pid); if (p) submitEntry(pid, p.day); } });
  });

  const evNm = document.getElementById('custom-event-name');
  if (evNm) evNm.addEventListener('input', () => {
    const el = document.getElementById('custom-event-name-counter');
    if (el) el.textContent = evNm.value.length + ' / 60';
  });

  document.getElementById('add-event-modal').addEventListener('click', e => { if (e.target === e.currentTarget) closeAddEvent(); });

  load();
});
</script>

