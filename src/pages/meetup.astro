---
import BaseLayout from '../components/layout/BaseLayout.astro';

const SUPABASE_URL = import.meta.env.PUBLIC_SUPABASE_URL;
const SUPABASE_KEY = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;

const days = [
  { id: 'apr10', label: 'Apr 10', sub: 'Friday' },
  { id: 'apr11', label: 'Apr 11', sub: 'Saturday' },
  { id: 'apr12', label: 'Apr 12', sub: 'Sunday' },
  { id: 'apr13', label: 'Apr 13', sub: 'Monday 🔥' },
  { id: 'apr14', label: 'Apr 14', sub: 'Tuesday' },
];

const parties = [
  { id: 'gcircuit-opening',  day: 'apr10', name: 'GCircuit — Opening Party: Team Alpha', headliner: 'Brian Solis, Mario Beckman', venue: 'UOB Live Hall, Emsphere',   color: '#a855f7', icon: 'nightlife',   type: 'Circuit' },

  { id: 's2o-night-1',      day: 'apr11', name: 'S2O Night 1',                      headliner: 'Alan Walker × Steve Aoki',    venue: 'S2O Land, Ratchada',        color: '#0ea5e9', icon: 'water_drop',  type: 'Festival' },
  { id: 'siam-night-1',     day: 'apr11', name: 'Siam Songkran Night 1',             headliner: 'Afrojack b2b R3HAB',          venue: 'Bravo BKK Arena, RCA',      color: '#006479', icon: 'festival',    type: 'Festival' },
  { id: 'gcircuit-pool-1',  day: 'apr11', name: 'GCircuit — Boy Pool Party: AQUA',  headliner: 'Boren, Kai',                  venue: 'Tribe Sky Beach Club, Emsphere', color: '#a855f7', icon: 'pool',   type: 'Circuit' },
  { id: 'gcircuit-main-1',  day: 'apr11', name: 'GCircuit — Main Party Vol. One: Empire Of The World', headliner: 'MisterMiss, Tomer Maizner', venue: 'UOB Live Hall, Emsphere', color: '#a855f7', icon: 'nightlife', type: 'Circuit' },
  { id: 'silom-apr11',      day: 'apr11', name: 'Silom Soi 2 & 4',                  headliner: 'Free street party',           venue: 'Silom Road',                color: '#f59e0b', icon: 'celebration', type: 'Free' },

  { id: 's2o-night-2',      day: 'apr12', name: 'S2O Night 2',                      headliner: 'Zedd',                        venue: 'S2O Land, Ratchada',        color: '#0ea5e9', icon: 'water_drop',  type: 'Festival' },
  { id: 'siam-night-2',     day: 'apr12', name: 'Siam Songkran Night 2',             headliner: 'Marshmello',                  venue: 'Bravo BKK Arena, RCA',      color: '#006479', icon: 'festival',    type: 'Festival' },
  { id: 'gcircuit-pool-2',  day: 'apr12', name: 'GCircuit — Bear Pool Party: AQUAXXL', headliner: 'Pat+, CallMeKevin',        venue: 'Tribe Sky Beach Club, Emsphere', color: '#a855f7', icon: 'pool',   type: 'Circuit' },
  { id: 'gcircuit-main-2',  day: 'apr12', name: 'GCircuit — Main Party Vol. Two: Adro Mada', headliner: 'Karsten Sollors, Fran Albuquerque', venue: 'UOB Live Hall, Emsphere', color: '#a855f7', icon: 'nightlife', type: 'Circuit' },
  { id: 'silom-apr12',      day: 'apr12', name: 'Silom Soi 2 & 4',                  headliner: 'Free street party',           venue: 'Silom Road',                color: '#f59e0b', icon: 'celebration', type: 'Free' },

  { id: 's2o-night-3',      day: 'apr13', name: 'S2O Night 3',                      headliner: 'Kygo',                        venue: 'S2O Land, Ratchada',        color: '#0ea5e9', icon: 'water_drop',  type: 'Festival' },
  { id: 'siam-night-3',     day: 'apr13', name: 'Siam Songkran Night 3',             headliner: 'Martin Garrix',               venue: 'Bravo BKK Arena, RCA',      color: '#006479', icon: 'festival',    type: 'Festival' },
  { id: 'gcircuit-closing', day: 'apr13', name: 'GCircuit — Closing Party: Kink',   headliner: 'Jair Sandoval, Alex Acosta',  venue: 'UOB Live Hall, Emsphere',   color: '#a855f7', icon: 'nightlife',   type: 'Circuit' },
  { id: 'silom-apr13',      day: 'apr13', name: 'Silom Soi 2 & 4',                  headliner: 'Peak day — FREE',             venue: 'Silom Road',                color: '#f59e0b', icon: 'celebration', type: 'Free' },
  { id: 'khao-san-apr13',   day: 'apr13', name: 'Khao San Road',                    headliner: 'Street water fight — FREE',   venue: 'Khao San Road',             color: '#ef4444', icon: 'water_drop',  type: 'Free' },

  { id: 'siam-night-4',     day: 'apr14', name: 'Siam Songkran Night 4',             headliner: 'John Summit',                 venue: 'Bravo BKK Arena, RCA',      color: '#006479', icon: 'festival',    type: 'Festival' },
  { id: 'silom-apr14',      day: 'apr14', name: 'Silom Soi 2 & 4',                  headliner: 'Free street party',           venue: 'Silom Road',                color: '#f59e0b', icon: 'celebration', type: 'Free' },
];

const partiesJson = JSON.stringify(parties);
---

<BaseLayout
  title="Who's Going? — Find Your Festival Crew | Bangkok Songkran 2026"
  description="Sign up to show which Songkran 2026 parties you're attending. Find others going to the same events and coordinate pre-drinks and after-parties."
  canonical="https://bkksongkran.com/meetup"
>

  <!-- HEADER -->
  <section class="pt-36 pb-14 px-6" style="background:linear-gradient(180deg,rgba(225,243,255,0.9),rgba(238,248,255,0));">
    <div class="max-w-7xl mx-auto">
      <div class="text-xs font-bold tracking-[0.2em] uppercase mb-3" style="color:#006479;">Community</div>
      <h1 class="font-headline font-extrabold tracking-tighter mb-4" style="font-size:clamp(3rem,8vw,6rem);color:#003345;line-height:0.9;">
        WHO'S<br/>
        <span style="background:linear-gradient(135deg,#006479,#40cef3);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;">GOING?</span>
      </h1>
      <p class="text-lg max-w-xl mb-3" style="color:#326177;">Find your crew. Sign up for events, add pre-drinks, after-parties — coordinate everything in one place.</p>
      <p class="text-sm flex items-center gap-1.5" style="color:#6b8fa3;">
        <span class="material-symbols-outlined text-sm" style="font-variation-settings:'FILL' 1;color:#40cef3;">info</span>
        No account needed. Organising a group or large meetup? <a href="/contact?type=whos-going" class="font-bold underline transition-colors hover:text-primary" style="color:#006479;">Contact us</a> — we can feature it.
      </p>
    </div>
  </section>

  <!-- STICKY TABS BAR -->
  <div class="sticky top-20 z-30 px-6" style="border-bottom:1px solid rgba(192,232,255,0.3);">
    <div class="max-w-7xl mx-auto">
      <!-- Row 1: Add event button -->
      <div class="flex justify-end gap-2 pt-2 pb-1">
        <button onclick="openAddEvent()" class="flex items-center gap-1.5 px-4 py-2.5 rounded-xl text-xs font-bold text-white transition-all hover:opacity-90 hover:scale-105" style="background:linear-gradient(135deg,#b4005d,#e91e8c);">
          <span class="material-symbols-outlined text-sm" style="font-variation-settings:'FILL' 1;">add</span>
          Add event
        </button>
      </div>
      <!-- Row 2: Day tabs -->
      <div class="flex gap-2 overflow-x-auto no-scrollbar pb-1">
        {days.map((day, i) => (
          <button
            data-day={day.id}
            onclick={`switchDay('${day.id}')`}
            class={`day-tab flex-shrink-0 flex flex-col items-center px-5 py-3 rounded-2xl border-2 transition-all font-bold min-w-[80px] ${i === 0 ? 'active-day' : ''}`}
          >
            <div class="day-tab-label text-sm font-black">{day.label}</div>
            <div class="day-tab-sub text-[11px] font-semibold mt-0.5">{day.sub}</div>
          </button>
        ))}
      </div>
      <!-- Row 3: Filters -->
      <div id="filter-bar" class="flex gap-2 overflow-x-auto no-scrollbar py-2">
        <button data-filter="all" onclick="filterEvents('all')" class="filter-btn active-filter flex-shrink-0 px-3 py-1.5 rounded-full text-xs font-bold transition-all">All</button>
        <button data-filter="festival" onclick="filterEvents('festival')" class="filter-btn flex-shrink-0 px-3 py-1.5 rounded-full text-xs font-bold transition-all" style="background:rgba(0,0,0,0.04);color:#003345;">Festival</button>
        <button data-filter="circuit" onclick="filterEvents('circuit')" class="filter-btn flex-shrink-0 px-3 py-1.5 rounded-full text-xs font-bold transition-all" style="background:rgba(0,0,0,0.04);color:#003345;">Circuit</button>
        <button data-filter="free" onclick="filterEvents('free')" class="filter-btn flex-shrink-0 px-3 py-1.5 rounded-full text-xs font-bold transition-all" style="background:rgba(0,0,0,0.04);color:#003345;">Free</button>
        <button data-filter="pre-drinks" onclick="filterEvents('pre-drinks')" class="filter-btn flex-shrink-0 px-3 py-1.5 rounded-full text-xs font-bold transition-all" style="background:rgba(0,0,0,0.04);color:#003345;">Pre-drinks</button>
        <button data-filter="afterparty" onclick="filterEvents('afterparty')" class="filter-btn flex-shrink-0 px-3 py-1.5 rounded-full text-xs font-bold transition-all" style="background:rgba(0,0,0,0.04);color:#003345;">Afterparty</button>
        <button data-filter="meetup" onclick="filterEvents('meetup')" class="filter-btn flex-shrink-0 px-3 py-1.5 rounded-full text-xs font-bold transition-all" style="background:rgba(0,0,0,0.04);color:#003345;">Meetup</button>
        <button data-filter="other" onclick="filterEvents('other')" class="filter-btn flex-shrink-0 px-3 py-1.5 rounded-full text-xs font-bold transition-all" style="background:rgba(0,0,0,0.04);color:#003345;">Other</button>
      </div>
    </div>
  </div>

  <!-- ADD EVENT MODAL -->
  <div id="add-event-modal" class="hidden fixed inset-0 flex items-end sm:items-center justify-center" style="z-index:10000;background:rgba(0,20,40,0.6);backdrop-filter:blur(6px);">
    <div class="w-full max-w-lg rounded-t-3xl sm:rounded-3xl p-6 sm:p-8 overflow-y-auto" style="background:white;box-shadow:0 32px 80px rgba(0,0,0,0.3);max-height:90vh;">
      <div class="flex items-center justify-between mb-1">
        <h2 class="font-headline font-extrabold text-2xl" style="color:#003345;">Add Your Event</h2>
        <button onclick="closeAddEvent()" class="w-9 h-9 rounded-full flex items-center justify-center transition-colors hover:bg-gray-100">
          <span class="material-symbols-outlined" style="color:#6b8fa3;">close</span>
        </button>
      </div>
      <p class="text-sm mb-6" style="color:#6b8fa3;">Pre-drinks, after-party, hotel rooftop, beach bar — anything.</p>

      <div class="space-y-4">
        <div>
          <label class="field-label">Event name *</label>
          <input id="custom-event-name" type="text" maxlength="60" placeholder='e.g. "Pre-drinks at Octave Rooftop"' class="field-input" />
          <div class="flex justify-end mt-1"><span id="custom-event-name-counter" class="text-[10px]" style="color:#6b8fa3;">0 / 60</span></div>
        </div>
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="field-label">Day *</label>
            <div class="custom-select-wrap" id="day-select-wrap">
              <button type="button" class="custom-select-btn field-input flex items-center justify-between gap-2" onclick="toggleSelect('day-select-wrap')">
                <span id="day-select-label">April 10 — Friday</span>
                <span class="material-symbols-outlined text-base flex-shrink-0" style="color:#6b8fa3;">expand_more</span>
              </button>
              <input type="hidden" id="custom-event-day" value="apr10" />
              <div class="custom-select-menu hidden">
                <button type="button" class="custom-select-option active" onclick="selectOption('day-select-wrap','custom-event-day','apr10','April 10 — Friday')">April 10 — Friday</button>
                <button type="button" class="custom-select-option" onclick="selectOption('day-select-wrap','custom-event-day','apr11','April 11 — Saturday')">April 11 — Saturday</button>
                <button type="button" class="custom-select-option" onclick="selectOption('day-select-wrap','custom-event-day','apr12','April 12 — Sunday')">April 12 — Sunday</button>
                <button type="button" class="custom-select-option" onclick="selectOption('day-select-wrap','custom-event-day','apr13','April 13 — Monday 🔥')">April 13 — Monday 🔥</button>
                <button type="button" class="custom-select-option" onclick="selectOption('day-select-wrap','custom-event-day','apr14','April 14 — Tuesday')">April 14 — Tuesday</button>
              </div>
            </div>
          </div>
          <div>
            <label class="field-label">Category *</label>
            <div class="custom-select-wrap" id="cat-select-wrap">
              <button type="button" class="custom-select-btn field-input flex items-center justify-between gap-2" onclick="toggleSelect('cat-select-wrap')">
                <span id="cat-select-label">🍹 Pre-drinks</span>
                <span class="material-symbols-outlined text-base flex-shrink-0" style="color:#6b8fa3;">expand_more</span>
              </button>
              <input type="hidden" id="custom-event-category" value="pre-drinks" />
              <div class="custom-select-menu hidden">
                <button type="button" class="custom-select-option active" onclick="selectOption('cat-select-wrap','custom-event-category','pre-drinks','🍹 Pre-drinks')">🍹 Pre-drinks</button>
                <button type="button" class="custom-select-option" onclick="selectOption('cat-select-wrap','custom-event-category','afterparty','🎉 Afterparty')">🎉 Afterparty</button>
                <button type="button" class="custom-select-option" onclick="selectOption('cat-select-wrap','custom-event-category','meetup','👥 Meetup')">👥 Meetup</button>
                <button type="button" class="custom-select-option" onclick="selectOption('cat-select-wrap','custom-event-category','other','✨ Other')">✨ Other</button>
              </div>
            </div>
          </div>
        </div>
        <div>
          <label class="field-label">Your name *</label>
          <input id="custom-event-host" type="text" maxlength="30" placeholder="Marco, Alex..." class="field-input" />
        </div>
        <div>
          <label class="field-label">Contact *</label>
          <div class="grid grid-cols-3 gap-2 mb-2">
            <label>
              <input type="radio" name="ce_contact_type" value="ig" class="peer hidden" checked />
              <div class="peer-checked:border-pink-600 peer-checked:bg-pink-50 border border-surface-container-high rounded-lg p-2 text-center cursor-pointer transition-all text-xs font-bold" style="color:#003345;">Instagram</div>
            </label>
            <label>
              <input type="radio" name="ce_contact_type" value="wa" class="peer hidden" />
              <div class="peer-checked:border-pink-600 peer-checked:bg-pink-50 border border-surface-container-high rounded-lg p-2 text-center cursor-pointer transition-all text-xs font-bold" style="color:#003345;">WhatsApp</div>
            </label>
            <label>
              <input type="radio" name="ce_contact_type" value="tg" class="peer hidden" />
              <div class="peer-checked:border-pink-600 peer-checked:bg-pink-50 border border-surface-container-high rounded-lg p-2 text-center cursor-pointer transition-all text-xs font-bold" style="color:#003345;">Telegram</div>
            </label>
          </div>
          <input id="custom-event-contact" type="text" maxlength="50" placeholder="@yourhandle or +66..." class="field-input" />
          <p class="text-[10px] mt-1" style="color:#6b8fa3;">Shown publicly so people can join</p>
        </div>
        <div>
          <label class="field-label">Your email *</label>
          <input id="custom-event-email" type="email" maxlength="100" placeholder="you@email.com" class="field-input" />
          <p class="text-[10px] mt-1" style="color:#6b8fa3;">Private — only used if there's an issue</p>
        </div>
        <div>
          <label class="field-label">Details <span class="font-normal normal-case" style="color:#6b8fa3;">(optional)</span></label>
          <textarea id="custom-event-note" maxlength="200" rows="2" placeholder="8pm, Sukhumvit Soi 11, meet near entrance" class="field-input resize-none"></textarea>
        </div>
        <div class="flex items-start gap-2 px-3 py-2.5 rounded-xl text-xs" style="background:#FFF8E0;border:1px solid rgba(255,159,10,0.2);color:#92400E;">
          <span class="material-symbols-outlined text-sm flex-shrink-0 mt-0.5" style="color:#FF9F0A;font-variation-settings:'FILL' 1;">info</span>
          No ticket selling, promotions, or advertising. Events are for personal meetups only.
        </div>
        <label class="flex items-start gap-3 cursor-pointer">
          <input id="custom-event-gdpr" type="checkbox" class="mt-0.5 flex-shrink-0 w-4 h-4 rounded accent-pink-600" />
          <span class="text-xs" style="color:#6b8fa3;">I agree that my nickname and contact handle will be shown publicly on this page so others can join my event. My email is stored privately and will not be shared. I confirm this is a personal meetup, not a promotion.</span>
        </label>
        <div id="turnstile-meetup"></div>
        <p id="custom-event-error" class="text-xs font-semibold hidden" style="color:#ef4444;"></p>
        <div class="flex items-center gap-3 pt-1">
          <button id="custom-event-submit" onclick="submitCustomEvent()" class="flex items-center gap-2 px-6 py-3 rounded-xl text-sm font-bold text-white transition-all hover:scale-105" style="background:linear-gradient(135deg,#b4005d,#e91e8c);">
            <span class="material-symbols-outlined text-base" style="font-variation-settings:'FILL' 1;">celebration</span>
            Create event
          </button>
          <button onclick="closeAddEvent()" class="text-sm font-semibold transition-colors hover:underline" style="color:#6b8fa3;">Cancel</button>
        </div>
      </div>
    </div>
  </div>

  <!-- PARTY CARDS -->
  <section class="px-6 pt-8 pb-28">
    <div class="max-w-3xl mx-auto space-y-4">

      {days.map(day => (
        <div id={`day-${day.id}`} class="day-panel space-y-4" style={day.id !== 'apr10' ? 'display:none;' : ''}>
          <div class="flex items-baseline gap-3 pt-2 pb-1">
            <h2 class="font-headline font-black text-3xl tracking-tight" style="color:#003345;">{day.label}</h2>
            <span class="text-sm font-bold" style="color:#6b8fa3;">{day.sub}</span>
          </div>
          {parties.filter(p => p.day === day.id).map(party => (
            <div class="party-card" data-party-id={party.id} data-filter-cat={party.type.toLowerCase()} style={`--party-color:${party.color};`}>
              <!-- Top accent bar -->
              <div class="h-1 rounded-t-2xl" style={`background:${party.color};`}></div>

              <div class="p-5">
                <!-- Card header row -->
                <div class="flex items-start gap-4">
                  <!-- Icon -->
                  <div class="w-12 h-12 rounded-2xl flex-shrink-0 flex items-center justify-center" style={`background:${party.color}18;`}>
                    <span class="material-symbols-outlined text-2xl" style={`color:${party.color};font-variation-settings:'FILL' 1;`}>{party.icon}</span>
                  </div>
                  <!-- Info -->
                  <div class="flex-1 min-w-0">
                    <div class="flex items-start justify-between gap-2 flex-wrap">
                      <div>
                        <span class="inline-block text-[9px] font-black uppercase tracking-widest px-2 py-0.5 rounded-full mb-1" style={`background:${party.color}15;color:${party.color};`}>{party.type}</span>
                        <h3 class="font-headline font-extrabold text-xl leading-tight" style="color:#003345;">{party.name}</h3>
                        <p class="text-sm font-bold mt-0.5" style={`color:${party.color};`}>{party.headliner}</p>
                        <p class="text-xs mt-1 flex items-center gap-1" style="color:#6b8fa3;">
                          <span class="material-symbols-outlined text-xs">location_on</span>
                          {party.venue}
                        </p>
                      </div>
                      <!-- Count -->
                      <div id={`count-${party.id}`} class="flex-shrink-0 text-xs font-bold px-3 py-1.5 rounded-xl" style={`background:${party.color}12;color:${party.color};`}>
                        — going
                      </div>
                    </div>
                  </div>
                </div>

                <!-- People chips -->
                <div id={`people-${party.id}`} class="mt-4 empty:hidden"></div>

                <!-- Divider -->
                <div class="mt-4 pt-4" style="border-top:1px solid rgba(192,232,255,0.4);">
                  <button
                    id={`btn-${party.id}`}
                    onclick={`toggleForm('${party.id}')`}
                    class="im-going-btn inline-flex items-center gap-2 px-5 py-2.5 rounded-xl text-sm font-bold text-white transition-all hover:scale-105"
                    style={`background:${party.color};box-shadow:0 4px 20px ${party.color}35;`}
                  >
                    <span class="material-symbols-outlined text-base" style="font-variation-settings:'FILL' 1;">add_circle</span>
                    I'm going
                  </button>
                </div>

                <!-- Inline form -->
                <div id={`form-${party.id}`} class="signup-form hidden mt-4 rounded-xl p-4" style="background:rgba(248,252,255,0.9);border:1px solid rgba(192,232,255,0.5);">
                  <p class="text-sm font-bold mb-1" style="color:#003345;">Add yourself to the list</p>
                  <p class="text-xs mb-3" style="color:#6b8fa3;">No promotions or ticket selling — just people finding their crew.</p>
                  <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 mb-3">
                    <div>
                      <label class="field-label">Name / Nickname *</label>
                      <input type="text" maxlength="30" placeholder="Marco, Alex..." id={`name-${party.id}`} class="name-input field-input" />
                      <div class="flex justify-end mt-1"><span id={`name-counter-${party.id}`} class="text-[10px]" style="color:#6b8fa3;">0 / 30</span></div>
                    </div>
                    <div>
                      <label class="field-label">Instagram or WhatsApp *</label>
                      <input type="text" maxlength="50" placeholder="@yourhandle or +66..." id={`contact-${party.id}`} class="contact-input field-input" />
                      <p class="text-[10px] mt-1" style="color:#6b8fa3;">So your crew can find you</p>
                    </div>
                  </div>
                  <div class="mb-3">
                    <label class="field-label">Note <span class="font-normal normal-case" style="color:#6b8fa3;">(optional)</span></label>
                    <input type="text" maxlength="100" placeholder='"arriving at 10pm, meeting near entrance"' id={`note-${party.id}`} class="note-input field-input" />
                    <div class="flex justify-end mt-1"><span id={`note-counter-${party.id}`} class="text-[10px]" style="color:#6b8fa3;">0 / 100</span></div>
                  </div>
                  <p id={`error-${party.id}`} class="form-error text-xs font-semibold hidden mb-2" style="color:#ef4444;"></p>
                  <div class="flex items-center gap-3">
                    <button id={`submit-${party.id}`} onclick={`submitEntry('${party.id}','${day.id}')`} class="inline-flex items-center gap-2 px-5 py-2.5 rounded-xl text-sm font-bold text-white transition-all hover:scale-105" style={`background:${party.color};`}>
                      <span class="material-symbols-outlined text-base" style="font-variation-settings:'FILL' 1;">check_circle</span>
                      Count me in!
                    </button>
                    <button onclick={`cancelForm('${party.id}')`} class="text-sm font-semibold hover:underline" style="color:#6b8fa3;">Cancel</button>
                  </div>
                </div>

                <!-- Success -->
                <div id={`success-${party.id}`} class="success-msg hidden mt-3 flex items-center gap-2 text-sm font-bold px-4 py-3 rounded-xl" style="background:#dcfce7;color:#16a34a;border:1px solid #bbf7d0;">
                  <span class="material-symbols-outlined text-base" style="font-variation-settings:'FILL' 1;">check_circle</span>
                  You're on the list! See you there 🎉
                </div>
              </div>
            </div>
          ))}

          <!-- Custom events for this day -->
          <div id={`custom-events-${day.id}`} class="space-y-4"></div>
        </div>
      ))}

      <!-- Empty state -->
      <div id="empty-state" class="hidden text-center py-16 px-6">
        <span class="material-symbols-outlined text-5xl mb-4 block" style="color:#40cef3;font-variation-settings:'FILL' 1;">group_add</span>
        <p class="font-headline font-extrabold text-2xl mb-2" style="color:#003345;">Nothing here yet</p>
        <p class="text-sm mb-6 max-w-xs mx-auto" style="color:#6b8fa3;">Be the first to add a pre-drinks, afterparty, or meetup for this day.</p>
        <button onclick="openAddEvent()" class="inline-flex items-center gap-2 px-6 py-3 rounded-xl text-sm font-bold text-white transition-all hover:scale-105" style="background:linear-gradient(135deg,#b4005d,#e91e8c);box-shadow:0 4px 20px rgba(180,0,93,0.3);">
          <span class="material-symbols-outlined text-base" style="font-variation-settings:'FILL' 1;">add_circle</span>
          Create first event
        </button>
      </div>

      <!-- Loading -->
      <div id="loading-state" class="flex items-center justify-center py-16 gap-3" style="color:#6b8fa3;">
        <span class="material-symbols-outlined animate-spin text-2xl" style="color:#40cef3;">progress_activity</span>
        <span class="text-sm font-semibold">Loading sign-ups...</span>
      </div>

      <!-- Error -->
      <div id="error-state" class="hidden text-center py-16">
        <span class="material-symbols-outlined text-4xl mb-3 block" style="color:#f59e0b;">cloud_off</span>
        <p class="text-sm font-semibold" style="color:#6b8fa3;">Couldn't load sign-ups. Please refresh.</p>
      </div>

    </div>
  </section>

</BaseLayout>

