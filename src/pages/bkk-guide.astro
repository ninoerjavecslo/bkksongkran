---
import BaseLayout from '../components/layout/BaseLayout.astro';
import { guidePlaces, guideCategories } from '../data/bkkGuide';

const placesJson  = JSON.stringify(guidePlaces);
const catsJson    = JSON.stringify(guideCategories);
const mapboxToken = import.meta.env.PUBLIC_MAPBOX_TOKEN;
---

<BaseLayout
  title="Bangkok Gay Guide 2026 — Bars, Clubs, Saunas, Hotels & More"
  description="The complete Bangkok gay travel guide. Best gay bars, clubs, saunas, massage, hotels, food and sightseeing around Silom and beyond."
  canonical="https://bkksongkran.com/bkk-guide"
>

  <!-- HEADER -->
  <section class="pt-36 pb-10 px-6" style="background:linear-gradient(180deg,rgba(225,243,255,0.8),rgba(238,248,255,0));">
    <div class="max-w-7xl mx-auto">
      <div class="text-xs font-bold tracking-[0.2em] uppercase mb-3" style="color:#b4005d;">Bangkok Guide</div>
      <h1 class="font-headline font-extrabold tracking-tighter mb-4" style="font-size:clamp(2.5rem,7vw,5rem);color:#003345;line-height:0.9;">
        BKK<br/>
        <span style="background:linear-gradient(135deg,#b4005d,#ff8eb2);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;">GUIDE</span>
      </h1>
      <p class="text-lg max-w-2xl" style="color:#326177;">
        Community-curated Bangkok guide. Gay bars, clubs, saunas, sightseeing, food & more.
        <span class="font-semibold" style="color:#b4005d;">60,000+ views</span> on the original map.
      </p>
      <div class="flex flex-wrap gap-6 mt-6">
        {guideCategories.map(c => (
          <div class="flex items-center gap-2">
            <span class="material-symbols-outlined text-base" style={`color:${c.color};font-variation-settings:'FILL' 1;`}>{c.icon}</span>
            <span class="text-xs font-semibold" style="color:#326177;">
              {guidePlaces.filter(p => p.category === c.id).length} {c.label}
            </span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FILTER TABS -->
  <section class="px-6 pb-4 sticky top-20 z-30" style="background:transparent;">
    <div class="max-w-7xl mx-auto">
      <div class="flex gap-2 overflow-x-auto no-scrollbar pb-2 pt-2">
        <button data-cat="all" onclick="filterCat('all')"
          class="cat-btn active-cat flex-shrink-0 flex items-center gap-1.5 px-4 py-2 rounded-full text-xs font-bold transition-all">
          <span class="material-symbols-outlined text-sm" style="font-variation-settings:'FILL' 1;">apps</span>All
        </button>
        {guideCategories.map(c => (
          <button data-cat={c.id} onclick={`filterCat('${c.id}')`}
            class="cat-btn flex-shrink-0 flex items-center gap-1.5 px-4 py-2 rounded-full text-xs font-bold transition-all"
            style="background:rgba(0,0,0,0.04);color:#003345;">
            <span class="material-symbols-outlined text-sm" style="font-variation-settings:'FILL' 1;">{c.icon}</span>
            {c.label}
          </button>
        ))}
      </div>
    </div>
  </section>

  <!-- MAP -->
  <section class="px-6 pb-6">
    <div class="max-w-7xl mx-auto">
      <div id="guide-map" class="rounded-2xl overflow-hidden" style="height:460px;border:1px solid rgba(192,232,255,0.5);box-shadow:0 4px 32px rgba(0,100,121,0.1);"></div>
    </div>
  </section>

  <!-- PLACE CARDS -->
  <section class="px-6 pb-24">
    <div class="max-w-7xl mx-auto">
      <div id="places-count" class="text-xs font-semibold mb-4" style="color:#6b8fa3;">
        Showing all {guidePlaces.length} places
      </div>
      <div id="places-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4">
        {guidePlaces.map(place => {
          const cat = guideCategories.find(c => c.id === place.category);
          return (
            <button
              data-cat={place.category}
              data-id={place.id}
              onclick={`focusPlace(${place.lat}, ${place.lng}, '${place.id}')`}
              class="place-card text-left rounded-2xl p-4 transition-all hover:shadow-md hover:-translate-y-0.5 cursor-pointer w-full"
              style="background:white;border:1px solid rgba(192,232,255,0.5);"
            >
              <div class="flex items-start gap-3">
                <div class="w-9 h-9 rounded-xl flex items-center justify-center flex-shrink-0" style={`background:${cat?.color}15;`}>
                  <span class="material-symbols-outlined text-base" style={`color:${cat?.color};font-variation-settings:'FILL' 1;`}>{cat?.icon}</span>
                </div>
                <div class="min-w-0">
                  <h3 class="font-headline font-bold text-sm leading-tight" style="color:#003345;">{place.name}</h3>
                  <p class="text-[10px] mt-0.5 font-semibold" style={`color:${cat?.color};`}>{cat?.label} · {place.area}</p>
                </div>
              </div>
              {place.tip && (
                <p class="text-[11px] mt-2.5 leading-relaxed line-clamp-2" style="color:#6b8fa3;">{place.tip}</p>
              )}
            </button>
          );
        })}
      </div>
    </div>
  </section>

</BaseLayout>

<link href="https://api.mapbox.com/mapbox-gl-js/v3.3.0/mapbox-gl.css" rel="stylesheet" />

<style>
  .cat-btn { border: 1px solid transparent; }
  .active-cat { background: #003345 !important; color: white !important; border-color: #003345 !important; }
  .place-card.hidden { display: none; }
  .mapboxgl-popup-content { border-radius: 12px !important; padding: 12px 14px !important; box-shadow: 0 4px 24px rgba(0,100,121,0.15) !important; font-family: 'Be Vietnam Pro', sans-serif; min-width: 180px; }
  .mapboxgl-popup-close-button { font-size: 16px; color: #6b8fa3; }
</style>

<script define:vars={{ placesJson, catsJson, mapboxToken }}>
const places = JSON.parse(placesJson);
const cats   = JSON.parse(catsJson);
const catMap = Object.fromEntries(cats.map(c => [c.id, c]));

const CAT_MATERIAL = {
  sightseeing: 'photo_camera', shopping: 'shopping_bag', 'gay-bars': 'local_bar',
  'gay-clubs': 'nightlife', hotels: 'hotel', food: 'restaurant',
  massage: 'self_improvement', shows: 'theater_comedy', saunas: 'hot_tub', useful: 'storefront',
};

const SVG_NS = 'http://www.w3.org/2000/svg';
let map, popupInstance;
let markerObjs = {};

function makeMarkerEl(cat) {
  const c = catMap[cat];
  const color = c ? c.color : '#006479';
  const icon  = CAT_MATERIAL[cat] || 'place';

  // Use absolute positioning — never relative — so Mapbox transform doesn't double-offset
  const wrap = document.createElement('div');
  wrap.style.cssText = 'width:32px;height:38px;cursor:pointer;pointer-events:all;position:absolute;';

  const svg = document.createElementNS(SVG_NS, 'svg');
  svg.setAttribute('viewBox', '0 0 32 38');
  svg.setAttribute('width', '32');
  svg.setAttribute('height', '38');
  svg.style.cssText = 'position:absolute;top:0;left:0;';

  const path = document.createElementNS(SVG_NS, 'path');
  path.setAttribute('d', 'M16 0C7.163 0 0 7.163 0 16c0 12 16 22 16 22s16-10 16-22C32 7.163 24.837 0 16 0z');
  path.setAttribute('fill', color);
  path.setAttribute('filter', 'drop-shadow(0 2px 4px rgba(0,0,0,0.35))');

  const circle = document.createElementNS(SVG_NS, 'circle');
  circle.setAttribute('cx', '16'); circle.setAttribute('cy', '15'); circle.setAttribute('r', '9');
  circle.setAttribute('fill', 'rgba(255,255,255,0.2)');

  svg.appendChild(path);
  svg.appendChild(circle);

  const iconEl = document.createElement('span');
  iconEl.className = 'material-symbols-outlined';
  iconEl.style.cssText = 'position:absolute;top:6px;left:50%;transform:translateX(-50%);font-size:14px;color:white;line-height:1;pointer-events:none;user-select:none;';
  iconEl.style.fontVariationSettings = "'FILL' 1";
  iconEl.textContent = icon;

  wrap.appendChild(svg);
  wrap.appendChild(iconEl);
  return wrap;
}

function showPopup(place) {
  if (popupInstance) popupInstance.remove();
  const cat = catMap[place.category];
  const color = cat ? cat.color : '#006479';

  const wrapper = document.createElement('div');

  const nameEl = document.createElement('strong');
  nameEl.style.cssText = 'font-size:13px;color:#003345;display:block;';
  nameEl.textContent = place.name;
  wrapper.appendChild(nameEl);

  const subEl = document.createElement('p');
  subEl.style.cssText = `margin:2px 0 0;font-size:11px;font-weight:600;color:${color};`;
  subEl.textContent = `${cat ? cat.label : ''} · ${place.area}`;
  wrapper.appendChild(subEl);

  if (place.tip) {
    const tipEl = document.createElement('p');
    tipEl.style.cssText = 'margin:4px 0 0;font-size:11px;color:#6b8fa3;line-height:1.4;';
    tipEl.textContent = place.tip;
    wrapper.appendChild(tipEl);
  }

  const dirBtn = document.createElement('a');
  dirBtn.href = `https://www.google.com/maps/dir/?api=1&destination=${place.lat},${place.lng}`;
  dirBtn.target = '_blank';
  dirBtn.rel = 'noopener noreferrer';
  dirBtn.style.cssText = 'display:inline-flex;align-items:center;gap:4px;margin-top:8px;padding:5px 10px;background:#006479;color:white;border-radius:20px;font-size:11px;font-weight:600;text-decoration:none;font-family:inherit;';
  const dirIcon = document.createElement('span');
  dirIcon.className = 'material-symbols-outlined';
  dirIcon.style.cssText = 'font-size:13px;';
  dirIcon.style.fontVariationSettings = "'FILL' 1";
  dirIcon.textContent = 'directions';
  dirBtn.appendChild(dirIcon);
  dirBtn.appendChild(document.createTextNode('Get Directions'));
  wrapper.appendChild(dirBtn);

  popupInstance = new mapboxgl.Popup({ maxWidth: '260px', offset: [0, -38] })
    .setLngLat([place.lng, place.lat])
    .setDOMContent(wrapper)
    .addTo(map);
}

function initMap() {
  mapboxgl.accessToken = mapboxToken;
  map = new mapboxgl.Map({
    container: 'guide-map',
    style: 'mapbox://styles/ninoerjavec/cmnbmfwyi001m01qt79mi86hx',
    center: [100.5290, 13.7270],
    zoom: 13.5,
  });
  map.addControl(new mapboxgl.NavigationControl(), 'top-right');

  places.forEach(p => {
    const el = makeMarkerEl(p.category);
    const m = new mapboxgl.Marker({ element: el, anchor: 'bottom' })
      .setLngLat([p.lng, p.lat])
      .addTo(map);
    el.addEventListener('click', (e) => {
      e.stopPropagation();
      map.flyTo({ center: [p.lng, p.lat], zoom: 17, duration: 600 });
      setTimeout(() => showPopup(p), 650);
    });
    markerObjs[p.id] = { marker: m, place: p };
  });
}

function updateMarkers(cat) {
  if (!map) return;
  const bounds = new mapboxgl.LngLatBounds();
  let count = 0;
  Object.values(markerObjs).forEach(({ marker, place }) => {
    if (cat === 'all' || place.category === cat) {
      marker.addTo(map);
      bounds.extend([place.lng, place.lat]);
      count++;
    } else {
      marker.remove();
    }
  });
  if (count > 0) map.fitBounds(bounds, { padding: 60, maxZoom: 16, duration: 800 });
}

window.filterCat = function(cat) {
  document.querySelectorAll('.cat-btn').forEach(btn => {
    if (btn.getAttribute('data-cat') === cat) {
      btn.classList.add('active-cat'); btn.style.background = ''; btn.style.color = '';
    } else {
      btn.classList.remove('active-cat'); btn.style.background = 'rgba(0,0,0,0.04)'; btn.style.color = '#003345';
    }
  });

  let visible = 0;
  document.querySelectorAll('.place-card').forEach(card => {
    if (cat === 'all' || card.getAttribute('data-cat') === cat) { card.classList.remove('hidden'); visible++; }
    else { card.classList.add('hidden'); }
  });

  const countEl = document.getElementById('places-count');
  if (countEl) countEl.textContent = `Showing ${visible} ${cat === 'all' ? 'places' : (catMap[cat]?.label || cat)}`;

  updateMarkers(cat);
};

window.focusPlace = function(lat, lng, id) {
  if (!map) return;
  map.flyTo({ center: [lng, lat], zoom: 17, duration: 600 });
  const obj = markerObjs[id];
  if (obj) setTimeout(() => showPopup(obj.place), 650);
  document.getElementById('guide-map').scrollIntoView({ behavior: 'smooth', block: 'center' });
};

function loadMapbox(cb) {
  if (window.mapboxgl) { cb(); return; }
  const s = document.createElement('script');
  s.src = 'https://api.mapbox.com/mapbox-gl-js/v3.3.0/mapbox-gl.js';
  s.onload = cb;
  document.head.appendChild(s);
}

document.addEventListener('DOMContentLoaded', () => loadMapbox(initMap));
</script>
