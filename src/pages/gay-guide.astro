---
import BaseLayout from '../components/layout/BaseLayout.astro';
---

<BaseLayout
  title="Gay Bangkok Songkran 2026 — The Ultimate LGBTQ+ Guide"
  description="The complete gay guide to Songkran 2026 Bangkok. GCircuit, Silom, clubs, transport tips, survival advice and more."
  canonical="https://bkksongkran.com/gay-guide"
>

<style>
  .guide-sidebar a {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 8px 12px;
    border-radius: 10px;
    font-size: 13px;
    font-weight: 600;
    color: #326177;
    text-decoration: none;
    transition: all 0.15s;
  }
  .guide-sidebar a:hover { background: rgba(168,85,247,0.1); color: #7c3aed; }
  .guide-sidebar a.active { background: rgba(168,85,247,0.08); color: #7c3aed; border-left: 3px solid #a855f7; padding-left: 9px; }
  .guide-sidebar .section-group { margin-bottom: 6px; }
  .guide-sidebar .section-group-label {
    font-size: 10px;
    font-weight: 800;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #6b8fa3;
    padding: 10px 12px 4px;
  }
  .section-anchor { scroll-margin-top: 100px; }
  .tip-card {
    background: white;
    border: 1px solid rgba(192,232,255,0.5);
    border-radius: 16px;
    padding: 18px 20px;
  }
  .tip-card.warn   { border-left: 4px solid #FF9F0A; background: rgba(255,159,10,0.03); }
  .tip-card.danger { border-left: 4px solid #ef4444; background: rgba(239,68,68,0.03); }
  .tip-card.good   { border-left: 4px solid #34C759; background: rgba(52,199,89,0.03); }
  .tip-card.info   { border-left: 4px solid #40cef3; background: rgba(64,206,243,0.03); }
  .tip-card.purple { border-left: 4px solid #a855f7; background: rgba(168,85,247,0.03); }
  .section-title {
    font-size: clamp(1.5rem, 4vw, 2.2rem);
    font-weight: 800;
    color: #003345;
    margin-bottom: 6px;
    line-height: 1.1;
  }
  .section-label {
    font-size: 10px;
    font-weight: 800;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #a855f7;
    margin-bottom: 8px;
    display: block;
  }
  .venue-card {
    background: white;
    border: 1px solid rgba(192,232,255,0.5);
    border-radius: 16px;
    padding: 18px 20px;
    display: flex;
    gap: 14px;
    align-items: flex-start;
  }
  .venue-icon {
    width: 44px; height: 44px;
    border-radius: 12px;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
  }
  .badge {
    display: inline-flex; align-items: center; gap: 4px;
    padding: 3px 10px;
    border-radius: 100px;
    font-size: 11px; font-weight: 700;
  }
  .btn {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 10px 18px;
    border-radius: 12px;
    font-size: 13px; font-weight: 700;
    text-decoration: none;
    transition: all 0.15s;
    cursor: pointer; border: none;
  }
  .btn:hover { opacity: 0.85; transform: translateY(-1px); box-shadow: 0 4px 14px rgba(0,0,0,0.12); }
  .btn-primary { background: linear-gradient(135deg,#a855f7,#ec4899); color: white; }
  .btn-outline { background: rgba(168,85,247,0.08); color: #7c3aed; border: 1px solid rgba(168,85,247,0.2); }
  .btn-dark { background: rgba(0,100,121,0.08); color: #006479; border: 1px solid rgba(0,100,121,0.15); }
  .event-card {
    background: white;
    border: 1px solid rgba(192,232,255,0.5);
    border-radius: 16px;
    overflow: hidden;
    transition: box-shadow 0.15s;
  }
  .event-card:hover { box-shadow: 0 4px 20px rgba(168,85,247,0.1); }
  .event-card-header { padding: 16px 18px 12px; border-bottom: 1px solid rgba(192,232,255,0.3); }
  .event-card-body { padding: 14px 18px 16px; }
  .festival-card {
    background: white;
    border: 1px solid rgba(192,232,255,0.5);
    border-radius: 18px;
    padding: 20px;
    display: flex; flex-direction: column; gap: 10px;
    transition: all 0.15s;
  }
  .festival-card:hover { box-shadow: 0 4px 20px rgba(0,0,0,0.07); transform: translateY(-2px); }

  /* Mobile */
  #mobile-nav-toggle { display: block; }
  #guide-sidebar { display: none; }
  #guide-sidebar.open {
    display: block !important;
    position: fixed; inset: 0; z-index: 100;
    background: white; overflow-y: auto; padding: 24px;
  }
  #guide-layout { display: block; }
  #guide-sidebar-desktop { display: none; }

  @media (min-width: 1024px) {
    #mobile-nav-toggle { display: none !important; }
    #guide-layout { display: flex; gap: 40px; align-items: flex-start; }
    #guide-sidebar-desktop { display: block; width: 256px; flex-shrink: 0; position: sticky; top: 96px; }
    #guide-sidebar { display: none; }
  }
</style>

<!-- HEADER -->
<section class="pt-36 pb-12 px-6" style="background:linear-gradient(160deg,rgba(88,28,135,0.06) 0%,rgba(225,243,255,0.7) 60%,rgba(238,248,255,0) 100%);">
  <div class="max-w-7xl mx-auto">
    <span class="section-label">LGBTQ+ Guide</span>
    <h1 class="font-headline font-extrabold tracking-tighter mb-4" style="font-size:clamp(2.8rem,8vw,5.5rem);color:#003345;line-height:0.9;">
      GAY<br/>
      <span style="background:linear-gradient(135deg,#a855f7,#ec4899);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;">SONGKRAN</span><br/>
      <span style="font-size:0.5em;color:#003345;">BANGKOK 2026</span>
    </h1>
    <p class="text-lg max-w-2xl mt-4 mb-6" style="color:#326177;line-height:1.6;">GCircuit, Silom, GOD club, cruising bars, afterparties — your complete guide to the gayest week in Asia.</p>
    <div class="flex flex-wrap gap-3">
      <a href="/events" class="btn btn-dark"><span class="material-symbols-outlined text-base">calendar_month</span>All Events</a>
      <a href="/meetup" class="btn btn-dark"><span class="material-symbols-outlined text-base">diversity_3</span>Who's Going?</a>
      <a href="/tickets" class="btn btn-dark"><span class="material-symbols-outlined text-base">confirmation_number</span>Buy / Sell Tickets</a>
      <a href="/survival-kit" class="btn btn-dark"><span class="material-symbols-outlined text-base">backpack</span>Survival Kit</a>
    </div>
  </div>
</section>

<!-- Mobile floating button -->
<div id="mobile-nav-toggle" style="position:fixed;bottom:24px;left:50%;transform:translateX(-50%);z-index:50;">
  <button onclick="document.getElementById('guide-sidebar').classList.toggle('open')" class="btn btn-primary" style="box-shadow:0 4px 20px rgba(168,85,247,0.4);">
    <span class="material-symbols-outlined" style="font-size:18px;">menu_book</span>
    Jump to section
  </button>
</div>

<!-- Mobile sidebar overlay -->
<aside id="guide-sidebar" class="guide-sidebar">
  <div style="display:flex;align-items:center;justify-content:space-between;padding:16px;border-bottom:1px solid rgba(192,232,255,0.4);margin-bottom:8px;">
    <span style="font-weight:700;font-size:15px;color:#003345;">Contents</span>
    <button onclick="document.getElementById('guide-sidebar').classList.remove('open')" style="background:none;border:none;cursor:pointer;" class="material-symbols-outlined">close</button>
  </div>
  <div class="section-group"><div class="section-group-label">Festivals & Events</div>
    <a href="#festivals" onclick="closeMobileNav()"><span class="material-symbols-outlined text-sm" style="color:#a855f7;">festival</span>Main Festivals</a>
    <a href="#gcircuit" onclick="closeMobileNav()"><span class="material-symbols-outlined text-sm" style="color:#a855f7;">nightlife</span>GCircuit</a>
    <a href="#silom" onclick="closeMobileNav()"><span class="material-symbols-outlined text-sm" style="color:#ec4899;">celebration</span>Silom Soi 2 & 4</a>
    <a href="#special" onclick="closeMobileNav()"><span class="material-symbols-outlined text-sm" style="color:#a855f7;">local_activity</span>Special Events</a>
    <a href="#clubs" onclick="closeMobileNav()"><span class="material-symbols-outlined text-sm" style="color:#ec4899;">nightlife</span>Clubs & Bars</a>
    <a href="#totems" onclick="closeMobileNav()"><span class="material-symbols-outlined text-sm" style="color:#FF9F0A;">flag</span>Totems & Meetups</a>
  </div>
  <div class="section-group"><div class="section-group-label">Community</div>
    <a href="#tickets-section" onclick="closeMobileNav()"><span class="material-symbols-outlined text-sm" style="color:#34C759;">confirmation_number</span>Buy / Sell Tickets</a>
    <a href="#whos-going" onclick="closeMobileNav()"><span class="material-symbols-outlined text-sm" style="color:#006479;">diversity_3</span>Who's Going?</a>
  </div>
  <div class="section-group"><div class="section-group-label">Practical</div>
    <a href="#transport" onclick="closeMobileNav()"><span class="material-symbols-outlined text-sm" style="color:#34C759;">directions_transit</span>Transport</a>
    <a href="#safety" onclick="closeMobileNav()"><span class="material-symbols-outlined text-sm" style="color:#ef4444;">health_and_safety</span>Safety & Tips</a>
    <a href="#map" onclick="closeMobileNav()"><span class="material-symbols-outlined text-sm" style="color:#006479;">map</span>Gay Bangkok Map</a>
  </div>
</aside>

<!-- LAYOUT -->
<div id="guide-layout" class="max-w-7xl mx-auto px-4 pb-32" style="overflow-x:clip;">

  <!-- Desktop sidebar -->
  <aside id="guide-sidebar-desktop" class="guide-sidebar">
    <div class="rounded-2xl overflow-hidden" style="background:white;border:1px solid rgba(192,232,255,0.5);box-shadow:0 2px 12px rgba(0,0,0,0.04);">
      <div class="section-group"><div class="section-group-label">Festivals & Events</div>
        <a href="#festivals"><span class="material-symbols-outlined text-sm" style="color:#a855f7;">festival</span>Main Festivals</a>
        <a href="#gcircuit"><span class="material-symbols-outlined text-sm" style="color:#a855f7;">nightlife</span>GCircuit</a>
        <a href="#silom"><span class="material-symbols-outlined text-sm" style="color:#ec4899;">celebration</span>Silom Soi 2 & 4</a>
        <a href="#special"><span class="material-symbols-outlined text-sm" style="color:#a855f7;">local_activity</span>Special Events</a>
        <a href="#clubs"><span class="material-symbols-outlined text-sm" style="color:#ec4899;">nightlife</span>Clubs & Bars</a>
        <a href="#totems"><span class="material-symbols-outlined text-sm" style="color:#FF9F0A;">flag</span>Totems & Meetups</a>
      </div>
      <div class="section-group"><div class="section-group-label">Community</div>
        <a href="#tickets-section"><span class="material-symbols-outlined text-sm" style="color:#34C759;">confirmation_number</span>Buy / Sell Tickets</a>
        <a href="#whos-going"><span class="material-symbols-outlined text-sm" style="color:#006479;">diversity_3</span>Who's Going?</a>
      </div>
      <div class="section-group"><div class="section-group-label">Practical</div>
        <a href="#transport"><span class="material-symbols-outlined text-sm" style="color:#34C759;">directions_transit</span>Transport</a>
        <a href="#safety"><span class="material-symbols-outlined text-sm" style="color:#ef4444;">health_and_safety</span>Safety & Tips</a>
        <a href="#map"><span class="material-symbols-outlined text-sm" style="color:#006479;">map</span>Gay Bangkok Map</a>
      </div>
    </div>
  </aside>

  <!-- MAIN CONTENT -->
  <main class="flex-1 min-w-0 space-y-16">

    <!-- ── MAIN FESTIVALS ── -->
    <section id="festivals" class="section-anchor">
      <span class="section-label">Main Festivals</span>
      <h2 class="section-title">The Big Three</h2>
      <p class="text-sm mb-5" style="color:#326177;line-height:1.7;">Three major paid festivals run across the long weekend. All are LGBTQ+ friendly — but GCircuit is the gay flagship.</p>
      <div class="grid gap-4 sm:grid-cols-3">
        <!-- S2O -->
        <div class="festival-card">
          <div>
            <div class="flex flex-wrap gap-1.5 mb-2">
              <span class="badge" style="background:rgba(64,206,243,0.12);color:#006479;">Apr 11–13</span>
              <span class="badge" style="background:rgba(64,206,243,0.08);color:#006479;">S2O Land, Ratchada</span>
            </div>
            <div class="font-headline font-bold text-xl" style="color:#003345;">S2O Songkran</div>
            <div class="text-xs font-semibold mt-0.5 mb-2" style="color:#40cef3;">The World's Wettest Party</div>
            <p class="text-sm" style="color:#326177;line-height:1.5;">Massive water cannons on every drop. International EDM. Very gay-friendly, mixed crowd. You <strong style="color:#003345;">will be soaked</strong> the entire time.</p>
          </div>
          <a href="/events#s2o" class="btn btn-primary mt-auto" style="font-size:12px;">
            <span class="material-symbols-outlined" style="font-size:14px;">arrow_forward</span>Full lineup
          </a>
        </div>
        <!-- Siam -->
        <div class="festival-card">
          <div>
            <div class="flex flex-wrap gap-1.5 mb-2">
              <span class="badge" style="background:rgba(180,0,93,0.1);color:#b4005d;">Apr 11–14</span>
              <span class="badge" style="background:rgba(180,0,93,0.07);color:#b4005d;">Bravo BKK Arena, RCA</span>
            </div>
            <div class="font-headline font-bold text-xl" style="color:#003345;">Siam Songkran</div>
            <div class="text-xs font-semibold mt-0.5 mb-2" style="color:#b4005d;">4 Nights of EDM</div>
            <p class="text-sm" style="color:#326177;line-height:1.5;">Indoor arena, less water than S2O. Martin Garrix, Marshmello, John Summit. RCA has great clubs right next door for after.</p>
          </div>
          <a href="/events#siam" class="btn btn-primary mt-auto" style="font-size:12px;">
            <span class="material-symbols-outlined" style="font-size:14px;">arrow_forward</span>Full lineup
          </a>
        </div>
        <!-- GCircuit -->
        <div id="gcircuit" class="festival-card section-anchor">
          <div>
            <div class="flex flex-wrap gap-1.5 mb-2">
              <span class="badge" style="background:rgba(168,85,247,0.12);color:#7c3aed;">Apr 11–14</span>
              <span class="badge" style="background:rgba(168,85,247,0.1);color:#7c3aed;">Emsphere + Tribe Sky</span>
            </div>
            <div class="font-headline font-bold text-xl" style="color:#003345;">GCircuit</div>
            <div class="text-xs font-semibold mt-0.5 mb-2" style="color:#a855f7;">Asia's #1 Gay Circuit Party</div>
            <p class="text-sm" style="color:#326177;line-height:1.5;">4 events, 4 days, 10,000+ gay men. Pool parties sell out. <strong style="color:#003345;">This is the main event.</strong></p>
          </div>
          <a href="/events#gcircuit" class="btn btn-primary mt-auto" style="font-size:12px;">
            <span class="material-symbols-outlined" style="font-size:14px;">arrow_forward</span>Full lineup
          </a>
        </div>
      </div>
    </section>

    <!-- ── SILOM ── -->
    <section id="silom" class="section-anchor">
      <span class="section-label">Free Street Party</span>
      <h2 class="section-title">Silom Soi 2 & 4</h2>
      <div class="space-y-3">
        <div class="tip-card purple">
          <div class="flex items-start gap-3">
            <span class="material-symbols-outlined flex-shrink-0 mt-0.5" style="color:#a855f7;font-size:20px;font-variation-settings:'FILL' 1;">celebration</span>
            <div>
              <p class="font-bold text-sm mb-1" style="color:#003345;">Apr 12–14 · Free · All welcome</p>
              <p class="text-sm" style="color:#326177;line-height:1.6;">Bangkok's historic gay district closes to traffic and becomes the world's biggest free LGBTQ+ street party. Sound trucks on every corner, water fights, foam, drag performances. The entire gay community plus thousands of visitors. Peak madness on Apr 13.</p>
            </div>
          </div>
        </div>
        <div class="tip-card warn">
          <div class="flex items-start gap-3">
            <span class="material-symbols-outlined flex-shrink-0 mt-0.5" style="color:#FF9F0A;font-size:20px;font-variation-settings:'FILL' 1;">warning</span>
            <div>
              <p class="font-bold text-sm mb-1" style="color:#003345;">Silom road is one-way and completely gridlocked Apr 12–14</p>
              <p class="text-sm" style="color:#326177;">Do not take Grab through Silom. Walk from BTS Sala Daeng or Chong Nonsi. The BTS is the only reliable option.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ── SPECIAL EVENTS ── -->
    <section id="special" class="section-anchor">
      <span class="section-label">Special Events</span>
      <h2 class="section-title">Don't Miss These</h2>
      <div class="space-y-3">

        <!-- Unleash -->
        <div class="event-card" style="border-color:rgba(168,85,247,0.25);">
          <div class="event-card-header" style="background:linear-gradient(135deg,rgba(168,85,247,0.08),rgba(236,72,153,0.05));">
            <div class="flex flex-wrap gap-2 mb-2">
              <span class="badge" style="background:rgba(168,85,247,0.12);color:#7c3aed;"><span class="material-symbols-outlined" style="font-size:11px;">calendar_today</span>Apr 13 · 4–9pm</span>
              <span class="badge" style="background:rgba(168,85,247,0.08);color:#7c3aed;"><span class="material-symbols-outlined" style="font-size:11px;">location_on</span>Side Bar, Silom</span>
              <span class="badge" style="background:rgba(236,72,153,0.1);color:#be185d;"><span class="material-symbols-outlined" style="font-size:11px;">local_activity</span>Ticketed</span>
            </div>
            <div class="font-headline font-bold text-lg" style="color:#003345;">Unleash — Wet Your Throat</div>
            <div class="text-sm font-semibold mt-0.5" style="color:#a855f7;">by Party Gay Asia</div>
          </div>
          <div class="event-card-body">
            <p class="text-sm mb-3" style="color:#326177;line-height:1.6;">An afternoon cruising bar celebration. Darkroom energy, themed play zones, unfiltered cruising, and a space to show up fully as yourself. Live DJ all afternoon. Perfect between the afternoon water fights and the night clubs.</p>
            <div class="flex flex-wrap gap-2 mb-3">
              <span class="badge" style="background:rgba(168,85,247,0.08);color:#7c3aed;"><span class="material-symbols-outlined" style="font-size:11px;">wb_twilight</span>Darkroom</span>
              <span class="badge" style="background:rgba(168,85,247,0.08);color:#7c3aed;"><span class="material-symbols-outlined" style="font-size:11px;">music_note</span>Live DJ</span>
              <span class="badge" style="background:rgba(168,85,247,0.08);color:#7c3aed;"><span class="material-symbols-outlined" style="font-size:11px;">groups</span>Cruising</span>
            </div>
            <div class="flex flex-wrap gap-2">
              <a href="https://yourtessera.com/e/unleash" target="_blank" rel="noopener" class="btn btn-primary">
                <span class="material-symbols-outlined" style="font-size:14px;">confirmation_number</span>Get Tickets
              </a>
              <a href="https://instagram.com/partygayasia" target="_blank" rel="noopener" class="btn btn-outline">
                <span class="material-symbols-outlined" style="font-size:14px;">photo_camera</span>@partygayasia
              </a>
            </div>
          </div>
        </div>

      </div>
    </section>

    <!-- ── CLUBS & BARS ── -->
    <section id="clubs" class="section-anchor">
      <span class="section-label">Nightlife</span>
      <h2 class="section-title">Gay Clubs & Bars</h2>
      <div class="space-y-3">

        {[
          {
            name: 'GOD Club',
            area: 'Silom area',
            icon: 'nightlife', color: '#1a1a2e',
            badges: [
              {label:'Afterparty', bg:'rgba(0,0,0,0.06)', c:'#003345'},
              {label:'Closes 3am', bg:'rgba(52,199,89,0.1)', c:'#16a34a'},
              {label:'Insane queues during Songkran', bg:'rgba(239,68,68,0.1)', c:'#dc2626'},
            ],
            desc: "Bangkok's most notorious gay afterparty club. Multiple floors, dark energy, circuit music. During Songkran queues can be 45–60 minutes — arrive before midnight to skip them.",
            hours: 'Opens late · Closes 3am',
            entry: '฿400',
          },
          {
            name: 'DJ Station',
            area: 'Silom Soi 2',
            icon: 'nightlife', color: '#a855f7',
            badges: [
              {label:'Flagship gay club', bg:'rgba(168,85,247,0.1)', c:'#7c3aed'},
            ],
            desc: "Bangkok's most iconic gay club. 3 floors, packed wall-to-wall during Songkran. Entry includes a drink. Dancing, good energy. Get there early — queue gets long.",
            hours: 'Closes 3am',
            entry: '฿400 incl. drink',
          },
          {
            name: 'Balcony Bar',
            area: 'Silom Soi 4',
            icon: 'local_bar', color: '#ec4899',
            badges: [
              {label:'Street views', bg:'rgba(236,72,153,0.1)', c:'#be185d'},
              {label:'Chill vibe', bg:'rgba(236,72,153,0.07)', c:'#be185d'},
            ],
            desc: 'Elevated bar overlooking the Silom Soi 4 street party. Perfect spot to watch the chaos below with a drink in hand. Great for a breather between venues.',
            hours: 'Late',
            entry: 'Free',
          },
          {
            name: 'Strangers Bar',
            area: 'Silom area',
            icon: 'local_bar', color: '#7c3aed',
            badges: [
              {label:'Gay bar', bg:'rgba(124,58,237,0.1)', c:'#7c3aed'},
              {label:'Drag shows', bg:'rgba(168,85,247,0.1)', c:'#7c3aed'},
            ],
            desc: 'Popular gay bar in the Silom area with regular drag shows. Good mix of locals and tourists, friendly crowd, solid drinks. A reliable stop on the Silom bar crawl.',
            hours: 'Late',
            entry: '฿450+',
          },
          {
            name: 'Banana Bar',
            area: 'Silom Soi 4',
            icon: 'local_bar', color: '#FF9F0A',
            badges: [
              {label:'Classic', bg:'rgba(255,159,10,0.1)', c:'#d97706'},
              {label:'Afterparty', bg:'rgba(255,159,10,0.07)', c:'#d97706'},
            ],
            desc: 'Long-running Silom bar known for its high-energy crowd. Popular afterparty spot — stays open until 5am when others close. Good for bar-hopping along Soi 4.',
            hours: 'Closes 5am',
            entry: '฿400',
          },
        ].map(v => (
          <div class="venue-card">
            <div class="venue-icon" style={`background:${v.color}18;`}>
              <span class="material-symbols-outlined" style={`color:${v.color};font-variation-settings:'FILL' 1;`}>{v.icon}</span>
            </div>
            <div class="min-w-0 flex-1">
              <div class="flex flex-wrap items-center gap-2 mb-1">
                <span class="font-bold text-base" style="color:#003345;">{v.name}</span>
                <span class="text-xs" style="color:#6b8fa3;">· {v.area}</span>
              </div>
              <div class="flex flex-wrap gap-1.5 mb-2">
