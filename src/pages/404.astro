---
import BaseLayout from '../components/layout/BaseLayout.astro';
---

<BaseLayout title="Page Not Found — Bangkok Songkran 2026" noindex={true}>
  <section class="min-h-screen flex items-center justify-center px-6 pt-28 pb-20">
    <div class="max-w-lg w-full text-center">
      <div class="font-headline font-extrabold tracking-tighter mb-2" style="font-size:clamp(6rem,20vw,10rem);color:#003345;line-height:1;opacity:0.08;">404</div>
      <div style="margin-top:-2rem;">
        <span class="material-symbols-outlined" style="font-size:56px;color:#40cef3;font-variation-settings:'FILL' 1;">water_drop</span>
        <h1 class="font-headline font-extrabold text-3xl md:text-4xl mt-3 mb-3" style="color:#003345;">Washed Away</h1>
        <p class="text-base mb-8" style="color:#326177;">This page got hit by a water cannon. It doesn't exist — or it moved.</p>
        <div class="flex flex-wrap gap-3 justify-center">
          <a href="/" class="flex items-center gap-2 px-6 py-3 rounded-xl text-sm font-bold text-white transition-all hover:scale-105" style="background:linear-gradient(135deg,#006479,#40cef3);">
            <span class="material-symbols-outlined text-base">home</span>
            Go Home
          </a>
          <a href="/events" class="flex items-center gap-2 px-6 py-3 rounded-xl text-sm font-bold transition-all hover:scale-105" style="background:rgba(0,100,121,0.08);color:#006479;">
            <span class="material-symbols-outlined text-base">calendar_month</span>
            View Events
          </a>
          <a href="/blog" class="flex items-center gap-2 px-6 py-3 rounded-xl text-sm font-bold transition-all hover:scale-105" style="background:rgba(0,100,121,0.08);color:#006479;">
            <span class="material-symbols-outlined text-base">menu_book</span>
            Festival Guide
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
