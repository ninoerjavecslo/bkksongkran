---
import BaseLayout from '../components/layout/BaseLayout.astro';
export const prerender = false;
---

<BaseLayout title="Songkran Ticket Exchange — Buy & Sell Festival Tickets" description="Buy and sell Songkran 2026 festival tickets directly. S2O, Siam Songkran, GCircuit — no middlemen, connect with sellers and buyers." canonical="https://bkksongkran.com/tickets">

  <!-- HEADER -->
  <section class="pt-36 pb-12 px-6" style="background:linear-gradient(180deg,rgba(225,243,255,0.8),rgba(238,248,255,0));">
    <div class="max-w-7xl mx-auto">
      <div class="text-xs font-bold tracking-[0.2em] uppercase mb-3" style="color:#006479;">Community Board</div>
      <h1 class="font-headline font-extrabold tracking-tighter mb-4" style="font-size:clamp(2.5rem,7vw,5rem);color:#003345;line-height:0.95;">
        TICKET<br/>
        <span style="background:linear-gradient(135deg,#006479,#40cef3);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;">EXCHANGE</span>
      </h1>
      <p class="text-lg max-w-xl" style="color:#326177;">Buy and sell Songkran festival tickets. No middlemen, no Facebook groups — just connect directly.</p>
      <div class="flex gap-3 mt-6">
        <button class="btn-primary px-6 py-3 text-sm" id="btn-open-form">
          <span class="material-symbols-outlined text-base" style="font-variation-settings:'FILL' 1;">add_circle</span>
          Post a Listing
        </button>
      </div>
    </div>
  </section>

  <!-- UNLOCK CONTACTS BUTTON (shown when not yet unlocked) -->
  <section class="px-6 pb-4" id="unlock-banner">
    <div class="max-w-7xl mx-auto flex items-center gap-4 flex-wrap">
      <p class="text-sm" style="color:#326177;">Contact info is hidden. Enter your email once to reveal all contacts.</p>
      <button id="btn-unlock-contacts" class="flex-shrink-0 flex items-center gap-2 px-5 py-2.5 rounded-xl text-sm font-bold text-white transition-all" style="background:linear-gradient(135deg,#006479,#40cef3);">
        <span class="material-symbols-outlined text-base" style="font-variation-settings:'FILL' 1;">lock_open</span>
        Unlock Contact Info
      </button>
    </div>
  </section>

  <!-- UNLOCK MODAL -->
  <div id="unlock-modal" class="modal-overlay hidden">
    <div class="modal-backdrop" id="unlock-modal-backdrop"></div>
    <div class="modal-scroll">
      <div class="modal-center">
        <div class="card w-full max-w-sm p-6 space-y-4 modal-card">
          <div class="flex items-center justify-between">
            <h3 class="font-headline font-bold text-lg" style="color:#003345;">Unlock Contact Info</h3>
            <button id="unlock-close-btn" class="p-1 rounded-full hover:bg-surface-container-high transition-colors">
              <span class="material-symbols-outlined text-on-surface-variant">close</span>
            </button>
          </div>
          <p class="text-sm" style="color:#326177;">Enter your email once to reveal seller and buyer contacts across all listings.</p>
          <input type="email" id="unlock-email" placeholder="your@email.com" class="form-input" />
          <div id="turnstile-unlock"></div>
          <button id="unlock-btn" class="w-full flex items-center justify-center gap-2 px-4 py-2.5 rounded-xl text-sm font-bold text-white transition-all" style="background:linear-gradient(135deg,#006479,#40cef3);">
            <span class="material-symbols-outlined text-base" style="font-variation-settings:'FILL' 1;">lock_open</span>
            Unlock all contacts
          </button>
          <p id="unlock-error" class="hidden text-xs font-bold" style="color:#b31b25;"></p>
          <p class="text-[11px] text-center" style="color:#86b3cc;">Your email is stored privately and never shared.</p>
        </div>
      </div>
    </div>
  </div>

  <!-- FILTERS -->
  <section class="px-6 pb-4">
    <div class="max-w-7xl mx-auto flex flex-wrap gap-3 items-center">
      <div class="flex gap-2 p-1 rounded-xl" style="background:rgba(255,255,255,0.7);border:1px solid rgba(192,232,255,0.6);">
        <button class="filter-btn active" data-filter-type="all">All</button>
        <button class="filter-btn" data-filter-type="selling">
          <span class="material-symbols-outlined text-xs" style="font-variation-settings:'FILL' 1;">sell</span> Selling
        </button>
        <button class="filter-btn" data-filter-type="buying">
          <span class="material-symbols-outlined text-xs" style="font-variation-settings:'FILL' 1;">shopping_cart</span> Buying
        </button>
      </div>
      <div class="flex gap-2 p-1 rounded-xl" style="background:rgba(255,255,255,0.7);border:1px solid rgba(192,232,255,0.6);">
        <button class="filter-btn active" data-filter-fest="all">All Festivals</button>
        <button class="filter-btn" data-filter-fest="S2O">S2O</button>
        <button class="filter-btn" data-filter-fest="Siam Songkran">Siam Songkran</button>
        <button class="filter-btn" data-filter-fest="GCircuit">GCircuit</button>
      </div>
      <div class="ml-auto text-sm font-semibold" style="color:#326177;" id="listing-count"></div>
    </div>
  </section>

  <!-- LISTINGS -->
  <section class="px-6 pb-20">
    <div class="max-w-7xl mx-auto">
      <div id="listings-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5"></div>
      <div id="empty-state" class="hidden text-center py-16">
        <span class="material-symbols-outlined text-5xl mb-4" style="color:#86b3cc;font-variation-settings:'FILL' 1;">confirmation_number</span>
        <p class="font-headline font-bold text-xl mb-2" style="color:#003345;">No listings yet</p>
        <p class="text-sm" style="color:#326177;">Be the first to post a ticket!</p>
      </div>
    </div>
  </section>

  <!-- CARD TEMPLATE -->
  <template id="ticket-card-tpl">
    <div class="card p-0 overflow-hidden animate-slide-up">
      <div class="tpl-bar h-1.5 w-full"></div>
      <div class="p-5 space-y-3">
        <div class="flex items-start justify-between gap-2">
          <div class="flex items-center gap-2">
            <span class="tpl-type-badge inline-flex items-center gap-1 px-2.5 py-1 rounded-full text-[10px] font-bold uppercase"></span>
            <span class="tpl-fest-badge inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-bold"></span>
          </div>
          <span class="tpl-time text-[10px] font-medium" style="color:#86b3cc;"></span>
        </div>
        <div>
          <div class="tpl-meta text-xs font-semibold mb-1" style="color:#326177;"></div>
          <div class="tpl-price font-headline font-black text-2xl"></div>
          <div class="tpl-qty text-xs" style="color:#326177;"></div>
        </div>
        <p class="tpl-note text-xs leading-relaxed hidden" style="color:#326177;"></p>
        <div class="tpl-contact-locked pt-3 border-t" style="border-color:rgba(192,232,255,0.5);">
          <div class="flex items-center gap-2">
            <span class="material-symbols-outlined text-sm" style="color:#86b3cc;font-variation-settings:'FILL' 1;">lock</span>
            <span class="text-xs" style="color:#86b3cc;">Unlock contacts above to reveal</span>
          </div>
        </div>
        <div class="tpl-contact-revealed hidden pt-2 border-t" style="border-color:rgba(192,232,255,0.5);">
          <div class="flex items-center justify-between gap-2">
            <div class="flex items-center gap-2 min-w-0">
              <span class="tpl-contact-icon material-symbols-outlined text-sm flex-shrink-0" style="font-variation-settings:'FILL' 1;"></span>
              <span class="tpl-contact text-sm font-bold truncate" style="color:#003345;"></span>
              <span class="tpl-contact-type text-[10px] px-1.5 py-0.5 rounded font-bold uppercase flex-shrink-0"></span>
            </div>
            <button class="tpl-copy-btn flex-shrink-0 p-1.5 rounded-lg transition-all hover:bg-surface-container-high" title="Copy contact">
              <span class="material-symbols-outlined text-sm" style="color:#86b3cc;">content_copy</span>
            </button>
          </div>
        </div>
      </div>
    </div>
  </template>

  <!-- SUCCESS MODAL -->
  <div id="success-modal" class="modal-overlay hidden">
    <div class="modal-backdrop"></div>
    <div class="modal-scroll">
      <div class="modal-center">
        <div class="card w-full max-w-md p-6 space-y-4 modal-card">
          <div class="text-center">
            <span class="material-symbols-outlined text-5xl mb-2" style="color:#006479;font-variation-settings:'FILL' 1;">check_circle</span>
            <h3 class="font-headline font-bold text-xl" style="color:#003345;">Listing Posted!</h3>
            <p class="text-sm mt-1" style="color:#326177;">Save the link below to delete your listing later.</p>
          </div>
          <div class="p-3 rounded-xl text-xs font-mono break-all" style="background:rgba(225,243,255,0.8);border:1.5px solid rgba(64,206,243,0.4);color:#003345;" id="delete-link-display"></div>
          <button id="copy-link-btn" class="w-full flex items-center justify-center gap-2 px-4 py-2.5 rounded-xl text-sm font-bold text-white" style="background:linear-gradient(135deg,#006479,#40cef3);">
            <span class="material-symbols-outlined text-base">content_copy</span>
            Copy Delete Link
          </button>
          <p class="text-[11px] text-center" style="color:#86b3cc;">Save it somewhere safe — you won't be able to recover it.</p>
          <button id="success-close-btn" class="w-full px-4 py-2.5 rounded-xl text-sm font-bold transition-all" style="background:rgba(225,243,255,0.7);border:1px solid rgba(192,232,255,0.8);color:#326177;">Close</button>
        </div>
      </div>
    </div>
  </div>

  <!-- POST FORM -->
  <section id="post-modal" class="hidden px-6 pb-20">
    <div class="max-w-3xl mx-auto">
      <div class="card p-6 md:p-8 space-y-4">
        <div class="flex items-center justify-between">
          <h2 class="font-headline font-bold text-xl" style="color:#003345;">Post a Listing</h2>
          <button id="close-form-btn" class="p-1 rounded-full hover:bg-surface-container-high transition-colors">
            <span class="material-symbols-outlined text-on-surface-variant">close</span>
          </button>
        </div>
        <div id="form-errors" class="hidden p-3 rounded-xl text-sm font-medium" style="background:#FFE8E8;border:1px solid #FF3B30;color:#7A0000;"></div>
        <form id="ticket-form" novalidate>
          <div class="mb-5">
            <label class="form-label">I'm... <span class="req">*</span></label>
            <div class="flex gap-3">
              <label class="flex-1">
                <input type="radio" name="type" value="selling" class="peer hidden" checked />
                <div class="peer-checked:border-primary peer-checked:bg-primary/5 border-2 border-surface-container-high rounded-xl p-3 text-center cursor-pointer transition-all">
                  <span class="material-symbols-outlined text-2xl mb-1" style="font-variation-settings:'FILL' 1;color:#006479;">sell</span>
                  <div class="text-sm font-bold" style="color:#003345;">Selling</div>
                </div>
              </label>
              <label class="flex-1">
                <input type="radio" name="type" value="buying" class="peer hidden" />
                <div class="peer-checked:border-primary peer-checked:bg-primary/5 border-2 border-surface-container-high rounded-xl p-3 text-center cursor-pointer transition-all">
                  <span class="material-symbols-outlined text-2xl mb-1" style="font-variation-settings:'FILL' 1;color:#006479;">shopping_cart</span>
                  <div class="text-sm font-bold" style="color:#003345;">Buying</div>
                </div>
              </label>
            </div>
          </div>
          <div class="mb-5">
            <label class="form-label">Festival <span class="req">*</span></label>
            <div class="cs-wrap" data-cs-name="festival">
              <button type="button" class="cs-trigger form-input" style="display:flex;align-items:center;justify-content:space-between;cursor:pointer;">
                <span class="cs-label" style="color:#86b3cc;">Select festival...</span>
                <span class="material-symbols-outlined text-base" style="color:#86b3cc;transition:transform 0.2s;">expand_more</span>
              </button>
              <div class="cs-menu">
                <div class="cs-item" data-val="S2O">S2O Songkran (Apr 11-13)</div>
                <div class="cs-item" data-val="Siam Songkran">Siam Songkran (Apr 11-14)</div>
                <div class="cs-item" data-val="GCircuit">GCircuit Songkran (Apr 10-13)</div>
              </div>
            </div>
          </div>
          <div class="grid grid-cols-2 gap-4 mb-5">
            <div>
              <label class="form-label">Date(s) <span class="req">*</span></label>
              <div class="cs-wrap" data-cs-name="dates">
                <button type="button" class="cs-trigger form-input" style="display:flex;align-items:center;justify-content:space-between;cursor:pointer;">
                  <span class="cs-label" style="color:#86b3cc;">Select...</span>
                  <span class="material-symbols-outlined text-base" style="color:#86b3cc;transition:transform 0.2s;">expand_more</span>
                </button>
                <div class="cs-menu">
                  <div class="cs-item" data-val="All Days">All Days Pass</div>
                  <div class="cs-item" data-val="Apr 10">Apr 10</div>
                  <div class="cs-item" data-val="Apr 11">Apr 11</div>
                  <div class="cs-item" data-val="Apr 12">Apr 12</div>
                  <div class="cs-item" data-val="Apr 13">Apr 13</div>
                  <div class="cs-item" data-val="Apr 14">Apr 14</div>
                </div>
              </div>
            </div>
            <div>
              <label class="form-label">Tier <span class="req">*</span></label>
              <div class="cs-wrap" data-cs-name="tier" data-cs-default="GA">
                <button type="button" class="cs-trigger form-input" style="display:flex;align-items:center;justify-content:space-between;cursor:pointer;">
                  <span class="cs-label">GA (General)</span>
                  <span class="material-symbols-outlined text-base" style="color:#86b3cc;transition:transform 0.2s;">expand_more</span>
                </button>
                <div class="cs-menu">
                  <div class="cs-item active" data-val="GA">GA (General)</div>
                  <div class="cs-item" data-val="VIP">VIP</div>
                </div>
              </div>
            </div>
          </div>
          <div class="grid grid-cols-2 gap-4 mb-5">
            <div>
              <label class="form-label">Tickets <span class="req">*</span></label>
              <input type="number" name="quantity" min="1" max="10" value="1" class="form-input" />
            </div>
            <div>
              <label class="form-label">Price per ticket (฿) <span class="req">*</span></label>
              <input type="number" name="price" min="0" step="100" placeholder="e.g. 2000" class="form-input" />
            </div>
          </div>
          <div class="mb-5">
            <label class="form-label">Contact <span class="req">*</span></label>
            <div class="grid grid-cols-2 sm:grid-cols-4 gap-2 mb-2">
              <label>
                <input type="radio" name="contact_type" value="telegram" class="peer hidden" checked />
                <div class="peer-checked:border-primary peer-checked:bg-primary/5 border border-surface-container-high rounded-lg p-2 text-center cursor-pointer transition-all text-xs font-bold" style="color:#003345;">Telegram</div>
              </label>
              <label>
                <input type="radio" name="contact_type" value="line" class="peer hidden" />
                <div class="peer-checked:border-primary peer-checked:bg-primary/5 border border-surface-container-high rounded-lg p-2 text-center cursor-pointer transition-all text-xs font-bold" style="color:#003345;">Line</div>
              </label>
              <label>
                <input type="radio" name="contact_type" value="whatsapp" class="peer hidden" />
                <div class="peer-checked:border-primary peer-checked:bg-primary/5 border border-surface-container-high rounded-lg p-2 text-center cursor-pointer transition-all text-xs font-bold" style="color:#003345;">WhatsApp</div>
              </label>
              <label>
                <input type="radio" name="contact_type" value="instagram" class="peer hidden" />
                <div class="peer-checked:border-primary peer-checked:bg-primary/5 border border-surface-container-high rounded-lg p-2 text-center cursor-pointer transition-all text-xs font-bold" style="color:#003345;">Instagram</div>
              </label>
            </div>
            <input type="text" name="contact" placeholder="@username, phone, or email" class="form-input" />
          </div>
          <div class="mb-5">
            <label class="form-label">Your Email <span class="req">*</span> <span style="font-weight:400;text-transform:none;color:#86b3cc;">(private — for listing management only)</span></label>
            <input type="email" name="email" placeholder="your@email.com" class="form-input" />
          </div>
          <div class="mb-5">
            <label class="form-label">Note <span style="font-weight:400;text-transform:none;color:#86b3cc;">(optional)</span></label>
            <textarea name="note" rows="2" maxlength="200" placeholder="Any extra info..." class="form-input resize-none"></textarea>
          </div>
          <div class="space-y-3 mb-6">
            <label class="flex items-start gap-3 cursor-pointer">
              <input type="checkbox" name="gdpr" class="mt-0.5 w-4 h-4 rounded" style="accent-color:#006479;" />
              <span class="text-xs leading-relaxed" style="color:#326177;">I agree that my contact info and listing details will be publicly visible. My email will only be used for listing management. <span class="req">*</span></span>
            </label>
            <label class="flex items-start gap-3 cursor-pointer">
              <input type="checkbox" name="safety" class="mt-0.5 w-4 h-4 rounded" style="accent-color:#006479;" />
              <span class="text-xs leading-relaxed" style="color:#326177;">I understand that BKK SONGKRAN is not responsible for any transactions. I will verify tickets and meet in safe, public places. <span class="req">*</span></span>
            </label>
          </div>
          <button type="submit" id="submit-btn" class="btn-primary w-full px-6 py-3 text-sm">
            <span class="material-symbols-outlined text-base" style="font-variation-settings:'FILL' 1;">send</span>
            Post Listing
          </button>
        </form>
      </div>
    </div>
  </section>

  <!-- DISCLAIMER -->
  <section class="px-6 pb-12">
    <div class="max-w-7xl mx-auto">
      <div class="p-4 rounded-xl text-xs" style="background:rgba(255,243,199,0.6);border:1px solid rgba(255,159,10,0.3);color:#7A5A00;">
        <span class="material-symbols-outlined text-sm align-middle mr-1" style="font-variation-settings:'FILL' 1;">info</span>
        <strong>Disclaimer:</strong> BKK SONGKRAN is not responsible for transactions. Always verify tickets before paying. Meet in public places. Use common sense.
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .filter-btn { padding:0.4rem 0.75rem;border-radius:0.5rem;font-size:0.75rem;font-weight:700;color:#326177;transition:all 0.2s;display:flex;align-items:center;gap:0.25rem;cursor:pointer;background:transparent;border:none; }
  .filter-btn:hover { color:#006479; }
  .filter-btn.active { background:linear-gradient(135deg,#006479,#40cef3);color:#fff; }
  .form-input { width:100%;padding:0.75rem 1rem;border-radius:0.75rem;font-size:0.875rem;font-weight:500;outline:none;background:rgba(225,243,255,0.7);border:1.5px solid rgba(192,232,255,0.8);color:#003345;transition:border-color 0.2s; }
  .form-input:focus { border-color:#006479; }
  .form-input.error { border-color:#FF3B30;background:rgba(255,232,232,0.3); }
  .form-label { display:block;font-size:0.75rem;font-weight:700;text-transform:uppercase;letter-spacing:0.05em;margin-bottom:0.5rem;color:#326177; }
  .req { color:#b31b25;font-weight:700; }
  .modal-overlay { position:fixed;inset:0;z-index:60; }
  .modal-backdrop { position:fixed;inset:0;background:rgba(0,30,50,0.6);backdrop-filter:blur(8px);-webkit-backdrop-filter:blur(8px); }
  .modal-scroll { position:fixed;inset:0;overflow-y:auto; }
  .modal-center { min-height:100%;display:flex;align-items:center;justify-content:center;padding:2rem 1rem; }
  .modal-card { position:relative;z-index:1; }
  .cs-wrap { position:relative; }
  .cs-trigger .cs-label { white-space:nowrap;overflow:hidden;text-overflow:ellipsis; }
  .cs-menu { display:none;position:absolute;top:calc(100% + 4px);left:0;right:0;z-index:30;background:#fff;border-radius:0.75rem;border:1.5px solid rgba(192,232,255,0.8);box-shadow:0 8px 24px rgba(0,51,69,0.12);overflow:hidden; }
  .cs-wrap.open .cs-menu { display:block; }
  .cs-wrap.open .cs-trigger { border-color:#006479; }
  .cs-wrap.open .cs-trigger .material-symbols-outlined { transform:rotate(180deg); }
  .cs-item { padding:0.625rem 1rem;font-size:0.875rem;font-weight:500;color:#003345;cursor:pointer;transition:background 0.15s; }
  .cs-item:hover { background:rgba(225,243,255,0.8); }
  .cs-item.active { background:rgba(0,100,121,0.08);color:#006479;font-weight:700; }
</style>

<script>
(window as any).__unlockTurnstileId = null;

const FC: Record<string,{c:string;d:string}> = {
  'S2O':           {c:'#40cef3',d:'#006479'},
  'Siam Songkran': {c:'#ff8eb2',d:'#b4005d'},
  'GCircuit':      {c:'#c084fc',d:'#7c3aed'},
};
const CI: Record<string,string> = { telegram:'send', line:'chat', whatsapp:'call', instagram:'photo_camera' };

let tickets: any[] = [];
let fType = 'all', fFest = 'all';

function getRevealed(): Record<string,{contact:string;contact_type:string}> {
  try { return JSON.parse(localStorage.getItem('revealed_tickets') || '{}'); } catch { return {}; }
}
function saveRevealed(r: Record<string,{contact:string;contact_type:string}>) {
  localStorage.setItem('revealed_tickets', JSON.stringify(r));
}
function getStoredEmail(): string {
  return localStorage.getItem('reveal_email') || '';
}
function saveStoredEmail(email: string) {
  localStorage.setItem('reveal_email', email);
}

// Custom selects
const csValues: Record<string,string> = { tier: 'GA' };
document.querySelectorAll('.cs-wrap').forEach(wrap => {
  const name = wrap.getAttribute('data-cs-name')!;
  const trigger = wrap.querySelector('.cs-trigger')!;
  const label = wrap.querySelector('.cs-label')!;
  const items = wrap.querySelectorAll('.cs-item');
  if (wrap.getAttribute('data-cs-default')) csValues[name] = wrap.getAttribute('data-cs-default')!;
  trigger.addEventListener('click', (e) => {
    e.stopPropagation();
    document.querySelectorAll('.cs-wrap.open').forEach(w => { if (w !== wrap) w.classList.remove('open'); });
    wrap.classList.toggle('open');
  });
  items.forEach(item => {
    item.addEventListener('click', (e) => {
      e.stopPropagation();
      const val = item.getAttribute('data-val')!;
      csValues[name] = val;
      label.textContent = item.textContent;
      (label as HTMLElement).style.color = '#003345';
      items.forEach(i => i.classList.remove('active'));
      item.classList.add('active');
      wrap.classList.remove('open');
    });
  });
});
document.addEventListener('click', () => {
  document.querySelectorAll('.cs-wrap.open').forEach(w => w.classList.remove('open'));
});

// Filters
document.querySelectorAll('[data-filter-type]').forEach(btn => {
  btn.addEventListener('click', () => {
    fType = btn.getAttribute('data-filter-type')!;
    document.querySelectorAll('[data-filter-type]').forEach(b => b.classList.toggle('active', b === btn));
    render();
  });
});
document.querySelectorAll('[data-filter-fest]').forEach(btn => {
  btn.addEventListener('click', () => {
    fFest = btn.getAttribute('data-filter-fest')!;
    document.querySelectorAll('[data-filter-fest]').forEach(b => b.classList.toggle('active', b === btn));
    render();
  });
});

// Form toggle
const postSection = document.getElementById('post-modal')!;
const listingsSection = document.querySelector('#listings-grid')!.closest('section')!;
const filtersSection = document.querySelector('[data-filter-type]')!.closest('section')!;
const unlockBanner = document.getElementById('unlock-banner')!;
const headerBtn = document.getElementById('btn-open-form')!;

function openForm() {
  postSection.classList.remove('hidden');
  listingsSection.classList.add('hidden');
  filtersSection.classList.add('hidden');
  unlockBanner.classList.add('hidden');
  headerBtn.classList.add('hidden');
  postSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
}
function closeFormView() {
  postSection.classList.add('hidden');
  listingsSection.classList.remove('hidden');
  filtersSection.classList.remove('hidden');
  if (Object.keys(getRevealed()).length === 0) unlockBanner.classList.remove('hidden');
  headerBtn.classList.remove('hidden');
}
document.getElementById('btn-open-form')!.addEventListener('click', openForm);
document.getElementById('close-form-btn')!.addEventListener('click', closeFormView);

// Unlock modal
function openUnlockModal() {
  document.getElementById('unlock-modal')!.classList.remove('hidden');
  document.body.style.overflow = 'hidden';
  initUnlockTurnstile();
}
function closeUnlockModal() {
  document.getElementById('unlock-modal')!.classList.add('hidden');
  document.body.style.overflow = '';
}
document.getElementById('btn-unlock-contacts')!.addEventListener('click', openUnlockModal);
document.getElementById('unlock-close-btn')!.addEventListener('click', closeUnlockModal);
document.getElementById('unlock-modal-backdrop')!.addEventListener('click', closeUnlockModal);

// Success modal
document.getElementById('success-close-btn')!.addEventListener('click', () => {
  document.getElementById('success-modal')!.classList.add('hidden');
  document.body.style.overflow = '';
});
document.querySelector('#success-modal .modal-backdrop')!.addEventListener('click', () => {
  document.getElementById('success-modal')!.classList.add('hidden');
  document.body.style.overflow = '';
});
document.getElementById('copy-link-btn')!.addEventListener('click', () => {
  const link = document.getElementById('delete-link-display')!.textContent || '';
  navigator.clipboard.writeText(link).then(() => {
    const btn = document.getElementById('copy-link-btn')!;
    btn.textContent = 'Copied!';
    setTimeout(() => {
      btn.textContent = '';
      const ic = document.createElement('span');
      ic.className = 'material-symbols-outlined text-base';
      ic.textContent = 'content_copy';
      btn.appendChild(ic);
      btn.appendChild(document.createTextNode(' Copy Delete Link'));
    }, 1500);
  });
});

// Unlock contacts
const unlockBtn = document.getElementById('unlock-btn')!;
const unlockEmailEl = document.getElementById('unlock-email') as HTMLInputElement;
const unlockError = document.getElementById('unlock-error')!;

if (Object.keys(getRevealed()).length > 0) unlockBanner.classList.add('hidden');

function initUnlockTurnstile() {
  if ((window as any).__unlockTurnstileId !== null && (window as any).__unlockTurnstileId !== undefined) return;
  if ((window as any).turnstile) {
    (window as any).__unlockTurnstileId = (window as any).turnstile.render('#turnstile-unlock', {
      sitekey: '0x4AAAAAACxlzbfzLTTpR49t',
      theme: 'light',
      size: 'normal',
    });
  }
}

unlockBtn.addEventListener('click', async () => {
  const email = unlockEmailEl.value.trim();
  unlockError.classList.add('hidden');
  if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
    unlockError.textContent = 'Please enter a valid email address';
    unlockError.classList.remove('hidden');
    return;
  }
  const tsId = (window as any).__unlockTurnstileId;
  const turnstileToken = (tsId !== undefined && tsId !== null && (window as any).turnstile)
    ? (window as any).turnstile.getResponse(tsId) || ''
    : '';
  if (!turnstileToken) {
    unlockError.textContent = 'Please complete the security check';
    unlockError.classList.remove('hidden');
    return;
  }
  unlockBtn.textContent = '...';
  unlockBtn.setAttribute('disabled', 'true');
  try {
    const res = await fetch('/api/reveal', {
      method: 'POST',
      headers: {'Content-Type':'application/json'},
      body: JSON.stringify({ email, turnstileToken }),
    });
    const data = await res.json();
    if (!res.ok) {
      unlockError.textContent = data.error || 'Failed to unlock. Try again.';
      unlockError.classList.remove('hidden');
      const _tsId = (window as any).__unlockTurnstileId;
      if (_tsId !== null && _tsId !== undefined && (window as any).turnstile) (window as any).turnstile.reset(_tsId);
    } else {
      saveRevealed(data.contacts || {});
      saveStoredEmail(email);
      closeUnlockModal();
      unlockBanner.classList.add('hidden');
      render();
    }
  } catch {
    unlockError.textContent = 'Connection error. Try again.';
    unlockError.classList.remove('hidden');
  }
  unlockBtn.textContent = 'Unlock';
  unlockBtn.removeAttribute('disabled');
});

// Submit form
document.getElementById('ticket-form')!.addEventListener('submit', async (e) => {
  e.preventDefault();
  const form = e.target as HTMLFormElement;
  const btn = document.getElementById('submit-btn')!;
  btn.setAttribute('disabled', 'true');
  btn.textContent = 'Posting...';

  const fd = Object.fromEntries(new FormData(form));
  fd.festival = csValues.festival || '';
  fd.dates = csValues.dates || '';
  fd.tier = csValues.tier || 'GA';

  const errBanner = document.getElementById('form-errors')!;
  form.querySelectorAll('.error').forEach(el => el.classList.remove('error'));
  errBanner.classList.add('hidden');

  const errors: string[] = [];
  if (!fd.festival) { errors.push('Select a festival'); document.querySelector('[data-cs-name="festival"] .cs-trigger')?.classList.add('error'); }
  if (!fd.dates) { errors.push('Select a date'); document.querySelector('[data-cs-name="dates"] .cs-trigger')?.classList.add('error'); }
  if (!fd.price || Number(fd.price) <= 0) { errors.push('Enter a price'); form.querySelector('[name="price"]')?.classList.add('error'); }
  if (!fd.contact) { errors.push('Enter contact info'); form.querySelector('[name="contact"]')?.classList.add('error'); }
  if (!fd.email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(fd.email as string)) { errors.push('Enter a valid email'); form.querySelector('[name="email"]')?.classList.add('error'); }
  if (!fd.gdpr) errors.push('Accept the data visibility agreement');
  if (!fd.safety) errors.push('Accept the safety disclaimer');

  if (errors.length) {
    errBanner.textContent = errors.join(' · ');
    errBanner.classList.remove('hidden');
    errBanner.scrollIntoView({ behavior: 'smooth', block: 'center' });
    btn.removeAttribute('disabled');
    btn.textContent = '';
    const ic = document.createElement('span'); ic.className='material-symbols-outlined text-base'; ic.style.fontVariationSettings="'FILL' 1"; ic.textContent='send'; btn.appendChild(ic); btn.appendChild(document.createTextNode(' Post Listing'));
    return;
  }

  delete fd.gdpr;
  delete fd.safety;

  try {
    const res = await fetch('/api/tickets', { method: 'POST', headers: {'Content-Type':'application/json'}, body: JSON.stringify(fd) });
    const data = await res.json();
    if (!res.ok) throw new Error(data.error || 'Failed');

    form.reset();
    document.querySelectorAll('.cs-wrap').forEach(w => {
      const lbl = w.querySelector('.cs-label') as HTMLElement;
      const n = w.getAttribute('data-cs-name')!;
      if (n === 'tier') { lbl.textContent = 'GA (General)'; lbl.style.color = '#003345'; }
      else { lbl.textContent = n === 'festival' ? 'Select festival...' : 'Select...'; lbl.style.color = '#86b3cc'; }
      w.querySelectorAll('.cs-item').forEach(i => i.classList.remove('active'));
      if (n === 'tier') w.querySelector('[data-val="GA"]')?.classList.add('active');
      delete csValues[n];
    });
    csValues.tier = 'GA';
    closeFormView();
    await load();

    const deleteLink = `${location.origin}/api/tickets?id=${encodeURIComponent(data.id)}&token=${encodeURIComponent(data.deleteToken)}`;
    document.getElementById('delete-link-display')!.textContent = deleteLink;
    document.getElementById('success-modal')!.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
  } catch (err: any) {
    alert(err.message || 'Something went wrong. Try again.');
  }

  btn.removeAttribute('disabled');
  btn.textContent = '';
  const icon = document.createElement('span');
  icon.className = 'material-symbols-outlined text-base';
  icon.style.fontVariationSettings = "'FILL' 1";
  icon.textContent = 'send';
  btn.appendChild(icon);
  btn.appendChild(document.createTextNode(' Post Listing'));
});

// Load & render
async function load() {
  try { tickets = await (await fetch('/api/tickets')).json(); } catch { tickets = []; }
  render();
}

function render() {
  const grid = document.getElementById('listings-grid')!;
  const empty = document.getElementById('empty-state')!;
  const tpl = document.getElementById('ticket-card-tpl') as HTMLTemplateElement;

  let list = tickets;
  if (fType !== 'all') list = list.filter((t:any) => t.type === fType);
  if (fFest !== 'all') list = list.filter((t:any) => t.festival === fFest);

  document.getElementById('listing-count')!.textContent = `${list.length} listing${list.length!==1?'s':''}`;
  grid.replaceChildren();

  if (!list.length) { empty.classList.remove('hidden'); return; }
  empty.classList.add('hidden');

  const revealed = getRevealed();

  list.forEach((t:any) => {
    const fc = FC[t.festival] || {c:'#40cef3',d:'#006479'};
    const sell = t.type === 'selling';
    const clone = tpl.content.cloneNode(true) as DocumentFragment;

    (clone.querySelector('.tpl-bar') as HTMLElement).style.background = `linear-gradient(90deg,${fc.d},${fc.c})`;

    const tb = clone.querySelector('.tpl-type-badge') as HTMLElement;
    tb.style.cssText = `background:${sell?'#E8FFF0':'#E8F4FF'};color:${sell?'#1A7A3A':'#006479'};border:1px solid ${sell?'#34C759':'#40cef3'};`;
    const ti = document.createElement('span');
    ti.className = 'material-symbols-outlined text-xs';
    ti.style.fontVariationSettings = "'FILL' 1";
    ti.textContent = sell ? 'sell' : 'shopping_cart';
    tb.appendChild(ti);
    tb.appendChild(document.createTextNode(sell ? ' Selling' : ' Buying'));

    const fb = clone.querySelector('.tpl-fest-badge') as HTMLElement;
    fb.style.cssText = `background:${fc.c}15;color:${fc.d};`;
    fb.textContent = t.festival;

    (clone.querySelector('.tpl-time') as HTMLElement).textContent = ago(t.created_at);
    (clone.querySelector('.tpl-meta') as HTMLElement).textContent = `${t.dates} · ${t.tier}`;
    const pe = clone.querySelector('.tpl-price') as HTMLElement;
    pe.style.color = fc.d;
    pe.textContent = `฿${Number(t.price).toLocaleString()}`;
    (clone.querySelector('.tpl-qty') as HTMLElement).textContent = `${t.quantity} ticket${t.quantity>1?'s':''}`;

    const ne = clone.querySelector('.tpl-note') as HTMLElement;
    if (t.note) { ne.textContent = t.note; ne.classList.remove('hidden'); }

    const lockedEl = clone.querySelector('.tpl-contact-locked') as HTMLElement;
    const revealedEl = clone.querySelector('.tpl-contact-revealed') as HTMLElement;
    const rev = revealed[t.id];

    if (rev) {
      lockedEl.classList.add('hidden');
      revealedEl.classList.remove('hidden');
      const ci = revealedEl.querySelector('.tpl-contact-icon') as HTMLElement;
      ci.textContent = CI[rev.contact_type] || 'link';
      ci.style.color = fc.d;
      (revealedEl.querySelector('.tpl-contact') as HTMLElement).textContent = rev.contact;
      const ct = revealedEl.querySelector('.tpl-contact-type') as HTMLElement;
      ct.textContent = rev.contact_type;
      ct.style.cssText = `background:${fc.c}15;color:${fc.d};`;
    }

    const copyBtn = clone.querySelector('.tpl-copy-btn') as HTMLElement;
    copyBtn.addEventListener('click', () => {
      const contact = (copyBtn.closest('.tpl-contact-revealed')?.querySelector('.tpl-contact') as HTMLElement)?.textContent || '';
      navigator.clipboard.writeText(contact).then(() => {
        const icon = copyBtn.querySelector('.material-symbols-outlined')!;
        icon.textContent = 'check';
        setTimeout(() => { icon.textContent = 'content_copy'; }, 1500);
      });
    });

    grid.appendChild(clone);
  });
}

function ago(d:string) {
  const ms = Date.now() - new Date(d).getTime();
  const m = Math.floor(ms/60000);
  if (m < 60) return `${m}m ago`;
  const h = Math.floor(m/60);
  if (h < 24) return `${h}h ago`;
  return `${Math.floor(h/24)}d ago`;
}

// On load, silently re-fetch contacts if previously unlocked (picks up new listings)
async function autoRefreshContacts() {
  const email = getStoredEmail();
  if (!email) return;
  try {
    const res = await fetch('/api/reveal', {
      method: 'POST',
      headers: {'Content-Type':'application/json'},
      body: JSON.stringify({ email }),
    });
    if (res.ok) {
      const data = await res.json();
      saveRevealed(data.contacts || {});
      render();
    }
  } catch {}
}

load().then(() => autoRefreshContacts());
</script>

