---
import BaseLayout from '../../components/layout/BaseLayout.astro';
import { articles } from '../../data/articles';
---

<BaseLayout
  title="Songkran 2026 Guide — Bangkok Festival Tips & Articles"
  description="All our guides, tips, and articles about Songkran 2026 in Bangkok. S2O, Siam Songkran, GCircuit, survival tips, water fights and more."
  canonical="https://bkksongkran.com/blog"
>

  <!-- SEO structured data -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Blog",
    "name": "Bangkok Songkran Guide",
    "description": "The complete guide to Songkran 2026 in Bangkok. Articles, tips, and everything you need to know about Thailand's water festival.",
    "url": "https://bkksongkran.com/blog",
    "blogPost": articles.map(a => ({
      "@type": "BlogPosting",
      "headline": a.title,
      "description": a.metaDescription,
      "datePublished": a.publishedDate,
      "dateModified": a.modifiedDate,
      "url": `https://bkksongkran.com/blog/${a.slug}`,
    })),
  })} />

  <!-- HEADER -->
  <section class="pt-36 pb-16 px-6" style="background:linear-gradient(180deg,rgba(225,243,255,0.8),rgba(238,248,255,0));">
    <div class="max-w-7xl mx-auto">
      <div class="text-xs font-bold tracking-[0.2em] uppercase mb-3" style="color:#006479;">Songkran Knowledge Base</div>
      <h1 class="font-headline font-extrabold tracking-tighter mb-4" style="font-size:clamp(3rem,8vw,6rem);color:#003345;line-height:0.9;">
        SONGKRAN<br/>
        <span style="background:linear-gradient(135deg,#006479,#40cef3);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;">GUIDE</span>
      </h1>
      <p class="text-lg max-w-2xl" style="color:#326177;">Everything you need to know about Thailand's water festival. Written by locals, updated for 2026.</p>
    </div>
  </section>

  <!-- FEATURED ARTICLE -->
  <section class="px-6 pb-8">
    <div class="max-w-7xl mx-auto">
      <a href={`/blog/${articles[0].slug}`} class="block group">
        <div class="card overflow-hidden relative" style="min-height:280px;">
          <div class="absolute inset-0">
            <img src={articles[0].featuredImage} alt={articles[0].title} width="1200" height="630" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" loading="lazy" />
            <div class="absolute inset-0" style="background:linear-gradient(to top,rgba(0,20,35,0.95) 0%,rgba(0,25,40,0.7) 50%,rgba(0,20,35,0.5) 100%);"></div>
          </div>
          <div class="relative p-8 flex flex-col justify-end" style="min-height:280px;">
            <span class="inline-block px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-wider mb-3 self-start" style={`background:${articles[0].categoryColor}30;color:${articles[0].categoryColor};border:1px solid ${articles[0].categoryColor}40;`}>
              {articles[0].category}
            </span>
            <h2 class="font-headline font-extrabold text-2xl md:text-3xl text-white mb-2 leading-tight" style="text-shadow:0 2px 12px rgba(0,0,0,0.6);">{articles[0].title}</h2>
            <p class="text-sm text-white max-w-lg">{articles[0].excerpt}</p>
            <div class="flex items-center gap-4 mt-3 text-xs text-white/80">
              <span>{articles[0].readTime} min read</span>
              <span>Updated {new Date(articles[0].modifiedDate).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</span>
            </div>
          </div>
        </div>
      </a>
    </div>
  </section>

  <!-- ALL ARTICLES GRID -->
  <section class="px-6 pb-20">
    <div class="max-w-7xl mx-auto">
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
        {articles.slice(1).map(article => (
          <a href={`/blog/${article.slug}`} class="card p-0 overflow-hidden group block">
            <div class="h-1.5 w-full" style={`background:${article.categoryColor};`}></div>
            <div class="p-5 space-y-3">
              <div class="flex items-center gap-2">
                <span class="inline-block px-2.5 py-0.5 rounded-full text-[10px] font-bold uppercase tracking-wider" style={`background:${article.categoryColor}15;color:${article.categoryColor};`}>
                  {article.category}
                </span>
                <span class="text-[10px] font-medium" style="color:#86b3cc;">{article.readTime} min</span>
              </div>
              <h3 class="font-headline font-bold text-base leading-snug group-hover:text-primary transition-colors" style="color:#003345;">{article.title}</h3>
              <p class="text-xs leading-relaxed line-clamp-2" style="color:#326177;">{article.excerpt}</p>
              <div class="flex items-center gap-1 text-xs font-bold group-hover:gap-2 transition-all" style="color:#006479;">
                Read article
                <span class="material-symbols-outlined text-sm transition-transform group-hover:translate-x-1">arrow_forward</span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ Section for SEO -->
  <section class="px-6 pb-20">
    <div class="max-w-7xl mx-auto">
      <h2 class="font-headline font-extrabold text-2xl mb-6" style="color:#003345;">Frequently Asked Questions</h2>
      <div class="space-y-4">
        {[
          { q: 'What is Songkran festival?', a: 'Songkran is Thailand\'s New Year festival celebrated every April 13-15. It\'s known as the world\'s largest water fight, but it\'s also a meaningful Buddhist holiday about renewal, family, and cleansing.' },
          { q: 'When is Songkran 2026?', a: 'Songkran 2026 officially runs April 13-15 (Sunday-Tuesday), with many events starting as early as April 10. The main street water fights happen April 13-15.' },
          { q: 'Where is the best place to celebrate Songkran in Bangkok?', a: 'The top spots are Silom Road (LGBTQ+ friendly, incredible energy), Khao San Road (backpacker chaos), and Siam Square (young local crowd). For music festivals, check out S2O, Siam Songkran, or GCircuit.' },
          { q: 'How long does Songkran last?', a: 'Officially 3 days (April 13-15), but practically 5-7 days with pre-events starting April 10 in Bangkok. Pattaya extends it to April 19 with the Wan Lai Festival.' },
          { q: 'Are shops open during Songkran?', a: 'Major shopping malls and 7-Elevens stay open. Banks close April 13-15. Restaurants in tourist areas remain open. Plan cash withdrawal before April 12.' },
          { q: 'Is Songkran safe?', a: 'Yes, Songkran is generally safe. Use waterproof bags for electronics, wear water-safe shoes, stay hydrated, use sunscreen, and avoid driving. Use BTS/MRT instead of taxis.' },
        ].map(faq => (
          <details class="card p-0 overflow-hidden group">
            <summary class="p-5 cursor-pointer flex items-center justify-between font-bold text-sm hover:bg-primary/5 transition-colors" style="color:#003345;">
              {faq.q}
              <span class="material-symbols-outlined text-base transition-transform group-open:rotate-180" style="color:#86b3cc;">expand_more</span>
            </summary>
            <div class="px-5 pb-5 text-sm leading-relaxed" style="color:#326177;">{faq.a}</div>
          </details>
        ))}
      </div>

      <!-- FAQ Schema -->
      <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "FAQPage",
        "mainEntity": [
          { "@type": "Question", "name": "What is Songkran festival?", "acceptedAnswer": { "@type": "Answer", "text": "Songkran is Thailand's New Year festival celebrated every April 13-15. It's known as the world's largest water fight, but it's also a meaningful Buddhist holiday about renewal, family, and cleansing." }},
          { "@type": "Question", "name": "When is Songkran 2026?", "acceptedAnswer": { "@type": "Answer", "text": "Songkran 2026 officially runs April 13-15 (Sunday-Tuesday), with many events starting as early as April 10." }},
          { "@type": "Question", "name": "Where is the best place to celebrate Songkran in Bangkok?", "acceptedAnswer": { "@type": "Answer", "text": "The top spots are Silom Road (LGBTQ+ friendly), Khao San Road (backpacker chaos), and Siam Square (young local crowd). For music festivals, check out S2O, Siam Songkran, or GCircuit." }},
          { "@type": "Question", "name": "How long does Songkran last?", "acceptedAnswer": { "@type": "Answer", "text": "Officially 3 days (April 13-15), but practically 5-7 days with pre-events starting April 10 in Bangkok." }},
          { "@type": "Question", "name": "Are shops open during Songkran?", "acceptedAnswer": { "@type": "Answer", "text": "Major shopping malls and 7-Elevens stay open. Banks close April 13-15. Restaurants in tourist areas remain open." }},
        ]
      })} />
    </div>
  </section>

</BaseLayout>
