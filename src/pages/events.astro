---
import BaseLayout from '../components/layout/BaseLayout.astro';
import FestivalSchedule from '../components/organisms/FestivalSchedule.astro';
import Breadcrumb from '../components/atoms/Breadcrumb.astro';
import { festivals, additionalEvents, waterFightZones, partyEvents } from '../data/index';

const ticketedEvents = additionalEvents.filter(e => e.type === 'festival');
const freeEvents = additionalEvents.filter(e => e.type !== 'festival');

const intensityConfig = {
  insane: { label: 'INSANE', color: '#FF3B30', bg: '#FFE8E8', icon: 'whatshot' },
  high:   { label: 'HIGH', color: '#FF9F0A', bg: '#FFF8E0', icon: 'local_fire_department' },
  medium: { label: 'CHILL', color: '#34C759', bg: '#E8FFF0', icon: 'spa' },
};

// ── JSON-LD Event schema helpers ───────────────
// Map abbreviated date strings like "Apr 11–13" or "Apr 10–11" to ISO dates.
// All events are in 2026.
const MONTH_MAP: Record<string, string> = {
  Jan: '01', Feb: '02', Mar: '03', Apr: '04', May: '05', Jun: '06',
  Jul: '07', Aug: '08', Sep: '09', Oct: '10', Nov: '11', Dec: '12',
};

function parseDateRange(dates: string): { startDate: string; endDate: string } {
  // e.g. "Apr 11–13", "Apr 10–15", "Apr 14", "Apr 9–30", "Apr 9–14"
  const match = dates.match(/^(\w+)\s+(\d+)(?:[–\-](\d+))?/);
  if (!match) return { startDate: '2026-04-10', endDate: '2026-04-14' };
  const month = MONTH_MAP[match[1]] ?? '04';
  const startDay = match[2].padStart(2, '0');
  // If range end day crosses into next month it would need extra logic — all events stay in April here.
  const endDay = (match[3] ?? match[2]).padStart(2, '0');
  return {
    startDate: `2026-${month}-${startDay}`,
    endDate:   `2026-${month}-${endDay}`,
  };
}

const festivalSchemas = festivals.map(f => {
  const { startDate, endDate } = parseDateRange(f.dates);
  return {
    '@type': 'Event',
    name: f.name,
    description: f.description,
    startDate,
    endDate,
    eventStatus: 'https://schema.org/EventScheduled',
    eventAttendanceMode: 'https://schema.org/OfflineEventAttendanceMode',
    location: {
      '@type': 'Place',
      name: f.venue,
      address: {
        '@type': 'PostalAddress',
        addressLocality: 'Bangkok',
        addressCountry: 'TH',
      },
    },
    url: 'https://bkksongkran.com/events',
    ...(f.url ? { sameAs: f.url } : {}),
    organizer: {
      '@type': 'Organization',
      name: f.name,
      url: f.url ?? 'https://bkksongkran.com/events',
    },
  };
});

const additionalSchemas = additionalEvents.map(e => {
  const { startDate, endDate } = parseDateRange(e.dates);
  return {
    '@type': 'Event',
    name: e.name,
    description: e.desc,
    startDate,
    endDate,
    eventStatus: 'https://schema.org/EventScheduled',
    eventAttendanceMode: 'https://schema.org/OfflineEventAttendanceMode',
    location: {
      '@type': 'Place',
      name: e.venue,
      address: {
        '@type': 'PostalAddress',
        addressLocality: 'Bangkok',
        addressCountry: 'TH',
      },
    },
    url: 'https://bkksongkran.com/events',
    isAccessibleForFree: e.price === 'Free',
  };
});

const eventSchema = {
  '@context': 'https://schema.org',
  '@graph': [...festivalSchemas, ...additionalSchemas],
};
---

<BaseLayout title="Songkran 2026 Events & Timetables — All Festivals, Lineups & Tickets" description="Complete Songkran 2026 event calendar. S2O, Siam Songkran, GCircuit lineups with day-by-day schedules. Water fight zones and free events in Bangkok." canonical="https://bkksongkran.com/events">

  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(eventSchema)} />
  </Fragment>

  <!-- HEADER -->
  <section class="pt-36 pb-16 px-6" style="background:linear-gradient(180deg,rgba(225,243,255,0.8),rgba(238,248,255,0));">
    <div class="max-w-7xl mx-auto">
      <Breadcrumb crumbs={[{ label: "Home", href: "/" }, { label: "Events" }]} />
      <div class="text-xs font-bold tracking-[0.2em] uppercase mb-3" style="color:#b4005d;">Festival Calendar</div>
      <h1 class="font-headline font-extrabold tracking-tighter mb-4" style="font-size:clamp(3rem,8vw,6rem);color:#003345;line-height:0.9;">
        ALL THE<br/>
        <span style="background:linear-gradient(135deg,#006479,#40cef3);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;">SPLASH EVENTS</span>
      </h1>
      <p class="text-lg max-w-2xl" style="color:#326177;">Every festival, street party, water fight zone, and cultural event happening during Songkran 2026 in Bangkok.</p>

      <!-- Section jump links -->
      <div class="flex gap-3 flex-wrap mt-8 items-center">
        <a href="#headliners" class="flex items-center gap-2 px-5 py-2.5 rounded-full text-sm font-bold border-2 transition-all hover:scale-105" style="border-color:#006479;color:#006479;background:#00647915;">
          <span class="material-symbols-outlined text-sm" style="font-variation-settings:'FILL' 1;">star</span>
          Headliner Festivals
        </a>
        <a href="#party-events" class="flex items-center gap-2 px-5 py-2.5 rounded-full text-sm font-bold border-2 transition-all hover:scale-105" style="border-color:#b45309;color:#b45309;background:#f59e0b15;">
          <span class="material-symbols-outlined text-sm" style="font-variation-settings:'FILL' 1;">local_fire_department</span>
          Party Events
        </a>
        <a href="#water-fights" class="flex items-center gap-2 px-5 py-2.5 rounded-full text-sm font-bold border-2 transition-all hover:scale-105" style="border-color:#FF3B30;color:#FF3B30;background:#FF3B3015;">
          <span class="material-symbols-outlined text-sm" style="font-variation-settings:'FILL' 1;">water_drop</span>
          Water Fight Zones
        </a>
        <a href="#more-festivals" class="flex items-center gap-2 px-5 py-2.5 rounded-full text-sm font-bold border-2 transition-all hover:scale-105" style="border-color:#8B5CF6;color:#8B5CF6;background:#8B5CF615;">
          <span class="material-symbols-outlined text-sm" style="font-variation-settings:'FILL' 1;">music_note</span>
          More Festivals
        </a>
        <a href="#free-events" class="flex items-center gap-2 px-5 py-2.5 rounded-full text-sm font-bold border-2 transition-all hover:scale-105" style="border-color:#FF9F0A;color:#FF9F0A;background:#FF9F0A15;">
          <span class="material-symbols-outlined text-sm" style="font-variation-settings:'FILL' 1;">celebration</span>
          Free Events
        </a>
        <a href="/contact?type=feature-event" class="flex items-center gap-2 px-5 py-2.5 rounded-full text-sm font-bold border-2 transition-all hover:scale-105 ml-auto" style="border-color:rgba(192,232,255,0.8);color:#326177;background:white;">
          <span class="material-symbols-outlined text-sm" style="font-variation-settings:'FILL' 1;">add_circle</span>
          Feature your event
        </a>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════ -->
  <!-- HEADLINER FESTIVALS (with full schedules)  -->
  <!-- ═══════════════════════════════════════════ -->
  <section class="px-6 pb-20" id="headliners">
    <div class="max-w-7xl mx-auto">
      <div class="flex items-center gap-3 mb-10">
        <div class="w-10 h-10 rounded-xl flex items-center justify-center" style="background:#00647915;">
          <span class="material-symbols-outlined text-xl" style="color:#006479;font-variation-settings:'FILL' 1;">star</span>
        </div>
        <div>
          <h2 class="font-headline font-extrabold text-2xl tracking-tight" style="color:#003345;">Headliner Festivals</h2>
          <p class="text-xs" style="color:#6b8fa3;">Full lineups. Day by day. Set by set.</p>
        </div>
      </div>

      <!-- Festival jump links -->
      <div class="flex gap-3 flex-wrap mb-10">
        {festivals.map(f => (
          <a href={`#${f.id}`} class="flex items-center gap-2 px-5 py-2.5 rounded-full text-sm font-bold border-2 transition-all hover:scale-105"
             style={`border-color:${f.color};color:${f.colorDark};background:${f.color}15;`}>
            {f.name}
            <span class="text-[10px] font-bold px-2 py-0.5 rounded-full text-white" style={`background:${f.colorDark};`}>{f.dates}</span>
          </a>
        ))}
      </div>

      <div class="space-y-20">
        {festivals.map(festival => (
          <div id={festival.id} class="scroll-mt-28">
            <!-- Banner -->
            <div class="rounded-2xl overflow-hidden mb-8 relative" style={`background:linear-gradient(135deg,${festival.colorDark},${festival.color});min-height:180px;`}>
              <div class="absolute inset-0 opacity-10" style="background:radial-gradient(circle at 80% 50%,rgba(255,255,255,0.5) 0,transparent 60%);"></div>
              <div class="relative p-8 flex flex-col md:flex-row md:items-center justify-between gap-6">
                <div>
                  <div class="text-xs font-bold uppercase tracking-widest mb-2 text-white opacity-70">
                    {festival.type === 'circuit' ? 'LGBTQ+ Circuit Festival' : 'EDM Festival'}
                  </div>
                  <h2 class="font-headline text-3xl md:text-4xl font-black text-white">{festival.name}</h2>
                  <p class="text-white opacity-80 font-medium italic mt-1">{festival.tagline}</p>
                  <div class="flex flex-wrap gap-4 mt-4">
                    {[{icon:'calendar_month',text:festival.dates+', 2026'},{icon:'location_on',text:festival.venue}].map(m => (
                      <span class="flex items-center gap-1.5 text-sm font-semibold text-white opacity-85">
                        <span class="material-symbols-outlined text-base" style="font-variation-settings:'FILL' 1;">{m.icon}</span>
                        {m.text}
                      </span>
                    ))}
                  </div>
                </div>
                <a href={festival.url} target="_blank" rel="noopener noreferrer"
                   class="inline-flex items-center justify-center gap-2 px-6 py-3 rounded-full font-bold text-sm transition-all hover:scale-105 self-start"
                   style={`background:#fff;color:${festival.colorDark};`}>
                  <span class="material-symbols-outlined text-base" style="font-variation-settings:'FILL' 1;">confirmation_number</span>
                  Buy Tickets
                </a>
              </div>
            </div>

            <!-- Schedule -->
            <div class="card p-6 md:p-8">
              <FestivalSchedule festival={festival} />
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════ -->
  <!-- COMMUNITY & PARTY EVENTS                   -->
  <!-- ═══════════════════════════════════════════ -->
  {partyEvents.length > 0 && (
    <section class="px-6 pb-20" id="party-events">
      <div class="max-w-7xl mx-auto">
        <div class="flex items-center gap-3 mb-10">
          <div class="w-10 h-10 rounded-xl flex items-center justify-center" style="background:#f59e0b15;">
            <span class="material-symbols-outlined text-xl" style="color:#b45309;font-variation-settings:'FILL' 1;">local_fire_department</span>
          </div>
          <div>
            <h2 class="font-headline font-extrabold text-2xl tracking-tight" style="color:#003345;">Community & Party Events</h2>
            <p class="text-xs" style="color:#6b8fa3;">Independent parties, community nights and more.</p>
          </div>
        </div>

        <!-- Day filter tabs -->
        <div class="flex gap-2 mb-8 flex-wrap" id="party-day-filter">
          {[
            { day: 'all', label: 'All Events' },
            { day: '10',  label: 'Fri Apr 10' },
            { day: '11',  label: 'Sat Apr 11' },
            { day: '12',  label: 'Sun Apr 12' },
            { day: '13',  label: 'Mon Apr 13' },
            { day: '14',  label: 'Tue Apr 14' },
          ].map(({ day, label }) => (
            <button
              class="party-day-btn text-sm font-bold px-4 py-2 rounded-full border-2 transition-all hover:scale-105"
              data-day={day}
              style={day === 'all'
                ? 'border-color:#b45309;color:#b45309;background:#f59e0b20;'
                : 'border-color:#d0e8ff;color:#326177;background:white;'}
            >
              {label}
            </button>
          ))}
        </div>

        <div class="space-y-6" id="party-events-list">
          {partyEvents.map(event => (
            <div class="rounded-2xl overflow-hidden party-event-card" data-days={event.days.join(',')} style={`border:1px solid ${event.color}30;background:white;`}>
              <!-- Banner -->
              <div class="p-6 md:p-8" style={`background:linear-gradient(135deg,${event.colorDark},${event.color});`}>
                <div class="flex flex-col md:flex-row md:items-center justify-between gap-4">
                  <div>
                    <div class="flex items-center gap-2 mb-2">
                      <div class="text-xs font-bold uppercase tracking-widest text-white opacity-70">
                        {event.lgbtq ? 'LGBTQ+ Party' : 'Community Event'}
                      </div>
                      {event.lgbtq && (
                        <span class="text-[10px] font-bold px-2 py-0.5 rounded-full" style="background:rgba(255,255,255,0.2);color:#fff;letter-spacing:0.05em;">🏳️‍🌈 LGBTQ+</span>
                      )}
                    </div>
                    <h3 class="font-headline text-3xl md:text-4xl font-black text-white">{event.name}</h3>
                    <p class="text-white opacity-80 italic mt-1">{event.tagline}</p>
                    <div class="flex flex-wrap gap-4 mt-3">
                      <span class="flex items-center gap-1.5 text-sm font-semibold text-white opacity-85">
                        <span class="material-symbols-outlined text-base" style="font-variation-settings:'FILL' 1;">calendar_month</span>
                        {event.dates}, 2026 · {event.time}
                      </span>
                      <span class="flex items-center gap-1.5 text-sm font-semibold text-white opacity-85">
                        <span class="material-symbols-outlined text-base" style="font-variation-settings:'FILL' 1;">location_on</span>
                        {event.venue}
                      </span>
                    </div>
                  </div>
                  {event.ticketUrl && (
                    <a href={event.ticketUrl} target="_blank" rel="noopener noreferrer"
                       class="inline-flex items-center justify-center gap-2 px-6 py-3 rounded-full font-bold text-sm transition-all hover:scale-105 self-start flex-shrink-0"
                       style={`background:#fff;color:${event.colorDark};`}>
                      <span class="material-symbols-outlined text-base" style="font-variation-settings:'FILL' 1;">
                        {event.inviteOnly ? 'open_in_new' : 'confirmation_number'}
                      </span>
                      {event.inviteOnly ? 'Request Invite' : 'Buy Tickets'}
                    </a>
                  )}
                </div>
              </div>

              <!-- Details -->
              <div class="p-6 md:p-8 grid md:grid-cols-2 gap-6">
                <!-- Description + Stages -->
                <div class="space-y-4">
                  <p class="text-sm leading-relaxed" style="color:#326177;">{event.desc}</p>
                  {event.stages && (
                    <div>
                      <div class="text-[10px] font-bold uppercase tracking-widest mb-2" style={`color:${event.colorDark};`}>Stages</div>
                      <div class="flex flex-wrap gap-2">
                        {event.stages.map(stage => (
                          <span class="text-xs font-semibold px-3 py-1 rounded-full" style={`background:${event.color}15;color:${event.colorDark};border:1px solid ${event.color}30;`}>
                            {stage}
                          </span>
                        ))}
                      </div>
                    </div>
                  )}
                </div>

                <!-- DJ Lineup -->
                {event.lineup && (
                  <div>
                    <div class="text-[10px] font-bold uppercase tracking-widest mb-3" style={`color:${event.colorDark};`}>DJ Lineup</div>
                    <div class="flex flex-wrap gap-2">
                      {event.lineup.map(dj => (
                        <span class="text-sm font-bold px-3 py-1.5 rounded-full" style={`background:${event.color}12;color:${event.colorDark};border:1px solid ${event.color}25;`}>
                          {dj}
                        </span>
                      ))}
                    </div>
                  </div>
                )}
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <script>
    const btns = document.querySelectorAll<HTMLButtonElement>('.party-day-btn');
    const cards = document.querySelectorAll<HTMLElement>('.party-event-card');

    const ACTIVE = 'border-color:#b45309;color:#b45309;background:#f59e0b20;';
    const INACTIVE = 'border-color:#d0e8ff;color:#326177;background:white;';

    btns.forEach(btn => {
      btn.addEventListener('click', () => {
        const day = btn.dataset.day!;
        btns.forEach(b => { b.style.cssText = INACTIVE; });
        btn.style.cssText = ACTIVE;

        cards.forEach(card => {
          if (day === 'all') {
            card.style.display = '';
          } else {
            const days = (card.dataset.days ?? '').split(',');
            card.style.display = days.includes(day) ? '' : 'none';
          }
        });
      });
    });
  </script>

  <!-- ═══════════════════════════════════════════ -->
  <!-- WATER FIGHT ZONES                          -->
  <!-- ═══════════════════════════════════════════ -->
  <section class="px-6 pb-20" id="water-fights" style="background:rgba(255,240,240,0.3);">
    <div class="max-w-7xl mx-auto pt-16">
      <div class="flex items-center gap-3 mb-3">
        <div class="w-10 h-10 rounded-xl flex items-center justify-center" style="background:#FF3B3015;">
          <span class="material-symbols-outlined text-xl" style="color:#FF3B30;font-variation-settings:'FILL' 1;">water_drop</span>
        </div>
        <div>
          <h2 class="font-headline font-extrabold text-2xl tracking-tight" style="color:#003345;">Water Fight Zones</h2>
          <p class="text-xs" style="color:#6b8fa3;">Where to get absolutely soaked. Free, no tickets needed.</p>
        </div>
      </div>
      <p class="text-sm mb-10 max-w-2xl" style="color:#326177;">Bangkok transforms into a massive water battlefield during Songkran. These are the hottest (and wettest) spots — from full-on chaos to chill family-friendly zones.</p>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
        {waterFightZones.map(zone => {
          const intensity = intensityConfig[zone.intensity as keyof typeof intensityConfig];
          return (
            <div class="rounded-2xl overflow-hidden transition-all hover:shadow-lg" style={`border:1px solid ${zone.color}25;background:white;`}>
              <!-- Header bar -->
              <div class="p-5 flex items-start justify-between gap-3" style={`background:${zone.color}08;`}>
                <div>
                  <h3 class="font-headline font-extrabold text-lg" style="color:#003345;">{zone.name}</h3>
                  <div class="flex flex-wrap items-center gap-3 mt-1.5">
                    <span class="flex items-center gap-1 text-xs font-semibold" style="color:#6b8fa3;">
                      <span class="material-symbols-outlined text-xs">calendar_today</span> {zone.dates}
                    </span>
                    <span class="flex items-center gap-1 text-xs font-semibold" style="color:#6b8fa3;">
                      <span class="material-symbols-outlined text-xs">schedule</span> {zone.hours}
                    </span>
                  </div>
                </div>
                <span class="flex-shrink-0 flex items-center gap-1 text-[10px] font-black uppercase tracking-wider px-3 py-1.5 rounded-full" style={`background:${intensity.bg};color:${intensity.color};`}>
                  <span class="material-symbols-outlined text-xs" style="font-variation-settings:'FILL' 1;">{intensity.icon}</span>
                  {intensity.label}
                </span>
              </div>

              <div class="p-5 space-y-4">
                <!-- Vibe -->
                <p class="text-sm" style="color:#326177;">{zone.vibe}</p>

                <!-- How to get there -->
                <div class="flex items-start gap-2.5 p-3 rounded-xl" style="background:rgba(238,248,255,0.6);border:1px solid rgba(192,232,255,0.3);">
                  <span class="material-symbols-outlined text-base flex-shrink-0 mt-0.5" style="color:#006479;font-variation-settings:'FILL' 1;">directions_transit</span>
                  <div>
                    <span class="text-[10px] font-bold uppercase tracking-wider block mb-0.5" style="color:#006479;">How to get there</span>
                    <p class="text-xs font-medium" style="color:#326177;">{zone.howToGet}</p>
                  </div>
                </div>

                <!-- Pro tip -->
                <div class="flex items-start gap-2.5 p-3 rounded-xl" style={`background:${zone.color}06;border:1px solid ${zone.color}15;`}>
                  <span class="material-symbols-outlined text-base flex-shrink-0 mt-0.5" style={`color:${zone.color};font-variation-settings:'FILL' 1;`}>tips_and_updates</span>
                  <div>
                    <span class="text-[10px] font-bold uppercase tracking-wider block mb-0.5" style={`color:${zone.color};`}>Pro Tip</span>
                    <p class="text-xs" style="color:#326177;">{zone.tip}</p>
                  </div>
                </div>
              </div>
            </div>
          );
        })}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════ -->
  <!-- MORE TICKETED FESTIVALS                    -->
  <!-- ═══════════════════════════════════════════ -->
  <section class="px-6 pb-20" id="more-festivals">
    <div class="max-w-7xl mx-auto">
      <div class="flex items-center gap-3 mb-3">
        <div class="w-10 h-10 rounded-xl flex items-center justify-center" style="background:#8B5CF615;">
          <span class="material-symbols-outlined text-xl" style="color:#8B5CF6;font-variation-settings:'FILL' 1;">music_note</span>
        </div>
        <div>
          <h2 class="font-headline font-extrabold text-2xl tracking-tight" style="color:#003345;">More Ticketed Festivals</h2>
          <p class="text-xs" style="color:#6b8fa3;">Beyond the big three — more music + water across Bangkok.</p>
        </div>
      </div>
      <p class="text-sm mb-10 max-w-2xl" style="color:#326177;">Not everything happens at S2O or Siam Songkran. These festivals bring their own flavor to the Songkran party.</p>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {ticketedEvents.map(e => (
          <div id={e.id} class="card p-5 space-y-3 transition-all hover:shadow-lg hover:-translate-y-0.5 scroll-mt-28">
            <div class="flex items-start justify-between gap-3">
              <div class="w-10 h-10 rounded-xl flex items-center justify-center" style={`background:${e.color}15;`}>
                <span class="material-symbols-outlined text-2xl" style={`color:${e.color};font-variation-settings:'FILL' 1;`}>{e.icon}</span>
              </div>
              <div class="text-right">
                <div class="text-xs font-bold uppercase tracking-widest" style={`color:${e.color};`}>{e.dates}</div>
              </div>
            </div>
            <div>
              <h3 class="font-headline font-bold text-base mb-0.5" style="color:#003345;">{e.name}</h3>
              <div class="text-xs font-semibold mb-2 flex items-center gap-1" style="color:#6b8fa3;">
                <span class="material-symbols-outlined text-xs">location_on</span> {e.venue}
              </div>
              <p class="text-sm" style="color:#326177;">{e.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════ -->
  <!-- FREE STREET & CULTURAL EVENTS              -->
  <!-- ═══════════════════════════════════════════ -->
  <section class="px-6 pb-24" id="free-events" style="background:rgba(225,243,255,0.4);">
    <div class="max-w-7xl mx-auto pt-16">
      <div class="flex items-center gap-3 mb-3">
        <div class="w-10 h-10 rounded-xl flex items-center justify-center" style="background:#FF9F0A15;">
          <span class="material-symbols-outlined text-xl" style="color:#FF9F0A;font-variation-settings:'FILL' 1;">celebration</span>
        </div>
        <div>
          <h2 class="font-headline font-extrabold text-2xl tracking-tight" style="color:#003345;">Free Street & Cultural Events</h2>
          <p class="text-xs" style="color:#6b8fa3;">No tickets needed. Just show up and get wet.</p>
        </div>
      </div>
      <p class="text-sm mb-10 max-w-2xl" style="color:#326177;">Some of the best Songkran experiences are completely free. Street parties, cultural celebrations, parades, and art — all across Bangkok.</p>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {freeEvents.map(e => (
          <div class="card p-5 space-y-3 transition-all hover:shadow-lg hover:-translate-y-0.5">
            <div class="flex items-start justify-between gap-3">
              <div class="w-10 h-10 rounded-xl flex items-center justify-center" style={`background:${e.color}15;`}>
                <span class="material-symbols-outlined text-2xl" style={`color:${e.color};font-variation-settings:'FILL' 1;`}>{e.icon}</span>
              </div>
              <div class="text-right">
                <div class="text-xs font-bold uppercase tracking-widest" style={`color:${e.color};`}>{e.dates}</div>
                <div class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-[10px] font-black uppercase" style="background:#E8FFF0;color:#34C759;">
                  <span class="material-symbols-outlined text-[10px]" style="font-variation-settings:'FILL' 1;">check_circle</span>
                  Free
                </div>
              </div>
            </div>
            <div>
              <h3 class="font-headline font-bold text-base mb-0.5" style="color:#003345;">{e.name}</h3>
              <div class="text-xs font-semibold mb-2 flex items-center gap-1" style="color:#6b8fa3;">
                <span class="material-symbols-outlined text-xs">location_on</span> {e.venue}
              </div>
              <p class="text-sm" style="color:#326177;">{e.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>
