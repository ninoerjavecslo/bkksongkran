---
import BaseLayout from '../components/layout/BaseLayout.astro';
import Breadcrumb from '../components/atoms/Breadcrumb.astro';
---

<BaseLayout
  title="Advertise on BKK Songkran — Reach 50,000+ Festival Travellers"
  description="Sponsor Bangkok's leading Songkran 2026 guide. Banner placements, event features, map pins, and more. Reach tens of thousands of festival-goers planning their trip."
  canonical="https://bkksongkran.com/advertise"
>

  <!-- HEADER -->
  <section class="pt-36 pb-16 px-6" style="background:linear-gradient(180deg,rgba(225,243,255,0.9),rgba(238,248,255,0));">
    <div class="max-w-4xl mx-auto">
      <Breadcrumb crumbs={[{ label: "Home", href: "/" }, { label: "Advertise" }]} />
      <div class="text-xs font-bold tracking-[0.2em] uppercase mb-3" style="color:#006479;">Partner with us</div>
      <h1 class="font-headline font-extrabold tracking-tighter mb-5" style="font-size:clamp(2.8rem,8vw,5.5rem);color:#003345;line-height:0.9;">
        REACH THE<br/>
        <span style="background:linear-gradient(135deg,#006479,#40cef3);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;">FESTIVAL CROWD</span>
      </h1>
      <p class="text-lg max-w-2xl mb-6" style="color:#326177;line-height:1.7;">
        BKK Songkran is Bangkok's most visited independent guide for Songkran 2026 — used by international festival-goers actively planning travel, accommodation, tickets, and nightlife for April 10–15.
      </p>

      <!-- Stats row -->
      <div class="flex flex-wrap gap-6 mb-8">
        {[
          { value: '50,000+', label: 'Monthly visitors' },
          { value: '12',      label: 'In-depth guides' },
          { value: '4',       label: 'Major festivals covered' },
          { value: 'Apr 10–15', label: 'Peak traffic window' },
        ].map(s => (
          <div class="flex flex-col">
            <span class="font-headline font-black text-3xl" style="color:#006479;">{s.value}</span>
            <span class="text-xs font-semibold uppercase tracking-wider mt-0.5" style="color:#6b8fa3;">{s.label}</span>
          </div>
        ))}
      </div>

      <a href="#contact-form" class="btn-primary inline-flex px-8 py-3.5 text-sm">
        <span class="material-symbols-outlined text-base" style="font-variation-settings:'FILL' 1;">campaign</span>
        Get in touch
      </a>
    </div>
  </section>

  <!-- AUDIENCE -->
  <section class="px-6 py-16">
    <div class="max-w-4xl mx-auto">
      <h2 class="font-headline font-extrabold text-3xl mb-2" style="color:#003345;">Who visits this site</h2>
      <p class="text-sm mb-8" style="color:#6b8fa3;">International travellers, predominantly 25–40, actively planning or attending Songkran 2026 in Bangkok.</p>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        {[
          { icon: 'flight_land', title: 'International travellers', body: 'Majority fly in from Europe, Australia, US, and SE Asia specifically for the festival.' },
          { icon: 'hotel',       title: 'Accommodation hunters', body: 'Actively searching hotels and hostels near Silom, Sukhumvit, and RCA.' },
          { icon: 'confirmation_number', title: 'Ticket buyers', body: 'Planning S2O, Siam Songkran, GCircuit — actively comparing prices and availability.' },
          { icon: 'nightlife',   title: 'Nightlife & food', body: 'Looking for bars, clubs, restaurants, and pre/after-party options across Bangkok.' },
        ].map(a => (
          <div class="card p-5 space-y-3">
            <div class="w-10 h-10 rounded-xl flex items-center justify-center" style="background:rgba(0,100,121,0.08);">
              <span class="material-symbols-outlined" style="color:#006479;font-variation-settings:'FILL' 1;">{a.icon}</span>
            </div>
            <h3 class="font-bold text-sm" style="color:#003345;">{a.title}</h3>
            <p class="text-xs leading-relaxed" style="color:#6b8fa3;">{a.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- PLACEMENTS -->
  <section class="px-6 py-16" style="background:rgba(225,243,255,0.4);">
    <div class="max-w-4xl mx-auto">
      <h2 class="font-headline font-extrabold text-3xl mb-2" style="color:#003345;">Placement options</h2>
      <p class="text-sm mb-10" style="color:#6b8fa3;">All placements are reviewed manually. We only feature businesses relevant to Songkran travellers.</p>

      <div class="space-y-4">

        <!-- Homepage banner -->
        <div class="card p-6 flex gap-5 items-start">
          <div class="w-12 h-12 rounded-2xl flex-shrink-0 flex items-center justify-center" style="background:linear-gradient(135deg,rgba(0,100,121,0.12),rgba(64,206,243,0.12));">
            <span class="material-symbols-outlined text-2xl" style="color:#006479;font-variation-settings:'FILL' 1;">home</span>
          </div>
          <div class="flex-1 min-w-0">
            <div class="flex items-center gap-2 mb-1">
              <h3 class="font-headline font-bold text-lg" style="color:#003345;">Homepage banner</h3>
              <span class="text-[10px] font-black uppercase tracking-wider px-2 py-0.5 rounded-full" style="background:rgba(255,159,10,0.12);color:#c77700;">High traffic</span>
            </div>
            <p class="text-sm mb-3" style="color:#326177;line-height:1.6;">Full-width sponsored strip between the quick-links section and the featured articles on the homepage. First impression placement — seen by every visitor.</p>
            <div class="flex flex-wrap gap-3 text-xs font-semibold" style="color:#6b8fa3;">
              <span class="flex items-center gap-1"><span class="material-symbols-outlined text-xs">check_circle</span> Full-width desktop &amp; mobile</span>
              <span class="flex items-center gap-1"><span class="material-symbols-outlined text-xs">check_circle</span> Your logo, tagline &amp; link</span>
              <span class="flex items-center gap-1"><span class="material-symbols-outlined text-xs">check_circle</span> Above the fold on scroll</span>
            </div>
          </div>
        </div>

        <!-- Events page feature -->
        <div class="card p-6 flex gap-5 items-start">
          <div class="w-12 h-12 rounded-2xl flex-shrink-0 flex items-center justify-center" style="background:linear-gradient(135deg,rgba(180,0,93,0.1),rgba(233,30,140,0.1));">
            <span class="material-symbols-outlined text-2xl" style="color:#b4005d;font-variation-settings:'FILL' 1;">festival</span>
          </div>
          <div class="flex-1 min-w-0">
            <div class="flex items-center gap-2 mb-1">
              <h3 class="font-headline font-bold text-lg" style="color:#003345;">Events page feature</h3>
              <span class="text-[10px] font-black uppercase tracking-wider px-2 py-0.5 rounded-full" style="background:rgba(180,0,93,0.1);color:#b4005d;">Best for venues &amp; promoters</span>
            </div>
            <p class="text-sm mb-3" style="color:#326177;line-height:1.6;">Get your party, venue, or event listed on the <a href="/events" class="underline font-semibold" style="color:#006479;">/events</a> page alongside S2O, Siam Songkran, and GCircuit. Includes your lineup, venue details, ticket link, and a featured badge.</p>
            <div class="flex flex-wrap gap-3 text-xs font-semibold" style="color:#6b8fa3;">
              <span class="flex items-center gap-1"><span class="material-symbols-outlined text-xs">check_circle</span> Listed with headliners &amp; schedule</span>
              <span class="flex items-center gap-1"><span class="material-symbols-outlined text-xs">check_circle</span> Ticket link &amp; venue info</span>
              <span class="flex items-center gap-1"><span class="material-symbols-outlined text-xs">check_circle</span> Featured badge</span>
            </div>
          </div>
        </div>

        <!-- Bangkok map pin -->
        <div class="card p-6 flex gap-5 items-start">
          <div class="w-12 h-12 rounded-2xl flex-shrink-0 flex items-center justify-center" style="background:linear-gradient(135deg,rgba(52,199,89,0.1),rgba(0,200,100,0.1));">
            <span class="material-symbols-outlined text-2xl" style="color:#16a34a;font-variation-settings:'FILL' 1;">location_on</span>
          </div>
          <div class="flex-1 min-w-0">
            <div class="flex items-center gap-2 mb-1">
              <h3 class="font-headline font-bold text-lg" style="color:#003345;">Bangkok map pin</h3>
              <span class="text-[10px] font-black uppercase tracking-wider px-2 py-0.5 rounded-full" style="background:rgba(52,199,89,0.1);color:#16a34a;">Best for hotels &amp; bars</span>
            </div>
            <p class="text-sm mb-3" style="color:#326177;line-height:1.6;">Get pinned on our <a href="/map" class="underline font-semibold" style="color:#006479;">interactive Bangkok map</a> — the go-to reference for visitors looking for bars, clubs, hotels, and restaurants near festival areas. Sponsored pins appear at the top of their category.</p>
            <div class="flex flex-wrap gap-3 text-xs font-semibold" style="color:#6b8fa3;">
              <span class="flex items-center gap-1"><span class="material-symbols-outlined text-xs">check_circle</span> Highlighted sponsored pin</span>
              <span class="flex items-center gap-1"><span class="material-symbols-outlined text-xs">check_circle</span> Name, description &amp; website link</span>
              <span class="flex items-center gap-1"><span class="material-symbols-outlined text-xs">check_circle</span> Category-top placement</span>
            </div>
          </div>
        </div>

        <!-- Blog article -->
        <div class="card p-6 flex gap-5 items-start">
          <div class="w-12 h-12 rounded-2xl flex-shrink-0 flex items-center justify-center" style="background:linear-gradient(135deg,rgba(64,206,243,0.1),rgba(0,100,121,0.1));">
            <span class="material-symbols-outlined text-2xl" style="color:#0ea5e9;font-variation-settings:'FILL' 1;">article</span>
          </div>
          <div class="flex-1 min-w-0">
            <div class="flex items-center gap-2 mb-1">
              <h3 class="font-headline font-bold text-lg" style="color:#003345;">Article mid-banner</h3>
              <span class="text-[10px] font-black uppercase tracking-wider px-2 py-0.5 rounded-full" style="background:rgba(14,165,233,0.1);color:#0ea5e9;">Best for travel brands</span>
            </div>
            <p class="text-sm mb-3" style="color:#326177;line-height:1.6;">Sponsored placement inside our <a href="/blog" class="underline font-semibold" style="color:#006479;">12 in-depth guide articles</a> — practical content read by visitors deep in their trip-planning process. High intent, low distraction.</p>
            <div class="flex flex-wrap gap-3 text-xs font-semibold" style="color:#6b8fa3;">
              <span class="flex items-center gap-1"><span class="material-symbols-outlined text-xs">check_circle</span> Mid-content rectangle placement</span>
              <span class="flex items-center gap-1"><span class="material-symbols-outlined text-xs">check_circle</span> Clearly marked "Sponsored"</span>
              <span class="flex items-center gap-1"><span class="material-symbols-outlined text-xs">check_circle</span> All 12 blog posts or specific articles</span>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- CONTACT FORM -->
  <section class="px-6 py-16" id="contact-form">
    <div class="max-w-xl mx-auto">
      <h2 class="font-headline font-extrabold text-3xl mb-2" style="color:#003345;">Get in touch</h2>
      <p class="text-sm mb-8" style="color:#6b8fa3;">Tell us about your business and which placement interests you. We'll reply within 24 hours.</p>

      <div class="card p-6 space-y-4">

        <div>
          <label class="block text-xs font-bold uppercase tracking-wider mb-1.5" style="color:#6b8fa3;">Your name <span style="color:#b31b25;">*</span></label>
          <input id="adv-name" type="text" maxlength="100" placeholder="Marco, Alex..." class="w-full px-4 py-3 rounded-xl text-sm font-medium outline-none" style="background:rgba(225,243,255,0.7);border:1.5px solid rgba(192,232,255,0.8);color:#003345;" />
        </div>

        <div>
          <label class="block text-xs font-bold uppercase tracking-wider mb-1.5" style="color:#6b8fa3;">Business email <span style="color:#b31b25;">*</span></label>
          <input id="adv-email" type="email" maxlength="254" placeholder="you@company.com" class="w-full px-4 py-3 rounded-xl text-sm font-medium outline-none" style="background:rgba(225,243,255,0.7);border:1.5px solid rgba(192,232,255,0.8);color:#003345;" />
        </div>

        <div>
          <label class="block text-xs font-bold uppercase tracking-wider mb-1.5" style="color:#6b8fa3;">Placement interest</label>
          <div class="flex flex-wrap gap-2">
            {['Homepage banner', 'Events listing', 'Map pin', 'Article banner', 'Other'].map(p => (
              <button class="adv-placement-btn px-3 py-1.5 rounded-full text-xs font-bold border-2 transition-all" data-placement={p}
                style="border-color:rgba(192,232,255,0.8);color:#326177;background:white;">
                {p}
              </button>
            ))}
          </div>
          <input type="hidden" id="adv-placement" value="" />
        </div>

        <div>
          <label class="block text-xs font-bold uppercase tracking-wider mb-1.5" style="color:#6b8fa3;">Message <span style="color:#b31b25;">*</span></label>
          <textarea id="adv-message" maxlength="2000" rows="5" placeholder="Tell us about your business, what you'd like to promote, and any questions about pricing or availability..." class="w-full px-4 py-3 rounded-xl text-sm font-medium outline-none resize-none" style="background:rgba(225,243,255,0.7);border:1.5px solid rgba(192,232,255,0.8);color:#003345;"></textarea>
        </div>

        <div id="turnstile-advertise" class="mt-1"></div>

        <p id="adv-error" class="hidden text-xs font-bold" style="color:#b31b25;"></p>
        <p id="adv-success" class="hidden text-sm font-bold" style="color:#16a34a;">Message sent! We'll get back to you within 24 hours.</p>

        <button id="adv-submit" class="w-full flex items-center justify-center gap-2 px-6 py-3 rounded-xl text-sm font-bold text-white transition-all" style="background:linear-gradient(135deg,#006479,#40cef3);">
          <span class="material-symbols-outlined text-base" style="font-variation-settings:'FILL' 1;">send</span>
          Send Enquiry
        </button>

        <p class="text-[11px] text-center" style="color:#6b8fa3;">We review all enquiries manually and only work with businesses relevant to festival travellers.</p>
      </div>
    </div>
  </section>

</BaseLayout>

<script>
// Placement toggle buttons
document.querySelectorAll('.adv-placement-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    const val = (btn as HTMLElement).dataset.placement!;
    const input = document.getElementById('adv-placement') as HTMLInputElement;
    const alreadyActive = input.value === val;

    document.querySelectorAll('.adv-placement-btn').forEach((b: Element) => {
      const el = b as HTMLElement;
      el.style.background   = 'white';
      el.style.color        = '#326177';
      el.style.borderColor  = 'rgba(192,232,255,0.8)';
    });

    if (!alreadyActive) {
      (btn as HTMLElement).style.background  = '#006479';
      (btn as HTMLElement).style.color       = '#fff';
      (btn as HTMLElement).style.borderColor = '#006479';
      input.value = val;
    } else {
      input.value = '';
    }
  });
});

document.getElementById('adv-submit')!.addEventListener('click', async () => {
  const btn       = document.getElementById('adv-submit')!;
  const errEl     = document.getElementById('adv-error')!;
  const sucEl     = document.getElementById('adv-success')!;
  const name      = (document.getElementById('adv-name') as HTMLInputElement).value.trim();
  const email     = (document.getElementById('adv-email') as HTMLInputElement).value.trim();
  const placement = (document.getElementById('adv-placement') as HTMLInputElement).value;
  const message   = (document.getElementById('adv-message') as HTMLTextAreaElement).value.trim();

  errEl.classList.add('hidden');
  sucEl.classList.add('hidden');

  if (!name)    { errEl.textContent = 'Please enter your name.'; errEl.classList.remove('hidden'); return; }
  if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) { errEl.textContent = 'Please enter a valid email.'; errEl.classList.remove('hidden'); return; }
  if (!message) { errEl.textContent = 'Please enter a message.'; errEl.classList.remove('hidden'); return; }

  const turnstileToken = (window as any).__advTurnstileId !== null
    ? ((window as any).turnstile?.getResponse((window as any).__advTurnstileId) || '')
    : '';
  if (!turnstileToken) { errEl.textContent = 'Please complete the security check.'; errEl.classList.remove('hidden'); return; }

  const fullMessage = placement ? `[Placement interest: ${placement}]\n\n${message}` : message;

  btn.setAttribute('disabled', 'true'); btn.style.opacity = '0.6';
  try {
    const res = await fetch('/api/contact', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ type: 'advertise', name, email, message: fullMessage, turnstileToken }),
    });
    const data = await res.json();
    if (!res.ok) throw new Error(data.error || 'Failed');
    sucEl.classList.remove('hidden');
    (document.getElementById('adv-name') as HTMLInputElement).value = '';
    (document.getElementById('adv-email') as HTMLInputElement).value = '';
    (document.getElementById('adv-message') as HTMLTextAreaElement).value = '';
    (document.getElementById('adv-placement') as HTMLInputElement).value = '';
    document.querySelectorAll('.adv-placement-btn').forEach((b: Element) => {
      const el = b as HTMLElement;
      el.style.background = 'white'; el.style.color = '#326177'; el.style.borderColor = 'rgba(192,232,255,0.8)';
    });
    if ((window as any).turnstile && (window as any).__advTurnstileId !== null) (window as any).turnstile.reset((window as any).__advTurnstileId);
  } catch (e: any) {
    errEl.textContent = e.message || 'Something went wrong. Try again.';
    errEl.classList.remove('hidden');
  } finally {
    btn.removeAttribute('disabled'); btn.style.opacity = '1';
  }
});
</script>

<script src="https://challenges.cloudflare.com/turnstile/v0/api.js?render=explicit" async defer></script>
<script is:inline>
  window.__advTurnstileId = null;
  function onAdvTurnstileLoad() {
    if (window.turnstile && window.__advTurnstileId === null) {
      window.__advTurnstileId = window.turnstile.render('#turnstile-advertise', {
        sitekey: '0x4AAAAAACxlzbfzLTTpR49t',
        theme: 'light',
      });
    }
  }
  var _at = setInterval(function() { if (window.turnstile) { clearInterval(_at); onAdvTurnstileLoad(); } }, 100);
</script>
