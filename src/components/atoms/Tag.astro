---
interface Props {
  label: string;
  class?: string;
}

const { label, class: className = '' } = Astro.props;

const colors: Record<string, string> = {
  wild:        'color:#FF3B30;border-color:#FF3B30;',
  party:       'color:#FF3EA5;border-color:#FF3EA5;',
  lgbtq:       'color:#9B59B6;border-color:#9B59B6;',
  chill:       'color:#34C759;border-color:#34C759;',
  local:       'color:#FF9F0A;border-color:#FF9F0A;',
  tourist:     'color:#00B4FF;border-color:#00B4FF;',
  edm:         'color:#0066FF;border-color:#0066FF;',
  circuit:     'color:#8B00FF;border-color:#8B00FF;',
  cultural:    'color:#B8A000;border-color:#B8A000;',
  underground: 'color:#00B4FF;border-color:#00B4FF;',
  pool:        'color:#00B4FF;border-color:#00B4FF;',
  iconic:      'color:#FF3EA5;border-color:#FF3EA5;',
  free:        'color:#34C759;border-color:#34C759;',
  headliner:   'color:#FFD60A;border-color:#FFD60A;',
};

const style = colors[label.toLowerCase()] || 'color:#888;border-color:#888;';
---

<span
  class={`inline-flex items-center px-2.5 py-0.5 rounded-full text-[10px] font-bold uppercase tracking-wider border opacity-85 ${className}`}
  style={style}
>
  {label}
</span>
