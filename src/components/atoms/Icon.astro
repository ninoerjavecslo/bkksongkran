---
interface Props {
  name: string;
  fill?: boolean;
  size?: 'sm' | 'md' | 'lg' | 'xl';
  class?: string;
  weight?: number;
}

const {
  name,
  fill = false,
  size = 'md',
  class: className = '',
  weight = 400,
} = Astro.props;

const sizes = {
  sm: 'text-lg',
  md: 'text-2xl',
  lg: 'text-3xl',
  xl: 'text-4xl',
};

const fillVal = fill ? 1 : 0;
const style = `font-variation-settings: 'FILL' ${fillVal}, 'wght' ${weight}, 'GRAD' 0, 'opsz' 24;`;
---

<span
  class={`material-symbols-outlined leading-none select-none ${sizes[size]} ${className}`}
  style={style}
  aria-hidden="true"
>
  {name}
</span>
