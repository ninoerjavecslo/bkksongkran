---
import Navbar from '../organisms/Navbar.astro';
import '../../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  class?: string;
  noindex?: boolean;
  ogImage?: string;
  lang?: 'en' | 'zh';
  enUrl?: string;
}

const {
  title = 'Bangkok Songkran 2026 — Complete Festival Guide, Lineups & Live Map',
  description = 'The complete guide to Songkran 2026 in Bangkok. Real lineups, live crowd map, AI trip planner, survival checklist. April 10-15, 2026.',
  canonical,
  class: className = '',
  noindex = false,
  ogImage = 'https://bkksongkran.com/og-image.jpg',
  lang = 'en',
  enUrl,
} = Astro.props;
---

<!DOCTYPE html>
<html lang={lang === 'zh' ? 'zh-Hans' : 'en'} class="scroll-smooth">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="theme-color" content="#006479" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <title>{title}</title>
  <meta name="description" content={description} />

  <!-- Open Graph -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:image" content={ogImage} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:image:type" content="image/jpeg" />
  <meta property="og:site_name" content="BKK Songkran" />
  <meta property="og:locale" content="en_US" />
  <meta property="og:url" content={canonical ?? Astro.url.href} />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />
  <meta name="twitter:image:alt" content="Bangkok Songkran 2026 — The Complete Festival Guide" />

  <!-- Canonical & indexing -->
  {canonical && <link rel="canonical" href={canonical} />}
  {lang === 'zh' && enUrl && (
    <>
      <link rel="alternate" hreflang="zh-Hans" href={canonical ?? Astro.url.href} />
      <link rel="alternate" hreflang="en" href={enUrl} />
      <link rel="alternate" hreflang="x-default" href={enUrl} />
    </>
  )}
  {lang === 'en' && canonical && (
    <>
      <link rel="alternate" hreflang="en" href={canonical} />
      <link rel="alternate" hreflang="zh-Hans" href={canonical.replace('https://bkksongkran.com', 'https://bkksongkran.com/zh')} />
      <link rel="alternate" hreflang="x-default" href={canonical} />
    </>
  )}
  <meta name="robots" content={noindex ? 'noindex, nofollow' : 'index, follow'} />
  <meta name="googlebot" content={noindex ? 'noindex, nofollow' : 'index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1'} />

  <!-- PWA -->
  <link rel="manifest" href="/manifest.json" />
  <meta name="mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-title" content="BKK Songkran" />
  <meta name="apple-mobile-web-app-status-bar-style" content="default" />

  <!-- DNS prefetch for third parties — resolves before browser needs them -->
  <link rel="dns-prefetch" href="https://fonts.googleapis.com" />
  <link rel="dns-prefetch" href="https://fonts.gstatic.com" />
  <link rel="dns-prefetch" href="https://www.googletagmanager.com" />
  <link rel="dns-prefetch" href="https://challenges.cloudflare.com" />

  <!-- Preconnect for fonts (used on every page, worth the early connection) -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

  <!-- Prevent CLS: reserve space for headline font before it loads -->
  <style is:inline>
    @font-face { font-family: 'Bebas Neue'; font-display: swap; src: local('Bebas Neue'); }
    .font-headline { font-family: 'Bebas Neue', 'Arial Narrow', Arial, sans-serif; }
  </style>

  <!-- Fonts — single combined request, display=swap avoids invisible text -->
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Plus+Jakarta+Sans:ital,wght@0,400;0,600;0,700;0,800;1,800&family=Be+Vietnam+Pro:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  <!-- Material Symbols — swap so text stays visible while icon font loads -->
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200&display=swap" rel="stylesheet" />

  <!-- Organization Schema -->
  <script type="application/ld+json" is:inline>{"@context":"https://schema.org","@type":"Organization","name":"BKK Songkran","url":"https://bkksongkran.com","logo":"https://bkksongkran.com/og-image.jpg","sameAs":[]}</script>

  <slot name="head" />

  <!-- GTM — async so it never blocks rendering -->
  <script is:inline>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src='https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);})(window,document,'script','dataLayer','GTM-W2PGW75M');</script>

  <style is:global>
    .material-symbols-outlined{font-variation-settings:'FILL' 0,'wght' 400,'GRAD' 0,'opsz' 24;}
    .glass{background:rgba(255,255,255,0.6);backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);border:1px solid rgba(255,255,255,0.4);}
    .glass-cyan{background:rgba(64,206,243,0.1);backdrop-filter:blur(16px);-webkit-backdrop-filter:blur(16px);border:1px solid rgba(64,206,243,0.25);}
    .liquid-gradient{background:linear-gradient(135deg,#006479 0%,#40cef3 100%);}
    .liquid-warm{background:linear-gradient(135deg,#964300 0%,#ffc5a6 100%);}
    .liquid-hot{background:linear-gradient(135deg,#b4005d 0%,#ff8eb2 100%);}
    .mesh-bg{background-image:radial-gradient(at 20% 20%,rgba(64,206,243,.18) 0,transparent 50%),radial-gradient(at 80% 10%,rgba(0,100,121,.12) 0,transparent 50%),radial-gradient(at 60% 80%,rgba(180,0,93,.07) 0,transparent 50%);}
    .text-gradient{background:linear-gradient(135deg,#006479,#40cef3);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;}
    .text-gradient-hot{background:linear-gradient(135deg,#b4005d,#ff8eb2);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;}
    .no-scrollbar::-webkit-scrollbar{display:none;}
    .no-scrollbar{-ms-overflow-style:none;scrollbar-width:none;}
    .card{background:#fff;border-radius:1rem;box-shadow:0 2px 24px rgba(0,51,69,.08);border:1px solid rgba(192,232,255,0.5);transition:all .3s;}
    .card:hover{box-shadow:0 8px 48px rgba(0,51,69,.14);transform:translateY(-2px);}
    .btn-primary{display:inline-flex;align-items:center;justify-content:center;gap:8px;background:linear-gradient(135deg,#006479,#40cef3);color:#fff;font-family:'Plus Jakarta Sans',sans-serif;font-weight:700;border-radius:9999px;border:none;cursor:pointer;transition:all .2s;box-shadow:0 4px 20px rgba(64,206,243,.3);}
    .btn-primary:hover{transform:scale(1.04);box-shadow:0 6px 28px rgba(64,206,243,.4);}
    .btn-ghost{display:inline-flex;align-items:center;justify-content:center;gap:8px;background:rgba(255,255,255,0.6);backdrop-filter:blur(16px);color:#006479;font-family:'Plus Jakarta Sans',sans-serif;font-weight:700;border-radius:9999px;border:1px solid rgba(0,100,121,.2);cursor:pointer;transition:all .2s;}
    .btn-ghost:hover{background:rgba(255,255,255,0.85);transform:scale(1.03);}
    html,body{overflow-x:hidden;}
    body{background:#eef8ff;color:#003345;font-family:'Be Vietnam Pro',sans-serif;-webkit-font-smoothing:antialiased;}
    ::selection{background:#40cef3;color:#002a34;}
    .animate-in{animation:slideUp .5s ease forwards;opacity:0;}
    @keyframes slideUp{from{opacity:0;transform:translateY(20px)}to{opacity:1;transform:translateY(0)}}
    .day-highlight{background:linear-gradient(135deg,#006479,#40cef3);color:#fff;border-radius:9999px;}
  </style>
</head>
<body>
  <!-- GTM noscript fallback -->
  <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-W2PGW75M" height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>

  <!-- Noise overlay -->
  <div class="pointer-events-none fixed inset-0 z-0 opacity-[0.022]" style="background-image:url('data:image/svg+xml,%3Csvg viewBox=%220 0 256 256%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cfilter id=%22n%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.9%22 numOctaves=%224%22 stitchTiles=%22stitch%22/%3E%3C/filter%3E%3Crect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23n)%22/%3E%3C/svg%3E');"></div>
  <!-- Mesh bg -->
  <div class="pointer-events-none fixed inset-0 z-0 mesh-bg opacity-70"></div>

  <Navbar />

  <main class={`relative z-10 ${className}`}>
    <slot />
  </main>

  <!-- Footer -->
  <footer class="relative z-10 border-t border-surface-container-high" style="background:rgba(255,255,255,0.5);backdrop-filter:blur(12px);">
    <div class="max-w-7xl mx-auto px-6 py-16">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-10 mb-12">
        <div class="col-span-2 md:col-span-1 space-y-4">
          <a href="/" class="font-headline text-2xl font-black italic tracking-tighter block" style="color:#006479;">
            SONGKRAN<span style="color:#b4005d;"> 2026</span>
          </a>
          <p class="text-sm leading-relaxed" style="color:#326177;">The complete guide to Songkran 2026 in Bangkok. Lineups, water fight zones, transport, survival tips.</p>
          <p class="text-xs" style="color:#6b8fa3;">April 10–15, 2026 · Bangkok, Thailand</p>
        </div>
        <div class="space-y-3">
          <h4 class="font-headline font-bold text-xs uppercase tracking-widest" style="color:#326177;">Festival</h4>
          <ul class="space-y-2">
            <li><a href="/events" class="text-sm transition-colors hover:text-primary hover:underline" style="color:#326177;">All Events</a></li>
            <li><a href="/events#s2o" class="text-sm transition-colors hover:text-primary hover:underline" style="color:#326177;">S2O Festival</a></li>
            <li><a href="/events#siam" class="text-sm transition-colors hover:text-primary hover:underline" style="color:#326177;">Siam Songkran</a></li>
            <li><a href="/events#gcircuit" class="text-sm transition-colors hover:text-primary hover:underline" style="color:#326177;">GCircuit</a></li>
            <li><a href="/events#water-fights" class="text-sm transition-colors hover:text-primary hover:underline" style="color:#326177;">Water Fight Zones</a></li>
          </ul>
        </div>
        <div class="space-y-3">
          <h4 class="font-headline font-bold text-xs uppercase tracking-widest" style="color:#326177;">Tools</h4>
          <ul class="space-y-2">
            <li><a href="/survival-kit" class="text-sm transition-colors hover:text-primary hover:underline" style="color:#326177;">Survival Kit</a></li>
            <li><a href="/map" class="text-sm transition-colors hover:text-primary hover:underline" style="color:#326177;">Bangkok Map</a></li>
            <li><a href="/heat-map" class="text-sm transition-colors hover:text-primary hover:underline" style="color:#326177;">Live Heat Map</a></li>
            <li><a href="/ai" class="text-sm transition-colors hover:text-primary hover:underline" style="color:#326177;">AI Planner</a></li>
            <li><a href="/blog" class="text-sm transition-colors hover:text-primary hover:underline" style="color:#326177;">Songkran Guide</a></li>
            <li><a href="/meetup" class="text-sm transition-colors hover:text-primary hover:underline" style="color:#326177;">Who's Going?</a></li>
            <li><a href="/gay-guide" class="text-sm transition-colors hover:text-primary hover:underline" style="color:#326177;">LGBTQ+ Guide</a></li>
          </ul>
        </div>
        <div class="space-y-3">
          <h4 class="font-headline font-bold text-xs uppercase tracking-widest" style="color:#326177;">Legal</h4>
          <ul class="space-y-2">
            <li><a href="/privacy" class="text-sm transition-colors hover:text-primary hover:underline" style="color:#326177;">Privacy Policy</a></li>
            <li><a href="/terms" class="text-sm transition-colors hover:text-primary hover:underline" style="color:#326177;">Terms of Use</a></li>
            <li><a href="/disclaimer" class="text-sm transition-colors hover:text-primary hover:underline" style="color:#326177;">Disclaimer</a></li>
            <li><a href="/privacy#cookies" class="text-sm transition-colors hover:text-primary hover:underline" style="color:#326177;">Cookie Policy</a></li>
            <li><a href="/contact" class="text-sm transition-colors hover:text-primary hover:underline" style="color:#326177;">Contact</a></li>
            <li><a href="/advertise" class="text-sm transition-colors hover:text-primary hover:underline font-bold" style="color:#006479;">Advertise</a></li>
          </ul>
        </div>
      </div>
      <div class="pt-8 border-t flex flex-col sm:flex-row justify-between items-center gap-4" style="border-color:rgba(192,232,255,0.6);">
        <p class="text-xs" style="color:#4f7d93;">© 2026 BKK Songkran · Bangkok, Thailand</p>
        <a id="footer-lang-switch" href="#" class="inline-flex items-center gap-1.5 px-4 py-1.5 rounded-full text-xs font-bold border transition-all hover:scale-105" style="border-color:rgba(0,100,121,0.25);color:#006479;background:rgba(0,100,121,0.06);"></a>
        <p class="text-xs" style="color:#4f7d93;">Independent guide — not affiliated with any festival organiser</p>
      </div>
    </div>
  </footer>


<script is:inline>
(function() {
  var path = window.location.pathname;
  var isZh = path.startsWith('/zh');
  var noZh = ['/tickets', '/meetup', '/privacy', '/terms', '/disclaimer', '/delete-ticket'];
  function switchPath(p) {
    if (p.startsWith('/zh')) return p.replace(/^\/zh/, '') || '/';
    if (p === '/') return '/zh';
    if (noZh.some(function(x) { return p === x || p.startsWith(x + '/'); })) return '/zh';
    return '/zh' + p;
  }
  var el = document.getElementById('footer-lang-switch');
  if (el) {
    el.href = switchPath(path);
    el.setAttribute('aria-label', isZh ? 'Switch to English' : '切换到中文');
    var flag = document.createElement('span');
    flag.style.fontSize = '14px';
    flag.textContent = isZh ? '🇬🇧' : '🇨🇳';
    var label = document.createTextNode(isZh ? ' English' : ' 中文');
    el.appendChild(flag);
    el.appendChild(label);
  }
})();
</script>
</body>
</html>
