---
import CrowdMeter from '../atoms/CrowdMeter.astro';
import Icon from '../atoms/Icon.astro';
import { zones } from '../../data/index';
---

<div class="relative">
  <!-- Live indicator -->
  <div class="flex items-center gap-2 mb-4">
    <span class="relative flex h-3 w-3">
      <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-error opacity-75"></span>
      <span class="relative inline-flex rounded-full h-3 w-3 bg-error"></span>
    </span>
    <span class="text-xs font-bold text-error uppercase tracking-widest">Live Crowd Reports</span>
    <span class="text-xs text-on-surface-variant" id="last-updated">Updating...</span>
  </div>

  <!-- Zone list -->
  <div class="space-y-3" id="zone-list">
    {zones.map(zone => (
      <div
        class="flex items-center gap-4 p-4 rounded-xl border border-surface-container-high bg-white/70
               hover:bg-white/90 hover:shadow-sm transition-all duration-200 cursor-pointer group"
        data-zone-id={zone.id}
      >
        <div class="flex-1 min-w-0">
          <div class="flex items-center gap-2 mb-1 flex-wrap">
            <h4 class="font-bold text-sm text-on-surface">{zone.name}</h4>
            <span class="text-xs text-on-surface-variant">{zone.area}</span>
          </div>
          <p class="text-xs text-on-surface-variant leading-relaxed">{zone.desc}</p>
          <div class="flex items-center gap-3 mt-2">
            <CrowdMeter level={zone.crowd as any} size="sm" />
            <span class="text-xs text-on-surface-variant flex items-center gap-1">
              <Icon name="schedule" size="sm" />
              {zone.bestTime}
            </span>
          </div>
        </div>
        <!-- Report button -->
        <button
          class="flex-shrink-0 opacity-0 group-hover:opacity-100 transition-opacity
                 px-3 py-1.5 rounded-full text-xs font-bold border border-primary/30 text-primary
                 hover:bg-primary hover:text-white hover:border-primary"
          data-zone={zone.id}
          onclick="reportCrowd(this)"
        >
          Report
        </button>
      </div>
    ))}
  </div>

  <!-- Report modal -->
  <div id="report-modal" class="hidden fixed inset-0 z-50 flex items-end sm:items-center justify-center p-4">
    <div class="absolute inset-0 backdrop-blur-md" style="background:rgba(0,51,69,0.4);" onclick="closeReport()"></div>
    <div class="relative w-full max-w-sm rounded-3xl p-7 space-y-5" style="background:rgba(255,255,255,0.97);box-shadow:0 24px 80px rgba(0,51,69,0.2),0 0 0 1px rgba(192,232,255,0.4);">
      <h3 class="font-headline font-extrabold text-xl" style="color:#003345;">How crowded is it?</h3>
      <p class="text-sm font-semibold" style="color:#326177;" id="report-zone-name"></p>
      <div class="grid grid-cols-2 gap-3">
        {(['low', 'medium', 'high', 'insane'] as const).map(level => {
          const cfg = {
            low: { label: 'Low', desc: 'Easy to move', icon: 'sentiment_satisfied', color: '#34C759', bg: '#E8FFF0' },
            medium: { label: 'Medium', desc: 'Getting busy', icon: 'groups', color: '#FF9F0A', bg: '#FFF8E0' },
            high: { label: 'High', desc: 'Very crowded', icon: 'warning', color: '#FF6B35', bg: '#FFF0E0' },
            insane: { label: 'Insane', desc: 'Absolute chaos', icon: 'local_fire_department', color: '#FF3B30', bg: '#FFE8E8' },
          }[level];
          return (
            <button
              class="p-4 rounded-2xl text-left transition-all active:scale-95 hover:-translate-y-0.5 hover:shadow-md"
              style={`background:${cfg.bg};border:2px solid ${cfg.color}30;`}
              onclick={`submitReport('${level}')`}
            >
              <div class="font-bold text-sm flex items-center gap-2 mb-1">
                <span class="material-symbols-outlined text-lg" style={`color:${cfg.color};font-variation-settings:'FILL' 1;`}>{cfg.icon}</span>
                <span style={`color:${cfg.color};`}>{cfg.label}</span>
              </div>
              <div class="text-xs" style="color:#6b8fa3;">{cfg.desc}</div>
            </button>
          );
        })}
      </div>
      <button onclick="closeReport()" class="w-full text-center text-sm font-semibold py-2.5 rounded-xl transition-all hover:bg-surface" style="color:#6b8fa3;">
        Cancel
      </button>
    </div>
  </div>

  <!-- Submit confirmation toast -->
  <div id="toast" class="hidden fixed bottom-6 left-1/2 -translate-x-1/2 z-50
                          px-6 py-3.5 rounded-2xl text-sm font-bold text-white
                          flex items-center gap-2 animate-slide-up"
       style="background:linear-gradient(135deg,#006479,#40cef3);box-shadow:0 8px 32px rgba(0,100,121,0.3);">
    <span class="material-symbols-outlined text-base" style="font-variation-settings:'FILL' 1;">check_circle</span> Report submitted — thanks!
  </div>
</div>

<script>
// Firebase config — replace with real config
const FIREBASE_CONFIG = {
  // Add your Firebase config here:
  // apiKey: "...",
  // databaseURL: "https://your-project-default-rtdb.firebaseio.com",
};

let activeZone: string | null = null;

function reportCrowd(btn: HTMLButtonElement) {
  activeZone = btn.dataset.zone || null;
  const zoneEl = document.querySelector(`[data-zone-id="${activeZone}"] h4`);
  const nameEl = document.getElementById('report-zone-name');
  if (nameEl && zoneEl) nameEl.textContent = zoneEl.textContent || '';
  document.getElementById('report-modal')?.classList.remove('hidden');
}

function closeReport() {
  document.getElementById('report-modal')?.classList.add('hidden');
  activeZone = null;
}

function submitReport(level: string) {
  // In production: write to Firebase Realtime DB
  // firebase.database().ref(`zones/${activeZone}/reports`).push({ level, ts: Date.now() });
  console.log('Report:', activeZone, level);
  closeReport();
  showToast();
}

function showToast() {
  const toast = document.getElementById('toast');
  if (!toast) return;
  toast.classList.remove('hidden');
  setTimeout(() => toast.classList.add('hidden'), 3000);
}

// Simulate live updates every 30s
function updateLastUpdated() {
  const el = document.getElementById('last-updated');
  if (el) el.textContent = `Updated ${new Date().toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit' })}`;
}
updateLastUpdated();
setInterval(updateLastUpdated, 30000);

// Make functions global
(window as any).reportCrowd = reportCrowd;
(window as any).closeReport = closeReport;
(window as any).submitReport = submitReport;
</script>
