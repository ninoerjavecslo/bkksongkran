---
import ScheduleRow from '../molecules/ScheduleRow.astro';
import Button from '../atoms/Button.astro';

interface Props {
  festival: any;
}
const { festival } = Astro.props;
const days = Object.keys(festival.schedule);
---

<div class="space-y-4" id={`schedule-${festival.id}`}>
  <!-- Festival header -->
  <div class="flex items-start justify-between gap-4 flex-wrap">
    <div>
      <h3 class="font-headline text-2xl font-extrabold" style={`color:${festival.colorDark};`}>
        {festival.name}
      </h3>
      <p class="text-sm text-on-surface-variant font-medium">
        {festival.venue} · {festival.dates}
      </p>
    </div>
    <Button href={festival.url} variant="primary" size="sm" external>
      <span class="material-symbols-outlined text-base" style="font-variation-settings:'FILL' 1;">confirmation_number</span> Tickets
    </Button>
  </div>

  <!-- Day selector -->
  <div class="flex gap-2 overflow-x-auto no-scrollbar pb-1" id={`day-tabs-${festival.id}`}>
    {days.map((day, i) => (
      <button
        class={`day-tab flex-shrink-0 px-4 py-2 rounded-full text-sm font-bold border transition-all duration-200
          ${i === 0
            ? 'text-white border-transparent'
            : 'border-surface-container-high text-on-surface-variant bg-white/60 hover:border-primary/40'
          }`}
        style={i === 0 ? `background:${festival.colorDark};` : ''}
        data-day={day}
        data-festival={festival.id}
      >
        {day}
      </button>
    ))}
  </div>

  <!-- Schedule panels — all rendered, JS toggles visibility -->
  {days.map((day, i) => (
    <div
      class={`schedule-panel space-y-2 ${i === 0 ? '' : 'hidden'}`}
      data-day={day}
      data-festival={festival.id}
    >
      {festival.schedule[day].map((slot: any) => (
        <ScheduleRow
          time={slot.time}
          end={slot.end}
          name={slot.name}
          sub={slot.sub}
          genre={slot.genre}
          headliner={slot.headliner}
          isPool={slot.isPool}
          accentColor={festival.colorDark}
        />
      ))}
    </div>
  ))}
</div>

<script>
// Day tab switching — scoped to each festival
document.querySelectorAll<HTMLButtonElement>('.day-tab').forEach(btn => {
  btn.addEventListener('click', () => {
    const festId = btn.dataset.festival!;
    const day = btn.dataset.day!;

    // Update tabs
    document.querySelectorAll<HTMLButtonElement>(`.day-tab[data-festival="${festId}"]`).forEach(t => {
      const isActive = t.dataset.day === day;
      // Get festival color from active state
      const schedEl = document.getElementById(`schedule-${festId}`);
      const colorDark = schedEl?.querySelector<HTMLElement>('h3')?.style.color || '#006479';
      t.className = `day-tab flex-shrink-0 px-4 py-2 rounded-full text-sm font-bold border transition-all duration-200 ${
        isActive
          ? 'text-white border-transparent'
          : 'border-surface-container-high text-on-surface-variant bg-white/60 hover:border-primary/40'
      }`;
      t.style.background = isActive ? colorDark : '';
    });

    // Show/hide panels
    document.querySelectorAll<HTMLElement>(`.schedule-panel[data-festival="${festId}"]`).forEach(panel => {
      panel.classList.toggle('hidden', panel.dataset.day !== day);
    });
  });
});
</script>
