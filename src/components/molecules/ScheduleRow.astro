---
import Badge from '../atoms/Badge.astro';
import Icon from '../atoms/Icon.astro';

interface Props {
  time?: string;
  end?: string;
  name: string;
  sub?: string;
  genre: string;
  headliner?: boolean;
  isPool?: boolean;
  accentColor?: string;
}

const { time, end, name, sub, genre, headliner = false, isPool = false, accentColor = '#006479' } = Astro.props;
const hasTime = !!time;
---

<div
  class={`flex gap-4 p-4 rounded-xl border transition-all duration-200 hover:shadow-md group
    ${isPool
      ? 'border-2 border-dashed'
      : headliner
        ? 'border-2 shadow-sm'
        : 'border-surface-container-high bg-white/60'
    }`}
  style={isPool
    ? 'border-color:#06b6d4;background:linear-gradient(135deg,rgba(6,182,212,0.08),rgba(14,165,233,0.05));'
    : headliner
      ? `border-color:${accentColor}60;background:${accentColor}08;`
      : ''}
>
  <!-- Time column — only shown when time is provided -->
  {hasTime && (
    <div class="w-20 flex-shrink-0 text-center">
      <div class="font-headline font-bold text-sm" style={headliner ? `color:${accentColor};` : 'color:#326177;'}>
        {time}
      </div>
      <div class="text-[10px] text-on-surface-variant font-medium">→ {end}</div>
    </div>
  )}

  <!-- Divider — only shown when time is present -->
  {hasTime && (
    <div class="w-px self-stretch rounded-full" style={`background:${headliner ? accentColor : '#d0e8ff'};opacity:${headliner ? '0.6' : '1'};`}></div>
  )}

  <!-- Content -->
  <div class="flex-1 min-w-0">
    <div class="flex items-start justify-between gap-2 flex-wrap">
      <div>
        {isPool && (
          <div class="text-[9px] font-bold uppercase tracking-widest mb-1 flex items-center gap-1" style="color:#0891b2;">
            <span class="material-symbols-outlined text-[11px]" style="font-variation-settings:'FILL' 1;">pool</span>
            Pool Party
          </div>
        )}
        {headliner && !isPool && (
          <div class="text-[9px] font-bold uppercase tracking-widest mb-1" style={`color:${accentColor};`}>
            ★ Headliner
          </div>
        )}
        <h4 class={`font-headline font-bold leading-tight ${headliner ? 'text-base' : 'text-sm'}`}
          style={isPool ? 'color:#0e7490;' : headliner ? `color:${accentColor};` : ''}>
          {name}
        </h4>
        {sub && <p class="text-xs text-on-surface-variant mt-0.5 italic">{sub}</p>}
      </div>
    </div>
  </div>
</div>
