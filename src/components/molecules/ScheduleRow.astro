---
import Badge from '../atoms/Badge.astro';
import Icon from '../atoms/Icon.astro';

interface Props {
  time: string;
  end: string;
  name: string;
  sub?: string;
  genre: string;
  headliner?: boolean;
  isPool?: boolean;
  accentColor?: string;
}

const { time, end, name, sub, genre, headliner = false, isPool = false, accentColor = '#006479' } = Astro.props;
---

<div
  class={`flex gap-4 p-4 rounded-xl border transition-all duration-200 hover:shadow-md group
    ${headliner
      ? 'border-2 shadow-sm'
      : isPool
        ? 'border-dashed border-primary/30 bg-primary/5'
        : 'border-surface-container-high bg-white/60'
    }`}
  style={headliner ? `border-color:${accentColor}60;background:${accentColor}08;` : ''}
>
  <!-- Time column -->
  <div class="w-20 flex-shrink-0 text-center">
    <div class="font-headline font-bold text-sm" style={headliner ? `color:${accentColor};` : 'color:#326177;'}>
      {time}
    </div>
    <div class="text-[10px] text-on-surface-variant font-medium">→ {end}</div>
  </div>

  <!-- Divider -->
  <div class="w-px self-stretch rounded-full" style={`background:${headliner ? accentColor : '#d0e8ff'};opacity:${headliner ? '0.6' : '1'};`}></div>

  <!-- Content -->
  <div class="flex-1 min-w-0">
    <div class="flex items-start justify-between gap-2 flex-wrap">
      <div>
        {headliner && (
          <div class="text-[9px] font-bold uppercase tracking-widest mb-1" style={`color:${accentColor};`}>
            ★ Headliner
          </div>
        )}
        {isPool && (
          <div class="text-[9px] font-bold uppercase tracking-widest mb-1 text-primary opacity-70">
            <span class="material-symbols-outlined text-[9px]" style="font-variation-settings:'FILL' 1;">pool</span> Pool Party
          </div>
        )}
        <h4 class={`font-headline font-bold leading-tight ${headliner ? 'text-base' : 'text-sm'}`} style={headliner ? `color:${accentColor};` : ''}>
          {name}
        </h4>
        {sub && <p class="text-xs text-on-surface-variant mt-0.5 italic">{sub}</p>}
      </div>
      <span
        class="text-[10px] font-bold px-2 py-0.5 rounded-full flex-shrink-0"
        style={`background:${accentColor}12;color:${accentColor};`}
      >
        {genre}
      </span>
    </div>
  </div>
</div>
