---
import Badge from '../atoms/Badge.astro';
import CrowdMeter from '../atoms/CrowdMeter.astro';
import Button from '../atoms/Button.astro';
import Icon from '../atoms/Icon.astro';

interface Props {
  id: string;
  name: string;
  tagline: string;
  dates: string;
  venue: string;
  area: string;
  price: string;
  color: string;
  colorDark: string;
  crowd: 'low' | 'medium' | 'high' | 'insane';
  description: string;
  url?: string;
  featured?: boolean;
  type: string;
  class?: string;
}

const {
  id, name, tagline, dates, venue, area, price, color, colorDark,
  crowd, description, url, featured = false, type, class: className = ''
} = Astro.props;

const typeLabel = { edm: 'EDM Festival', circuit: 'Circuit Party', cultural: 'Cultural' }[type] || type;
---

<article
  class={`card overflow-hidden group cursor-pointer relative ${featured ? 'ring-2' : ''} ${className}`}
  style={featured ? `ring-color:${color};` : ''}
  data-event-id={id}
>
  <!-- Color bar top -->
  <div class="h-1.5 w-full" style={`background:linear-gradient(90deg,${colorDark},${color});`}></div>

  <!-- Featured badge -->
  {featured && (
    <div class="absolute top-4 right-4 z-10">
      <Badge variant="live" size="xs"><span class="material-symbols-outlined text-[9px]" style="font-variation-settings:'FILL' 1;">star</span> Featured</Badge>
    </div>
  )}

  <div class="p-6 flex flex-col gap-4 relative">
    <!-- Header -->
    <div class="flex items-start justify-between gap-3">
      <div>
        <div class="flex items-center gap-2 mb-2 flex-wrap">
          <Badge variant="custom" bg={`${color}20`} color={colorDark} size="xs">
            {typeLabel}
          </Badge>
          <span class="text-xs font-bold text-on-surface-variant">{dates}</span>
        </div>
        <h3 class="font-headline text-xl font-extrabold text-on-surface leading-tight">{name}</h3>
        <p class="text-sm font-semibold italic" style={`color:${colorDark};`}>{tagline}</p>
      </div>
    </div>

    <!-- Description -->
    <p class="text-sm text-on-surface-variant leading-relaxed line-clamp-2">{description}</p>

    <!-- Meta row -->
    <div class="flex items-center gap-3 flex-wrap">
      <CrowdMeter level={crowd} size="sm" />
      <div class="flex items-center gap-1 text-xs text-on-surface-variant">
        <Icon name="location_on" size="sm" />
        <span>{area}</span>
      </div>
    </div>

    <!-- Venue -->
    <div class="flex items-center gap-2 py-3 border-t border-surface-container-high">
      <Icon name="place" size="sm" class="text-on-surface-variant" />
      <span class="text-xs font-semibold text-on-surface-variant">{venue}</span>
    </div>

    <!-- Footer -->
    <div class="flex items-center justify-between">
      <div class="flex gap-2">
        <Button href={`/events#${id}`} variant="ghost" size="sm">
          Schedule
        </Button>
        {url && (
          <Button href={url} variant="primary" size="sm" external>
            Tickets
          </Button>
        )}
      </div>
    </div>
  </div>
</article>
