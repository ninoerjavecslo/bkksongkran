# OpenAI API key for /api/chat.ts (server-side only, never expose to client)
OPENAI_API_KEY=sk-proj-YOUR_OPENAI_API_KEY_HERE

# Resend email service API key for /api/contact.ts
RESEND_API_KEY=re_YOUR_RESEND_API_KEY_HERE

# Contact form recipient email address
CONTACT_RECIPIENT_EMAIL=your@email.com

# Mapbox public token for heat map visualization (safe to expose)
PUBLIC_MAPBOX_TOKEN=pk.YOUR_MAPBOX_PUBLIC_TOKEN_HERE

# Supabase project URL (safe to expose)
PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Supabase anonymous public key for meetup entries (safe to expose, limited permissions)
PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Cloudflare Turnstile secret key for CAPTCHA verification (server-side only)
TURNSTILE_SECRET=your_turnstile_secret_key_here

# Setup instructions:
# 1. Copy this file: cp .env.example .env.local
# 2. Replace placeholder values with your actual keys
# 3. .env.local is gitignored and only used locally
# 4. Production keys are set in Vercel environment variables dashboard
